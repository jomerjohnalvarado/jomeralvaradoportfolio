                <i class="fas fa-heading text-blue-600 dark:text-blue-400"></i>
                <span class="text-gray-900 dark:text-slate-100">Subject</span>
                <span class="text-red-600 dark:text-red-400">*</span>
              </label>
              <input 
                type="text"
                id="subjectLine"
                name="subject"
                placeholder="What is this about?"
                required
