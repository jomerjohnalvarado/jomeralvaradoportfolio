                <i class="fas fa-phone text-blue-600 dark:text-blue-400"></i>
                <span class="text-gray-900 dark:text-slate-100">Phone Number</span>
                <span class="text-slate-500 dark:text-slate-400 text-xs font-normal">(Optional)</span>
