    </div>

    <!-- Icon 4: JavaScript -->
    <div class="absolute top-1/2 right-1/4 w-20 h-20 opacity-25 dark:opacity-15 animate-float-tech" style="animation-delay: 3s;">
      <div class="w-full h-full border-2 border-cyan-600/60 dark:border-cyan-500/50 rounded-xl rotate-12 flex items-center justify-center">
        <i class="fab fa-js text-cyan-700 dark:text-cyan-400 text-xl -rotate-12"></i>
      </div>
