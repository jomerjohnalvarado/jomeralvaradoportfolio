<%- include('./layouts/header.ejs') %>

<div class="pt-32 pb-20 relative overflow-hidden" id="app">
  <!-- Adaptive Animated Technology Background -->
  <div class="fixed inset-0 -z-10 overflow-hidden" id="bg-container">
    <!-- Gradient Background - Dark Blue Theme -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-blue-50/80 to-indigo-50/60 dark:from-slate-950 dark:via-blue-950/70 dark:to-indigo-950/40"></div>
    
    <!-- Animated Code Lines -->
    <svg class="absolute inset-0 w-full h-full opacity-10 dark:opacity-30" preserveAspectRatio="none">
      <defs>
        <linearGradient id="lineGradient1" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#1e40af;stop-opacity:0" />
          <stop offset="50%" style="stop-color:#1e40af;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#1e40af;stop-opacity:0" />
        </linearGradient>
        <linearGradient id="lineGradient2" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#0284c7;stop-opacity:0" />
          <stop offset="50%" style="stop-color:#0284c7;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#0284c7;stop-opacity:0" />
        </linearGradient>
        <linearGradient id="lineGradient3" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#4f46e5;stop-opacity:0" />
          <stop offset="50%" style="stop-color:#4f46e5;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#4f46e5;stop-opacity:0" />
        </linearGradient>
        <linearGradient id="lg4" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#06b6d4;stop-opacity:0"/>
          <stop offset="50%" style="stop-color:#06b6d4;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:0"/>
        </linearGradient>
        <linearGradient id="lg5" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#8b5cf6;stop-opacity:0"/>
          <stop offset="50%" style="stop-color:#8b5cf6;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#8b5cf6;stop-opacity:0"/>
        </linearGradient>
      </defs>
      
      <!-- Animated Horizontal Lines -->
      <line x1="0" y1="6%"  x2="100%" y2="6%"  stroke="url(#lineGradient1)" stroke-width="2" class="animate-scan-line" style="animation-delay: 0s;"/>
      <line x1="0" y1="18%" x2="100%" y2="18%" stroke="url(#lineGradient2)" stroke-width="2" class="animate-scan-line" style="animation-delay: 0.6s;"/>
      <line x1="0" y1="30%" x2="100%" y2="30%" stroke="url(#lg4)" stroke-width="2" class="animate-scan-line" style="animation-delay: 1.2s;"/>
      <line x1="0" y1="42%" x2="100%" y2="42%" stroke="url(#lineGradient3)" stroke-width="2" class="animate-scan-line" style="animation-delay: 1.8s;"/>
      <line x1="0" y1="54%" x2="100%" y2="54%" stroke="url(#lg5)" stroke-width="2" class="animate-scan-line" style="animation-delay: 2.4s;"/>
      <line x1="0" y1="66%" x2="100%" y2="66%" stroke="url(#lineGradient1)" stroke-width="2" class="animate-scan-line" style="animation-delay: 3s;"/>
      <line x1="0" y1="78%" x2="100%" y2="78%" stroke="url(#lineGradient2)" stroke-width="2" class="animate-scan-line" style="animation-delay: 0.9s;"/>
      <line x1="0" y1="90%" x2="100%" y2="90%" stroke="url(#lg4)" stroke-width="2" class="animate-scan-line" style="animation-delay: 2.1s;"/>
    </svg>

    <!-- Tech Grid Patterns -->
    <svg class="absolute inset-0 w-full h-full opacity-10 dark:opacity-40" preserveAspectRatio="none">
      <defs>
        <pattern id="grid" width="100" height="100" patternUnits="userSpaceOnUse">
          <path d="M 100 0 L 0 0 0 100" fill="none" stroke="rgba(30, 64, 175, 0.3)" stroke-width="1"/>
        </pattern>
        <pattern id="grid-dot" width="60" height="60" patternUnits="userSpaceOnUse">
          <circle cx="30" cy="30" r="1.5" fill="rgba(59,130,246,0.25)" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
    <svg class="absolute inset-0 w-full h-full opacity-5 dark:opacity-20" preserveAspectRatio="none">
      <rect width="100%" height="100%" fill="url(#grid-dot)" />
    </svg>

    <!-- ═══ FLOATING TECH ICONS — KEPT ================ -->
    <!-- Icon 1: Code -->
    <div class="tech-icon absolute top-20 left-20 w-24 h-24 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 0s;">
      <div class="w-full h-full border-t-2 border-l-2 border-blue-600 dark:border-blue-400 rounded-3xl rotate-45 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-code text-blue-700 dark:text-blue-500 text-3xl -rotate-45"></i>
      </div>
    </div>

    <!-- Icon 2: Server -->
    <div class="tech-icon absolute top-40 right-32 w-20 h-20 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 2s;">
      <div class="w-full h-full border-t-2 border-r-2 border-indigo-600 dark:border-indigo-400 rounded-full flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-server text-indigo-700 dark:text-indigo-500 text-2xl"></i>
      </div>
    </div>

    <!-- Icon 3: Database -->
    <div class="tech-icon absolute bottom-40 left-1/4 w-28 h-28 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 4s;">
      <div class="w-full h-full border-b-2 border-r-2 border-blue-500 dark:border-blue-400 rounded-3xl flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-database text-blue-600 dark:text-blue-500 text-3xl"></i>
      </div>
    </div>

    <!-- Icon 4: Microchip -->
    <div class="tech-icon absolute bottom-20 right-20 w-24 h-24 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 1s;">
      <div class="w-full h-full border-b-2 border-l-2 border-blue-600 dark:border-blue-400 rounded-full flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-microchip text-blue-700 dark:text-blue-500 text-2xl"></i>
      </div>
    </div>

    <!-- Icon 5: Network -->
    <div class="tech-icon absolute top-1/2 right-1/4 w-20 h-20 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 3s;">
      <div class="w-full h-full border-t-2 border-b-2 border-indigo-600 dark:border-indigo-400 rounded-3xl flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-network-wired text-indigo-700 dark:text-indigo-500 text-xl"></i>
      </div>
    </div>

    <!-- ═══ NEW: HTML5 (visible on mobile, placed early) ═══ -->
    <div class="tech-icon absolute top-32 left-1/3 w-16 h-16 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 0.6s;">
      <div class="w-full h-full border-2 border-orange-600/60 dark:border-orange-500/50 rounded-xl rotate-12 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fab fa-html5 text-orange-700 dark:text-orange-400 text-xl -rotate-12"></i>
      </div>
    </div>

    <!-- ═══ NEW: CSS3 (visible on mobile, placed early) ═══ -->
    <div class="tech-icon absolute top-1/3 left-10 w-14 h-14 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 2.6s;">
      <div class="w-full h-full border-2 border-blue-600/60 dark:border-blue-500/50 rounded-xl -rotate-6 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fab fa-css3-alt text-blue-700 dark:text-blue-400 text-lg rotate-6"></i>
      </div>
    </div>

    <!-- Icon 6: JavaScript -->
    <div class="tech-icon absolute bottom-1/3 left-1/3 w-18 h-18 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 1.8s;">
      <div class="w-full h-full border-2 border-cyan-600/60 dark:border-cyan-500/50 rounded-xl rotate-45 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fab fa-js text-cyan-700 dark:text-cyan-400 text-xl -rotate-45"></i>
      </div>
    </div>

    <!-- Icon 7: Python -->
    <div class="tech-icon absolute bottom-32 right-1/4 w-16 h-16 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 0.3s;">
      <div class="w-full h-full border-2 border-violet-600/60 dark:border-violet-500/50 rounded-xl -rotate-12 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fab fa-python text-violet-700 dark:text-violet-400 text-xl rotate-12"></i>
      </div>
    </div>

    <!-- Icon 8: React -->
    <div class="tech-icon absolute top-1/2 left-2/3 w-14 h-14 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 3.8s;">
      <div class="w-full h-full border-2 border-pink-600/60 dark:border-pink-500/50 rounded-xl rotate-6 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fab fa-react text-pink-700 dark:text-pink-400 text-lg -rotate-6"></i>
      </div>
    </div>

    <!-- Rest of icons (hidden on mobile) -->
    <div class="tech-icon absolute top-60 right-10 w-18 h-18 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 1.4s;">
      <div class="w-full h-full border-2 border-sky-600/60 dark:border-sky-500/50 rounded-2xl rotate-3 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fab fa-php text-sky-700 dark:text-sky-400 text-xl -rotate-3"></i>
      </div>
    </div>
    <div class="tech-icon absolute bottom-1/4 right-1/5 w-16 h-16 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 2.2s;">
      <div class="w-full h-full border-2 border-amber-600/60 dark:border-amber-500/50 rounded-full flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-cloud text-amber-700 dark:text-amber-400 text-xl"></i>
      </div>
    </div>
    <div class="tech-icon absolute top-1/4 right-1/3 w-14 h-14 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 0.9s;">
      <div class="w-full h-full border-2 border-rose-600/60 dark:border-rose-500/50 rounded-xl -rotate-8 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-terminal text-rose-700 dark:text-rose-400 text-lg rotate-8"></i>
      </div>
    </div>
    <div class="tech-icon absolute top-2/3 right-1/3 w-18 h-18 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 4.2s;">
      <div class="w-full h-full border-2 border-teal-600/60 dark:border-teal-500/50 rounded-2xl rotate-12 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-cogs text-teal-700 dark:text-teal-400 text-xl -rotate-12"></i>
      </div>
    </div>
    <div class="tech-icon absolute bottom-10 left-1/3 w-16 h-16 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 3.4s;">
      <div class="w-full h-full border-2 border-fuchsia-600/60 dark:border-fuchsia-500/50 rounded-xl rotate-6 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-laptop-code text-fuchsia-700 dark:text-fuchsia-400 text-lg -rotate-6"></i>
      </div>
    </div>
    <div class="tech-icon absolute top-1/4 left-2/3 w-14 h-14 opacity-8 dark:opacity-15 animate-float-tech" style="animation-delay: 5s;">
      <div class="w-full h-full border-2 border-blue-600/50 dark:border-blue-500/40 rounded-lg rotate-45 flex items-center justify-center bg-white/5 dark:bg-black/5 backdrop-blur-sm">
        <i class="fas fa-robot text-blue-600 dark:text-blue-400 text-lg -rotate-45"></i>
      </div>
    </div>
    <div class="tech-icon absolute bottom-2/3 left-1/5 w-16 h-16 opacity-8 dark:opacity-15 animate-float-tech" style="animation-delay: 1s;">
      <div class="w-full h-full border-2 border-indigo-600/50 dark:border-indigo-500/40 rounded-2xl -rotate-3 flex items-center justify-center bg-white/5 dark:bg-black/5 backdrop-blur-sm">
        <i class="fas fa-shield-alt text-indigo-600 dark:text-indigo-400 text-lg rotate-3"></i>
      </div>
    </div>
    <div class="tech-icon absolute top-3/4 right-2/3 w-14 h-14 opacity-8 dark:opacity-15 animate-float-tech" style="animation-delay: 3s;">
      <div class="w-full h-full border-2 border-cyan-600/50 dark:border-cyan-500/40 rounded-full flex items-center justify-center bg-white/5 dark:bg-black/5 backdrop-blur-sm">
        <i class="fas fa-bolt text-cyan-600 dark:text-cyan-400 text-lg"></i>
      </div>
    </div>
    <div class="tech-icon absolute top-1/3 right-10 w-16 h-16 opacity-8 dark:opacity-15 animate-float-tech" style="animation-delay: 2.8s;">
      <div class="w-full h-full border-2 border-green-600/50 dark:border-green-500/40 rounded-xl rotate-8 flex items-center justify-center bg-white/5 dark:bg-black/5 backdrop-blur-sm">
        <i class="fab fa-git-alt text-green-700 dark:text-green-400 text-lg -rotate-8"></i>
      </div>
    </div>

    <!-- ═══ FLOATING CODE BRACKETS ═══ -->
    <div class="absolute top-28 left-2/3 text-4xl font-mono font-bold text-blue-600/20 dark:text-blue-400/15 animate-float-bracket" style="animation-delay:0.3s;">
      { }
    </div>
    <div class="absolute bottom-32 left-1/5 text-3xl font-mono font-bold text-indigo-600/20 dark:text-indigo-400/15 animate-float-bracket" style="animation-delay:1.8s;">
      &lt; / &gt;
    </div>
    <div class="absolute top-1/3 right-1/5 text-4xl font-mono font-bold text-cyan-600/15 dark:cyan-400/12 animate-float-bracket" style="animation-delay:2.6s;">
      [ ]
    </div>
    <div class="absolute bottom-1/3 left-2/3 text-3xl font-mono font-bold text-violet-600/15 dark:text-violet-400/12 animate-float-bracket" style="animation-delay:0.9s;">
      ( )
    </div>
    <div class="absolute top-2/3 right-1/4 text-3xl font-mono font-bold text-rose-600/15 dark:text-rose-400/12 animate-float-bracket" style="animation-delay:3.8s;">
      { &lt; / &gt; }
    </div>
    <div class="absolute top-10 left-1/2 text-2xl font-mono font-bold text-blue-600/12 dark:text-blue-400/10 animate-float-bracket" style="animation-delay:4.5s;">
      &lt; code &gt;
    </div>

    <!-- ═══ TERMINAL CURSOR LINES ═══ -->
    <div class="absolute top-1/2 left-8 text-sm font-mono text-blue-600/20 dark:text-blue-400/15 animate-terminal-cursor hidden sm:block" style="animation-delay:0s;">
      <span class="opacity-80">$</span>
      <span class="text-cyan-600/25 dark:text-cyan-400/20"> npm install --save</span>
      <span class="inline-block w-2 h-4 bg-blue-600/30 dark:bg-blue-400/25 ml-1 animate-blink-cursor"></span>
    </div>
    <div class="absolute bottom-1/4 right-8 text-sm font-mono text-indigo-600/20 dark:text-indigo-400/15 animate-terminal-cursor" style="animation-delay:3s;">
      <span class="opacity-80">$</span>
      <span class="text-violet-600/25 dark:text-violet-400/20"> git push origin main</span>
      <span class="inline-block w-2 h-4 bg-indigo-600/30 dark:bg-indigo-400/25 ml-1 animate-blink-cursor"></span>
    </div>
    <div class="absolute top-3/4 left-1/4 text-sm font-mono text-cyan-600/20 dark:text-cyan-400/15 animate-terminal-cursor" style="animation-delay:6s;">
      <span class="opacity-80">$</span>
      <span class="text-sky-600/25 dark:text-sky-400/20"> yarn build</span>
      <span class="inline-block w-2 h-4 bg-cyan-600/30 dark:bg-cyan-400/25 ml-1 animate-blink-cursor"></span>
    </div>

    <!-- ═══ PARTICLES — HEAVY: DISABLED ON MOBILE ═══ -->
    <div class="absolute inset-0 opacity-60 dark:opacity-100 mobile-hide-particles">
      <!-- Blue Particles -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 15%; left: 10%; animation-delay: 0s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 35%; left: 70%; animation-delay: 1.5s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 60%; left: 20%; animation-delay: 3s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 75%; right: 15%; animation-delay: 4.5s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 45%; left: 5%; animation-delay: 6s;"></div>
      
      <!-- Indigo Particles -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top: 25%; right: 30%; animation-delay: 0.8s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top: 50%; left: 45%; animation-delay: 2.3s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top: 80%; left: 30%; animation-delay: 3.8s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top: 10%; left: 50%; animation-delay: 5.2s;"></div>
      
      <!-- Sky Particles -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-sky-500 dark:bg-sky-400 rounded-full animate-tech-float shadow-glow-sky" style="top: 40%; right: 10%; animation-delay: 1.2s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-sky-500 dark:bg-sky-400 rounded-full animate-tech-float shadow-glow-sky" style="top: 70%; right: 50%; animation-delay: 2.8s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-sky-500 dark:bg-sky-400 rounded-full animate-tech-float shadow-glow-sky" style="top: 20%; left: 80%; animation-delay: 4.2s;"></div>
      
      <!-- Violet Particles -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-violet-500 dark:bg-violet-400 rounded-full animate-tech-float shadow-glow-violet" style="top: 30%; left: 55%; animation-delay: 0.5s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-violet-500 dark:bg-violet-400 rounded-full animate-tech-float shadow-glow-violet" style="top: 90%; right: 30%; animation-delay: 2s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-violet-500 dark:bg-violet-400 rounded-full animate-tech-float shadow-glow-violet" style="top: 5%; right: 60%; animation-delay: 3.5s;"></div>
      
      <!-- Teal Particles -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-teal-500 dark:bg-teal-400 rounded-full animate-tech-float shadow-glow-teal" style="top: 10%; right: 15%; animation-delay: 0.2s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-teal-500 dark:bg-teal-400 rounded-full animate-tech-float shadow-glow-teal" style="top: 95%; left: 40%; animation-delay: 1.7s;"></div>
      
      <!-- Rose/Pink Particles -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-rose-500 dark:bg-rose-400 rounded-full animate-tech-float shadow-glow-rose" style="top: 78%; left: 10%; animation-delay: 0.7s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-rose-500 dark:bg-rose-400 rounded-full animate-tech-float shadow-glow-rose" style="top: 18%; left: 40%; animation-delay: 2.2s;"></div>
    </div>

    <!-- ═══ ANIMATED ORBITS — HEAVY: DISABLED ON MOBILE ═══ -->
    <div class="absolute top-1/4 left-1/3 w-64 h-64 opacity-20 dark:opacity-30 mobile-hide-orbits">
      <svg class="w-full h-full animate-rotate-slow" viewBox="0 0 100 100" preserveAspectRatio="none">
        <circle cx="50" cy="50" r="45" fill="none" stroke="url(#lineGradient1)" stroke-width="0.5" opacity="0.5"/>
        <circle cx="50" cy="50" r="30" fill="none" stroke="url(#lineGradient2)" stroke-width="0.5" opacity="0.5"/>
        <circle cx="50" cy="50" r="15" fill="none" stroke="url(#lineGradient3)" stroke-width="0.5" opacity="0.5"/>
        <circle cx="95" cy="50" r="2.5" fill="#1e40af" class="animate-orbit-1"/>
        <circle cx="50" cy="5" r="2.5" fill="#0284c7" class="animate-orbit-2"/>
        <circle cx="5" cy="50" r="2.5" fill="#4f46e5" class="animate-orbit-3"/>
      </svg>
    </div>
    <!-- Second orbit ring -->
    <div class="absolute bottom-1/3 right-1/4 w-48 h-48 opacity-15 dark:opacity-20 mobile-hide-orbits">
      <svg class="w-full h-full animate-rotate-slow" viewBox="0 0 100 100" preserveAspectRatio="none" style="animation-duration:25s;animation-direction:reverse">
        <circle cx="50" cy="50" r="40" fill="none" stroke="url(#lg4)" stroke-width="0.4" opacity="0.4"/>
        <circle cx="50" cy="50" r="25" fill="none" stroke="url(#lg5)" stroke-width="0.4" opacity="0.4"/>
        <circle cx="90" cy="50" r="2" fill="#06b6d4" class="animate-orbit-1" style="animation-duration:8s"/>
        <circle cx="50" cy="10" r="2" fill="#8b5cf6" class="animate-orbit-2" style="animation-duration:8s"/>
      </svg>
    </div>

    <!-- ═══ STATUS INDICATOR LIGHTS — KEPT (low cost) ═══ -->
    <div class="absolute top-20 right-1/3 w-3 h-3 bg-blue-500 rounded-full animate-status-pulse" style="animation-delay: 0s;">
      <div class="absolute inset-0 bg-blue-500 rounded-full animate-status-ping"></div>
    </div>
    <div class="absolute top-1/3 left-1/4 w-3 h-3 bg-indigo-500 rounded-full animate-status-pulse" style="animation-delay: 1s;">
      <div class="absolute inset-0 bg-indigo-500 rounded-full animate-status-ping"></div>
    </div>
    <div class="absolute bottom-1/3 right-1/4 w-3 h-3 bg-sky-500 rounded-full animate-status-pulse" style="animation-delay: 2s;">
      <div class="absolute inset-0 bg-sky-500 rounded-full animate-status-ping"></div>
    </div>
    <div class="absolute top-2/3 left-10 w-2.5 h-2.5 bg-violet-500 rounded-full animate-status-pulse" style="animation-delay: 0.5s;">
