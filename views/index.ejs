<%- include('./layouts/header.ejs') %>

<div class="pt-32 pb-20 relative overflow-hidden" id="app">
  <!-- ===== OPTIMIZED BACKGROUND FOR MOBILE ===== -->
  <div class="fixed inset-0 -z-10 overflow-hidden" id="bg-container">
    <!-- Gradient Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-blue-50/80 to-indigo-50/60 dark:from-slate-950 dark:via-blue-950/70 dark:to-indigo-950/40"></div>
    
    <!-- Scan Lines - Reduced on mobile -->
    <svg class="absolute inset-0 w-full h-full opacity-10 dark:opacity-30 mobile-hide-scan" preserveAspectRatio="none">
      <defs>
        <linearGradient id="lineGradient1" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#1e40af;stop-opacity:0" />
          <stop offset="50%" style="stop-color:#1e40af;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#1e40af;stop-opacity:0" />
        </linearGradient>
        <linearGradient id="lineGradient2" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#0284c7;stop-opacity:0" />
          <stop offset="50%" style="stop-color:#0284c7;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#0284c7;stop-opacity:0" />
        </linearGradient>
        <linearGradient id="lineGradient3" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#4f46e5;stop-opacity:0" />
          <stop offset="50%" style="stop-color:#4f46e5;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#4f46e5;stop-opacity:0" />
        </linearGradient>
        <linearGradient id="lg4" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#06b6d4;stop-opacity:0"/>
          <stop offset="50%" style="stop-color:#06b6d4;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:0"/>
        </linearGradient>
      </defs>
      <line x1="0" y1="12%" x2="100%" y2="12%" stroke="url(#lineGradient1)" stroke-width="2" class="animate-scan-line" style="animation-delay:0s;"/>
      <line x1="0" y1="38%" x2="100%" y2="38%" stroke="url(#lineGradient2)" stroke-width="2" class="animate-scan-line" style="animation-delay:1.2s;"/>
      <line x1="0" y1="64%" x2="100%" y2="64%" stroke="url(#lineGradient3)" stroke-width="2" class="animate-scan-line" style="animation-delay:2.4s;"/>
      <line x1="0" y1="88%" x2="100%" y2="88%" stroke="url(#lg4)" stroke-width="2" class="animate-scan-line" style="animation-delay:3.6s;"/>
    </svg>

    <!-- Grid Patterns - Simplified -->
    <svg class="absolute inset-0 w-full h-full opacity-8 dark:opacity-30" preserveAspectRatio="none">
      <defs>
        <pattern id="grid" width="80" height="80" patternUnits="userSpaceOnUse">
          <path d="M 80 0 L 0 0 0 80" fill="none" stroke="rgba(30,64,175,0.2)" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>

    <!-- ===== FLOATING TECH ICONS - REDUCED on mobile ===== -->
    <div class="tech-icon absolute top-20 left-20 w-20 h-20 opacity-10 dark:opacity-20 animate-float-tech mobile-hide-icon" style="animation-delay:0s;">
      <div class="w-full h-full border-t-2 border-l-2 border-blue-600 dark:border-blue-400 rounded-2xl rotate-45 flex items-center justify-center bg-white/5 dark:bg-black/5">
        <i class="fas fa-code text-blue-700 dark:text-blue-400 text-2xl -rotate-45"></i>
      </div>
    </div>

    <div class="tech-icon absolute top-40 right-20 w-16 h-16 opacity-10 dark:opacity-20 animate-float-tech mobile-hide-icon" style="animation-delay:2s;">
      <div class="w-full h-full border-t-2 border-r-2 border-indigo-600 dark:border-indigo-400 rounded-full flex items-center justify-center bg-white/5 dark:bg-black/5">
        <i class="fas fa-server text-indigo-700 dark:text-indigo-400 text-xl"></i>
      </div>
    </div>

    <div class="tech-icon absolute bottom-40 left-20 w-20 h-20 opacity-10 dark:opacity-20 animate-float-tech mobile-hide-icon" style="animation-delay:4s;">
      <div class="w-full h-full border-b-2 border-r-2 border-blue-500 dark:border-blue-400 rounded-2xl flex items-center justify-center bg-white/5 dark:bg-black/5">
        <i class="fas fa-database text-blue-600 dark:text-blue-400 text-2xl"></i>
      </div>
    </div>

    <div class="tech-icon absolute bottom-20 right-20 w-16 h-16 opacity-10 dark:opacity-20 animate-float-tech mobile-hide-icon" style="animation-delay:1s;">
      <div class="w-full h-full border-b-2 border-l-2 border-blue-600 dark:border-blue-400 rounded-full flex items-center justify-center bg-white/5 dark:bg-black/5">
        <i class="fas fa-microchip text-blue-700 dark:text-blue-400 text-xl"></i>
      </div>
    </div>

    <!-- ===== FLOATING CODE BRACKETS - HIDDEN on mobile ===== -->
    <div class="absolute top-28 left-2/3 text-3xl font-mono font-bold text-blue-600/20 dark:text-blue-400/15 animate-float-bracket mobile-hide-bracket" style="animation-delay:0.3s;">{ }</div>
    <div class="absolute bottom-32 left-1/5 text-2xl font-mono font-bold text-indigo-600/20 dark:text-indigo-400/15 animate-float-bracket mobile-hide-bracket" style="animation-delay:1.8s;">&lt; / &gt;</div>
    <div class="absolute top-1/3 right-1/5 text-3xl font-mono font-bold text-cyan-600/15 dark:cyan-400/12 animate-float-bracket mobile-hide-bracket" style="animation-delay:2.6s;">[ ]</div>

    <!-- ===== TERMINAL CURSOR LINES - HIDDEN on mobile ===== -->
    <div class="absolute top-1/2 left-8 text-sm font-mono text-blue-600/20 dark:text-blue-400/15 animate-terminal-cursor hidden sm:block mobile-hide-terminal" style="animation-delay:0s;">
      <span class="opacity-80">$</span>
      <span class="text-cyan-600/25 dark:text-cyan-400/20"> npm install --save</span>
      <span class="inline-block w-2 h-4 bg-blue-600/30 dark:bg-blue-400/25 ml-1 animate-blink-cursor"></span>
    </div>
    <div class="absolute bottom-1/4 right-8 text-sm font-mono text-indigo-600/20 dark:text-indigo-400/15 animate-terminal-cursor mobile-hide-terminal" style="animation-delay:3s;">
      <span class="opacity-80">$</span>
      <span class="text-violet-600/25 dark:text-violet-400/20"> git push origin main</span>
      <span class="inline-block w-2 h-4 bg-indigo-600/30 dark:bg-indigo-400/25 ml-1 animate-blink-cursor"></span>
    </div>

    <!-- ===== PARTICLES - REDUCED on mobile ===== -->
    <div class="absolute inset-0 opacity-40 dark:opacity-80" id="particles-container">
      <!-- Only 12 particles total (vs 20+) -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top:15%;left:10%;animation-delay:0s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top:35%;left:70%;animation-delay:1.5s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top:60%;left:20%;animation-delay:3s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top:75%;right:15%;animation-delay:4.5s;"></div>
      
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top:25%;right:30%;animation-delay:0.8s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top:50%;left:45%;animation-delay:2.3s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top:80%;left:30%;animation-delay:3.8s;"></div>
      
      <div class="tech-particle absolute w-1.5 h-1.5 bg-sky-500 dark:bg-sky-400 rounded-full animate-tech-float shadow-glow-sky" style="top:40%;right:10%;animation-delay:1.2s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-sky-500 dark:bg-sky-400 rounded-full animate-tech-float shadow-glow-sky" style="top:70%;right:50%;animation-delay:2.8s;"></div>
      
      <div class="tech-particle absolute w-1.5 h-1.5 bg-violet-500 dark:bg-violet-400 rounded-full animate-tech-float shadow-glow-violet" style="top:30%;left:55%;animation-delay:0.5s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-violet-500 dark:bg-violet-400 rounded-full animate-tech-float shadow-glow-violet" style="top:90%;right:30%;animation-delay:2s;"></div>
      
      <div class="tech-particle absolute w-1.5 h-1.5 bg-teal-500 dark:bg-teal-400 rounded-full animate-tech-float shadow-glow-teal" style="top:10%;right:15%;animation-delay:0.2s;"></div>
    </div>

    <!-- ===== ANIMATED ORBITS - DISABLED on mobile ===== -->
    <div class="absolute top-1/4 left-1/3 w-64 h-64 opacity-15 dark:opacity-25 mobile-hide-orbits">
      <svg class="w-full h-full animate-rotate-slow" viewBox="0 0 100 100" preserveAspectRatio="none">
        <circle cx="50" cy="50" r="45" fill="none" stroke="url(#lineGradient1)" stroke-width="0.5" opacity="0.4"/>
        <circle cx="50" cy="50" r="30" fill="none" stroke="url(#lineGradient2)" stroke-width="0.5" opacity="0.4"/>
        <circle cx="50" cy="50" r="15" fill="none" stroke="url(#lineGradient3)" stroke-width="0.5" opacity="0.4"/>
        <circle cx="95" cy="50" r="2" fill="#1e40af" class="animate-orbit-1"/>
        <circle cx="50" cy="5" r="2" fill="#0284c7" class="animate-orbit-2"/>
        <circle cx="5" cy="50" r="2" fill="#4f46e5" class="animate-orbit-3"/>
      </svg>
    </div>

    <!-- ===== STATUS LIGHTS - REDUCED on mobile ===== -->
    <div class="absolute top-20 right-1/3 w-2.5 h-2.5 bg-blue-500 rounded-full animate-status-pulse mobile-hide-status" style="animation-delay:0s;">
      <div class="absolute inset-0 bg-blue-500 rounded-full animate-status-ping"></div>
    </div>
    <div class="absolute top-1/3 left-1/4 w-2.5 h-2.5 bg-indigo-500 rounded-full animate-status-pulse mobile-hide-status" style="animation-delay:1s;">
      <div class="absolute inset-0 bg-indigo-500 rounded-full animate-status-ping"></div>
    </div>
    <div class="absolute bottom-1/3 right-1/4 w-2.5 h-2.5 bg-sky-500 rounded-full animate-status-pulse mobile-hide-status" style="animation-delay:2s;">
      <div class="absolute inset-0 bg-sky-500 rounded-full animate-status-ping"></div>
    </div>

    <!-- ===== GLOWING ORBS - REDUCED on mobile ===== -->
    <div class="absolute top-0 left-1/3 w-80 h-80 bg-gradient-to-br from-blue-200/20 to-indigo-200/15 dark:from-blue-500/8 dark:to-indigo-500/4 rounded-full blur-3xl animate-pulse-glow mobile-hide-glow"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-gradient-to-br from-blue-200/20 to-indigo-200/15 dark:from-blue-500/8 dark:to-indigo-500/4 rounded-full blur-3xl animate-pulse-glow mobile-hide-glow" style="animation-delay:2s;"></div>
  </div>

  <!-- Hero Section -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
      <!-- Content -->
      <div class="animate-fade-in-up">
        <div class="inline-block mb-4 md:mb-6">
          <span class="badge-glow">
            <i class="fas fa-star text-blue-600 mr-2"></i><span class="text-blue-700 dark:text-blue-300 text-sm md:text-base">Welcome to my Portfolio</span>
          </span>
        </div>

        <h1 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-black mb-4 md:mb-6 text-slate-900 dark:text-white leading-tight">
          Hi, I'm <span class="text-blue-700 dark:text-blue-400">Jomer John Alvarado</span>
          <span class="inline-block text-3xl md:text-5xl animate-bounce-slow ml-2">👋</span>
        </h1>

        <p class="text-base sm:text-lg md:text-xl text-slate-700 dark:text-slate-300 mb-4 md:mb-6 leading-relaxed">
          <i class="fas fa-code text-blue-700 dark:text-blue-400 mr-2"></i>
          A developer creating beautiful, responsive web applications and mobile apps with the power of AI prompting Technology.
        </p>

        <div class="mb-4 md:mb-6 space-y-2 md:space-y-3">
          <p class="text-sm sm:text-base md:text-lg text-slate-700 dark:text-slate-300 flex items-center gap-2">
            <i class="fas fa-graduation-cap text-blue-700 dark:text-blue-500"></i>
            <strong class="text-slate-900 dark:text-white">Bachelor of Science in Information Technology</strong>
          </p>
          <p class="text-sm sm:text-base md:text-lg text-slate-700 dark:text-slate-300 flex items-center gap-2">
            <i class="fas fa-school text-blue-600 dark:text-blue-400"></i>
            <strong class="text-slate-900 dark:text-white">St. Vincent's College Incorporated</strong>
          </p>
        </div>
        
        <div class="flex flex-wrap gap-3 md:gap-4 mb-6 md:mb-8">
          <a href="/projects" class="btn-primary text-sm md:text-base">
            <span>View My Work</span>
            <i class="fas fa-arrow-right group-hover:translate-x-2 transition"></i>
          </a>
          <a href="/contact" class="btn-secondary text-sm md:text-base">
            <span>Get In Touch</span>
            <i class="fas fa-envelope group-hover:scale-125 transition"></i>
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 gap-3 md:gap-4 mt-8 md:mt-12">
          <div class="stat-box group hover-lift card-border" onmouseenter="borderZoom(event)" onmouseleave="borderUnzoom(event)">
            <div class="flex items-center justify-between mb-1 md:mb-2">
              <i class="fas fa-rocket text-blue-700 dark:text-blue-400 text-xl md:text-2xl"></i>
              <span class="counter text-2xl md:text-3xl font-bold text-blue-700 dark:text-blue-400">50</span>
            </div>
            <p class="text-slate-600 dark:text-slate-300 text-xs md:text-sm">Projects</p>
          </div>

          <div class="stat-box group hover-lift card-border" onmouseenter="borderZoom(event)" onmouseleave="borderUnzoom(event)">
            <div class="flex items-center justify-between mb-1 md:mb-2">
              <i class="fas fa-award text-sky-700 dark:text-sky-400 text-xl md:text-2xl"></i>
              <span class="counter text-2xl md:text-3xl font-bold text-sky-700 dark:text-sky-400">No</span>
            </div>
            <p class="text-slate-600 dark:text-slate-300 text-xs md:text-sm">Years Exp Yet.</p>
          </div>
        </div>
      </div>

      <!-- Hero Image -->
      <div class="relative animate-fade-in-up mt-6 md:mt-0" style="animation-delay: 0.2s;">
        <div class="relative bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-900 dark:to-slate-950 rounded-2xl md:rounded-3xl p-4 md:p-8 overflow-hidden group">
          <div class="absolute inset-0 opacity-10 dark:opacity-30">
            <div class="absolute inset-0 bg-grid-tech"></div>
          </div>
          
          <div class="relative aspect-square rounded-xl md:rounded-2xl overflow-hidden">
            <img 
              src="/images/myself.jpeg" 
              alt="Jomer John V. Alvarado" 
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
              loading="lazy"
              onerror="this.style.display='none'; this.parentElement.innerHTML += '<div class=\\'flex items-center justify-center h-full bg-slate-200 dark:bg-slate-700 rounded-xl md:rounded-2xl\\'><i class=\\'fas fa-user text-4xl md:text-6xl text-slate-400 dark:text-slate-500\\'></i></div>'"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-blue-600/20 to-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="my-12 md:my-20">
    <div class="divider max-w-7xl mx-auto border-t border-blue-300 dark:border-blue-600/30"></div>
  </div>

  <!-- Featured Projects -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="mb-8 md:mb-12">
      <h2 class="section-title flex items-center gap-2 md:gap-3 text-slate-900 dark:text-white text-2xl sm:text-3xl md:text-4xl">
        <i class="fas fa-star text-blue-600 text-2xl md:text-4xl"></i>Featured Projects
      </h2>
      <p class="section-subtitle text-slate-600 dark:text-slate-300 text-base md:text-xl">Checkout my recent work and projects</p>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6 lg:gap-8">
      <% 
      const featured = [
        {
          id: 1,
          title: 'Jojohn Hack Tool',
          category: 'App Development',
          icon: 'shield-halved',
          color: 'red',
          tech: ['Flutter', 'Dart', 'Packages','API Integration'],
          description: 'A powerful, open-source automation framework used for advanced penetration testing and security vulnerability scanning.',
          fullDescription: 'A comprehensive security testing framework with automated vulnerability scanning, penetration testing tools, and detailed reporting capabilities.',
          images: [
            '/images/jojohn hack/1.jpg',
            '/images/jojohn hack/2.jpg',
            '/images/jojohn hack/3.jpg',
            '/images/jojohn hack/4.jpg',
            '/images/jojohn hack/5.jpg',
            '/images/jojohn hack/6.jpg',
            '/images/jojohn hack/7.jpg',
            '/images/jojohn hack/8.jpg',
            '/images/jojohn hack/9.jpg',
            '/images/jojohn hack/10.jpg',
            '/images/jojohn hack/11.jpg',
            '/images/jojohn hack/12.jpg',
            '/images/jojohn hack/13.jpg',
            '/images/jojohn hack/14.jpg',
            '/images/jojohn hack/15.jpg',
            '/images/jojohn hack/16.jpg',
            '/images/jojohn hack/17.jpg',
            '/images/jojohn hack/18.jpg',
            '/images/jojohn hack/19.jpg',
            '/images/jojohn hack/20.jpg',
            '/images/jojohn hack/21.jpg',
            '/images/jojohn hack/22.jpg',
            '/images/jojohn hack/23.jpg',
            '/images/jojohn hack/24.jpg',
            '/images/jojohn hack/25.jpg',
            '/images/jojohn hack/26.jpg',
            '/images/jojohn hack/27.jpg',
            '/images/jojohn hack/28.jpg',
            '/images/jojohn hack/29.jpg',
            '/images/jojohn hack/30.jpg',
            '/images/jojohn hack/31.jpg'
          ],
          websiteUrl: 'https://phishingdetector-4.onrender.com/',
          githubUrl: 'https://github.com/SyntaxRepo/file-tracking-system',
          featured: true
        },
        {
          id: 2,
          title: 'Phishing Detector',
          category: 'Website',
          icon: 'shield-halved',
          color: 'blue',
          tech: ['Html', 'CSS', 'Python', 'Phishing Website Links'],
          description: 'Advanced phishing detection tool that analyzes URLs and emails for potential security threats.',
          fullDescription: 'Protect yourself from phishing attacks with this intelligent detection system. Analyze links, emails, and websites for suspicious patterns using machine learning algorithms.',
          images: [
          '/images/phishing/phishing.png',
          '/images/phishing/phishing1.png',
         ],
          websiteUrl: 'https://phishingdetector-4.onrender.com/',
          githubUrl: 'https://github.com/yourusername/phishing-detector',
          featured: false
        },
        {
          id: 3,
          title: 'File Tracking System',
          category: 'System',
          icon: 'folder-tree',
          color: 'indigo',
          tech: ['HTML', 'CSS', 'JavaScript'],
          description: 'A comprehensive file tracking and management system with version control and audit trails.',
          fullDescription: 'Track every file movement across your organization with detailed logs, version history, and permission-based access control.',
          images: ['/images/file-tracking/1.jpg', '/images/file-tracking/2.jpg', '/images/file-tracking/3.jpg'],
          githubUrl: 'https://github.com/SyntaxRepo/file-tracking-system',
          featured: false
        }
      ];
      featured.forEach((project, index) => { %>
        <div class="feature-card animate-fade-in-up card-hover card-border" style="animation-delay: <%= index * 0.12 %>s;" onmouseenter="borderZoom(event)" onmouseleave="borderUnzoom(event)">
          <div class="h-40 sm:h-48 bg-gradient-to-br from-<%= project.color %>-100 to-indigo-100 dark:from-<%= project.color %>-950/40 dark:to-indigo-950/40 flex items-center justify-center relative overflow-hidden rounded-xl mb-4 md:mb-6 group/image cursor-pointer" onclick='openProjectModal(<%= JSON.stringify(project).replace(/'/g, "\\'") %>)'>
            <% if (project.images && project.images.length > 0) { %>
              <img 
                src="<%= project.images[0] %>" 
                alt="<%= project.title %>" 
                class="w-full h-full object-cover group-hover/image:scale-110 transition-transform duration-500"
                loading="lazy"
                onerror="this.style.display='none'; this.parentElement.querySelector('.fallback-icon').style.display='flex';"
              />
              <div class="fallback-icon absolute inset-0 hidden items-center justify-center">
                <i class="fas fa-<%= project.icon %> text-4xl md:text-6xl text-<%= project.color %>-600 opacity-40 dark:opacity-50"></i>
              </div>
            <% } else { %>
              <i class="fas fa-<%= project.icon %> text-4xl md:text-6xl text-<%= project.color %>-600 opacity-40 dark:opacity-50"></i>
            <% } %>
            
            <% if (project.images && project.images.length > 1) { %>
              <div class="absolute bottom-2 right-2 md:bottom-3 md:right-3 bg-black/60 backdrop-blur-sm text-white text-[10px] md:text-xs px-1.5 py-0.5 md:px-2 md:py-1 rounded-full">
                <i class="fas fa-images mr-1"></i><%= project.images.length %>
              </div>
            <% } %>
            
            <% if (project.featured) { %>
              <div class="absolute top-2 left-2 md:top-3 md:left-3 bg-gradient-to-r from-yellow-500 to-yellow-600 text-white text-[10px] md:text-xs px-1.5 py-0.5 md:px-2 md:py-1 rounded-full">
                <i class="fas fa-star mr-1"></i>Featured
              </div>
            <% } %>
            
            <div class="absolute inset-0 bg-black/60 opacity-0 group-hover/image:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <span class="text-white font-bold text-xs md:text-sm bg-white/20 backdrop-blur-sm px-3 py-1.5 md:px-4 md:py-2 rounded-full">
                <i class="fas fa-images mr-1 md:mr-2"></i>View Gallery
              </span>
            </div>
          </div>
          
          <span class="badge text-[10px] md:text-xs">
            <i class="fas fa-tag mr-1"></i><%= project.category %>
          </span>
          
          <h3 class="text-lg md:text-2xl font-bold mb-1 md:mb-2 mt-2 md:mt-3 text-slate-900 dark:text-white group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors duration-300">
            <%= project.title %>
          </h3>
          
          <p class="text-slate-600 dark:text-slate-400 text-xs md:text-sm mb-3 md:mb-4 line-clamp-2">
            <%= project.description %>
          </p>
          
          <div class="flex flex-wrap gap-1.5 md:gap-2 mb-3 md:mb-4">
            <% project.tech.forEach(t => { %>
              <span class="text-[10px] md:text-xs px-2 py-1 md:px-3 md:py-1.5 rounded-full bg-blue-100 dark:bg-blue-950/40 text-blue-700 dark:text-blue-300 border border-blue-300 dark:border-blue-800/50 font-medium">
                <i class="fas fa-check-circle mr-1"></i><%= t %>
              </span>
            <% }); %>
          </div>

          <div class="flex flex-wrap gap-2 md:gap-3 mt-1 md:mt-2 pt-2 md:pt-3 border-t border-slate-200 dark:border-slate-700">
            <% if (project.websiteUrl && project.id !== 1) { %>
              <a href="<%= project.websiteUrl %>" target="_blank" 
                 class="inline-flex items-center gap-1 md:gap-2 text-blue-700 dark:text-blue-400 font-semibold text-[10px] md:text-sm hover:text-blue-800 dark:hover:text-blue-300 transition-colors duration-300 group">
                <i class="fas fa-globe"></i>
                <span>Live Demo</span>
                <i class="fas fa-arrow-right group-hover:translate-x-1 transition-transform duration-300"></i>
              </a>
            <% } %>
            
            <% if (project.githubUrl) { %>
              <a href="<%= project.githubUrl %>" target="_blank" 
                 class="inline-flex items-center gap-1 md:gap-2 text-slate-600 dark:text-slate-400 font-semibold text-[10px] md:text-sm hover:text-slate-800 dark:hover:text-slate-300 transition-colors duration-300 group">
                <i class="fab fa-github"></i>
                <span>GitHub</span>
                <i class="fas fa-arrow-right group-hover:translate-x-1 transition-transform duration-300"></i>
              </a>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 md:mt-20 relative z-10">
    <div class="relative bg-gradient-to-r from-blue-100/80 to-indigo-100/80 dark:from-blue-950/30 dark:to-indigo-950/30 rounded-2xl md:rounded-3xl p-8 md:p-12 border-t-2 border-l-2 border-blue-600 dark:border-blue-600 overflow-hidden group backdrop-blur-sm card-border" onmouseenter="borderZoom(event)" onmouseleave="borderUnzoom(event)">
      <div class="absolute inset-0 opacity-10 dark:opacity-20">
        <div class="absolute inset-0 bg-grid-tech"></div>
      </div>
      
      <div class="relative text-center">
        <i class="fas fa-rocket text-3xl md:text-5xl text-blue-700 dark:text-blue-400 mb-3 md:mb-4 inline-block animate-bounce-slow"></i>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-2 md:mb-4 text-slate-900 dark:text-white">Ready to Start Something Amazing?</h2>
        <p class="text-base md:text-lg text-slate-700 dark:text-slate-300 mb-4 md:mb-8">Let's collaborate and bring your ideas to life!</p>
        <a href="/contact" class="btn-primary inline-flex group text-sm md:text-base">
          <i class="fas fa-envelope group-hover:animate-bounce-slow"></i>
          <span>Get Started Today</span>
        </a>
      </div>
    </div>
  </section>
</div>

<!-- Back to Top -->
<button id="backToTop" 
        class="fixed bottom-6 md:bottom-8 right-6 md:right-8 z-50 w-10 h-10 md:w-14 md:h-14 rounded-full bg-gradient-to-r from-blue-600 to-indigo-600 text-white shadow-lg shadow-blue-500/30 hover:shadow-xl hover:shadow-blue-500/50 hover:scale-110 transition-all duration-300 flex items-center justify-center group opacity-0 invisible translate-y-4"
        onclick="scrollToTop()"
        aria-label="Back to top">
  <i class="fas fa-arrow-up text-sm md:text-xl group-hover:-translate-y-1 transition-transform duration-300"></i>
  <span class="absolute -top-1 -right-1 md:-top-2 md:-right-2 w-4 h-4 md:w-5 md:h-5 bg-red-500 rounded-full flex items-center justify-center text-[8px] md:text-[10px] font-bold animate-pulse">↑</span>
</button>

<!-- Project Modal -->
<div id="projectModal" class="fixed inset-0 z-50 hidden items-center justify-center p-2 md:p-4 bg-black/70 backdrop-blur-sm">
  <div class="modal-content relative w-full max-w-3xl max-h-[95vh] overflow-y-auto bg-white dark:bg-slate-900 rounded-2xl md:rounded-3xl shadow-2xl transform transition-all duration-500 scale-95 opacity-0">
    
    <button onclick="closeProjectModal()" 
            class="absolute top-2 right-2 md:top-4 md:right-4 z-50 w-8 h-8 md:w-10 md:h-10 flex items-center justify-center bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-full hover:bg-red-500 hover:text-white transition-all duration-300 shadow-xl border-2 border-slate-200 dark:border-slate-700 group">
      <i class="fas fa-times text-sm md:text-base group-hover:rotate-90 transition-transform duration-300"></i>
    </button>

    <div class="px-4 md:px-6 pt-4 md:pt-6 pb-2 md:pb-3">
      <div class="flex items-center gap-2 flex-wrap pr-8 md:pr-10">
        <span id="modalCategory" class="px-2 py-0.5 md:px-3 md:py-1 rounded-full text-[10px] md:text-xs font-bold bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 border-2 border-blue-200 dark:border-blue-800"></span>
        <span id="modalFeatured" class="hidden px-2 py-0.5 md:px-3 md:py-1 rounded-full text-[10px] md:text-xs font-bold bg-gradient-to-r from-yellow-500 to-yellow-600 text-white">
          <i class="fas fa-star mr-1"></i>Featured
        </span>
      </div>
      <h2 id="modalTitle" class="text-xl md:text-3xl font-black text-slate-900 dark:text-white mt-1 md:mt-2"></h2>
      <p id="modalDescription" class="text-slate-500 dark:text-slate-400 mt-0.5 md:mt-1 text-xs md:text-sm"></p>
    </div>

    <div class="px-4 md:px-6 py-2 md:py-3">
      <div id="mainImageWrapper" class="relative rounded-xl md:rounded-2xl overflow-hidden border-2 border-slate-200 dark:border-slate-700 bg-slate-100 dark:bg-slate-800">
        <div id="imageSlider" class="relative w-full"></div>

        <button onclick="previousImage()" id="prevBtn"
                class="hidden absolute left-2 md:left-3 top-1/2 -translate-y-1/2 z-20 w-8 h-8 md:w-10 md:h-10 items-center justify-center bg-white/95 dark:bg-slate-800/95 text-slate-700 dark:text-slate-200 rounded-full hover:bg-blue-600 hover:text-white transition-all duration-300 shadow-lg border border-slate-200 dark:border-slate-600 group">
          <i class="fas fa-chevron-left text-xs md:text-sm group-hover:-translate-x-0.5 transition-transform duration-300"></i>
        </button>

        <button onclick="nextImage()" id="nextBtn"
                class="hidden absolute right-2 md:right-3 top-1/2 -translate-y-1/2 z-20 w-8 h-8 md:w-10 md:h-10 items-center justify-center bg-white/95 dark:bg-slate-800/95 text-slate-700 dark:text-slate-200 rounded-full hover:bg-blue-600 hover:text-white transition-all duration-300 shadow-lg border border-slate-200 dark:border-slate-600 group">
          <i class="fas fa-chevron-right text-xs md:text-sm group-hover:translate-x-0.5 transition-transform duration-300"></i>
        </button>

        <div id="imageCounter" class="hidden absolute top-2 right-2 md:top-3 md:right-3 z-20">
          <span class="px-1.5 py-0.5 md:px-2.5 md:py-1 bg-black/65 backdrop-blur-sm text-white rounded-full text-[10px] md:text-xs font-bold">
            <span id="currentImageIndex">1</span> / <span id="totalImages">1</span>
          </span>
        </div>
      </div>

      <div id="thumbnailRow" class="hidden mt-2 md:mt-3">
        <div id="thumbnailContainer" class="flex gap-1.5 md:gap-2 overflow-x-auto pb-1 scrollbar-hide"></div>
      </div>
    </div>

    <div class="px-4 md:px-6 pb-4 md:pb-6">
      <div class="mb-4 md:mb-6">
        <h3 class="text-sm md:text-base font-bold text-slate-900 dark:text-white mb-1 md:mb-2 flex items-center gap-2">
          <div class="w-5 h-5 md:w-6 md:h-6 rounded-md bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center">
            <i class="fas fa-info-circle text-blue-600 text-[10px] md:text-xs"></i>
          </div>
          About This Project
        </h3>
        <p id="modalFullDescription" class="text-slate-600 dark:text-slate-300 text-xs md:text-sm leading-relaxed"></p>
      </div>

      <div class="mb-4 md:mb-6">
        <h3 class="text-sm md:text-base font-bold text-slate-900 dark:text-white mb-1 md:mb-2 flex items-center gap-2">
          <div class="w-5 h-5 md:w-6 md:h-6 rounded-md bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center">
            <i class="fas fa-code text-blue-600 text-[10px] md:text-xs"></i>
          </div>
          Technologies Used
        </h3>
        <div id="modalTechnologies" class="flex flex-wrap gap-1.5 md:gap-2"></div>
      </div>

      <div class="flex flex-wrap gap-2 md:gap-3 pt-3 md:pt-5 border-t border-slate-200 dark:border-slate-800">
        <a id="modalWebsiteLink" href="#" target="_blank" 
           class="flex-1 min-w-[100px] md:min-w-[140px] flex items-center justify-center gap-1.5 md:gap-2 px-3 md:px-5 py-2 md:py-3 bg-blue-600 text-white rounded-lg md:rounded-xl font-bold text-[10px] md:text-sm hover:bg-blue-700 transition-all duration-300 shadow-md">
          <i class="fas fa-globe"></i>Visit Website
        </a>

        <a id="modalGithubLink" href="#" target="_blank" 
           class="flex-1 min-w-[100px] md:min-w-[140px] flex items-center justify-center gap-1.5 md:gap-2 px-3 md:px-5 py-2 md:py-3 bg-slate-800 dark:bg-slate-700 text-white rounded-lg md:rounded-xl font-bold text-[10px] md:text-sm hover:bg-slate-900 dark:hover:bg-slate-600 transition-all duration-300 shadow-md">
          <i class="fab fa-github"></i>View on GitHub
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  /* ===== MOBILE PERFORMANCE OPTIMIZATIONS ===== */
  @media (max-width: 768px) {
    /* Hide heavy animations on mobile */
    .mobile-hide-icon { display: none !important; }
    .mobile-hide-bracket { display: none !important; }
    .mobile-hide-terminal { display: none !important; }
    .mobile-hide-orbits { display: none !important; }
    .mobile-hide-status { display: none !important; }
    .mobile-hide-glow { display: none !important; }
    .mobile-hide-scan line { animation-duration: 6s !important; }
    
    /* Reduce particle count on mobile */
    #particles-container .tech-particle:nth-child(n+7) { display: none !important; }
    
    /* Disable backdrop blur on mobile */
    .backdrop-blur-sm { backdrop-filter: none !important; }
    .backdrop-blur-md { backdrop-filter: none !important; }
    
    /* Reduce blur on glowing orbs */
    .blur-3xl { filter: blur(20px) !important; }
    
    /* Simplify transitions */
    * { transition-duration: 0.2s !important; }
    
    /* Disable scale transforms on mobile */
    .hover\:scale-105:hover { transform: none !important; }
    .group-hover\:scale-110:hover { transform: none !important; }
  }

  @media (max-width: 480px) {
    /* Further reduce for small phones */
    .tech-particle { display: none !important; }
    #particles-container .tech-particle:nth-child(-n+4) { display: block !important; }
  }

  /* ===== PERFORMANCE: Reduce animation on reduced-motion preference ===== */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* ===== BASE ANIMATIONS (same as before, but optimized) ===== */
  .card-border {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }
  .card-border.border-zoom {
    border-width: 2.5px;
    border-color: #1e40af;
    transform: scale(1.02);
    box-shadow: 0 0 20px rgba(30, 64, 175, 0.3) !important;
  }

  @keyframes scan-line {
    0%, 100% { opacity: 0; transform: translateX(-100%) translateZ(0); }
    50% { opacity: 1; }
  }
  .animate-scan-line { animation: scan-line 4s ease-in-out infinite; will-change: transform, opacity; }

  @keyframes float-tech {
    0%, 100% { transform: translateY(0px) rotateZ(0deg) translateZ(0); }
    25% { transform: translateY(-15px) rotateZ(3deg) translateZ(0); }
    50% { transform: translateY(-30px) rotateZ(0deg) translateZ(0); }
    75% { transform: translateY(-15px) rotateZ(-3deg) translateZ(0); }
  }
  .animate-float-tech { animation: float-tech 8s ease-in-out infinite; will-change: transform; }

  @keyframes tech-float {
    0% { transform: translateY(100vh) translateX(0) translateZ(0); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(-100vh) translateX(80px) translateZ(0); opacity: 0; }
  }
  .animate-tech-float { animation: tech-float 20s linear infinite; will-change: transform, opacity; }

  .shadow-glow-blue { box-shadow: 0 0 8px rgba(30,64,175,0.6), 0 0 16px rgba(30,64,175,0.3); }
  .shadow-glow-indigo { box-shadow: 0 0 8px rgba(79,70,229,0.6), 0 0 16px rgba(79,70,229,0.3); }
  .shadow-glow-sky { box-shadow: 0 0 8px rgba(2,132,199,0.6), 0 0 16px rgba(2,132,199,0.3); }
  .shadow-glow-violet { box-shadow: 0 0 8px rgba(139,92,246,0.6), 0 0 16px rgba(139,92,246,0.3); }
  .shadow-glow-teal { box-shadow: 0 0 8px rgba(20,184,166,0.6), 0 0 16px rgba(20,184,166,0.3); }
  .shadow-glow-rose { box-shadow: 0 0 8px rgba(244,63,94,0.6), 0 0 16px rgba(244,63,94,0.3); }

  @keyframes rotate-slow {
    0% { transform: rotate(0deg) translateZ(0); }
    100% { transform: rotate(360deg) translateZ(0); }
  }
  .animate-rotate-slow { animation: rotate-slow 20s linear infinite; will-change: transform; }

  @keyframes orbit-1 { 0% { cx:95; cy:50; } 33.33% { cx:50; cy:5; } 66.66% { cx:5; cy:50; } 100% { cx:95; cy:50; } }
  @keyframes orbit-2 { 0% { cx:50; cy:5; } 33.33% { cx:5; cy:50; } 66.66% { cx:95; cy:50; } 100% { cx:50; cy:5; } }
  @keyframes orbit-3 { 0% { cx:5; cy:50; } 33.33% { cx:95; cy:50; } 66.66% { cx:50; cy:5; } 100% { cx:5; cy:50; } }
  .animate-orbit-1 { animation: orbit-1 6s linear infinite; }
  .animate-orbit-2 { animation: orbit-2 6s linear infinite; }
  .animate-orbit-3 { animation: orbit-3 6s linear infinite; }

  @keyframes status-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 8px currentColor; }
    50% { opacity: 0.5; box-shadow: 0 0 4px currentColor; }
  }
  .animate-status-pulse { animation: status-pulse 2s cubic-bezier(0.4,0,0.6,1) infinite; }

  @keyframes status-ping { 75%, 100% { transform: scale(2) translateZ(0); opacity: 0; } }
  .animate-status-ping { animation: status-ping 2s cubic-bezier(0,0,0.2,1) infinite; will-change: transform, opacity; }

  @keyframes pulse-glow {
    0%, 100% { opacity: 0.4; filter: blur(30px); }
    50% { opacity: 0.7; filter: blur(20px); }
  }
  .animate-pulse-glow { animation: pulse-glow 4s ease-in-out infinite; will-change: opacity, filter; }

  @keyframes float-bracket {
    0%,100% { transform: translateY(0) scale(1) rotate(0deg); opacity:0.2; }
    25% { transform: translateY(-12px) scale(1.03) rotate(2deg); opacity:0.3; }
    50% { transform: translateY(-24px) scale(0.97) rotate(-2deg); opacity:0.4; }
    75% { transform: translateY(-12px) scale(1.03) rotate(1deg); opacity:0.3; }
  }
  .animate-float-bracket { animation: float-bracket 7s ease-in-out infinite; will-change: transform,opacity; }

  @keyframes terminal-cursor {
    0%,100% { opacity:0.2; transform:translateX(0); }
    50% { opacity:0.5; transform:translateX(6px); }
  }
  .animate-terminal-cursor { animation: terminal-cursor 8s ease-in-out infinite; will-change: transform,opacity; }

  @keyframes blink-cursor { 0%,100% { opacity:1; } 50% { opacity:0; } }
  .animate-blink-cursor { animation: blink-cursor 1s step-end infinite; will-change: opacity; }

  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px) translateZ(0); }
    to { opacity: 1; transform: translateY(0) translateZ(0); }
  }
  .animate-fade-in-up { animation: fade-in-up 0.6s ease-out forwards; will-change: transform, opacity; }

  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0) translateZ(0); }
    50% { transform: translateY(-8px) translateZ(0); }
  }
  .animate-bounce-slow { animation: bounce-slow 2s ease-in-out infinite; }

  .bg-grid-tech {
    background-image: 
      linear-gradient(0deg, transparent 24%, rgba(30,64,175,0.04) 25%, rgba(30,64,175,0.04) 26%, transparent 27%, transparent 74%, rgba(30,64,175,0.04) 75%, rgba(30,64,175,0.04) 76%, transparent 77%, transparent),
      linear-gradient(90deg, transparent 24%, rgba(30,64,175,0.04) 25%, rgba(30,64,175,0.04) 26%, transparent 27%, transparent 74%, rgba(30,64,175,0.04) 75%, rgba(30,64,175,0.04) 76%, transparent 77%, transparent);
    background-size: 50px 50px;
  }

  @media (prefers-color-scheme: dark) {
    .bg-grid-tech {
      background-image: 
        linear-gradient(0deg, transparent 24%, rgba(30,64,175,0.06) 25%, rgba(30,64,175,0.06) 26%, transparent 27%, transparent 74%, rgba(30,64,175,0.06) 75%, rgba(30,64,175,0.06) 76%, transparent 77%, transparent),
        linear-gradient(90deg, transparent 24%, rgba(30,64,175,0.06) 25%, rgba(30,64,175,0.06) 26%, transparent 27%, transparent 74%, rgba(30,64,175,0.06) 75%, rgba(30,64,175,0.06) 76%, transparent 77%, transparent);
    }
  }

  .stat-box { @apply bg-white dark:bg-slate-900 backdrop-blur-sm border-t-2 border-l-2 border-blue-300 dark:border-blue-700/50 rounded-xl p-3 md:p-4; }
  .stat-box:hover { @apply border-blue-600 dark:border-blue-600 shadow-lg shadow-blue-200/50 dark:shadow-blue-900/50; }

  .feature-card { @apply bg-white dark:bg-slate-900 backdrop-blur-sm border-t-2 border-l-2 border-blue-300 dark:border-blue-700/50 rounded-xl md:rounded-2xl p-4 md:p-6; }
  .feature-card:hover { @apply border-blue-600 dark:border-blue-600 shadow-lg; }

  .badge { @apply text-[10px] md:text-xs px-2 md:px-3 py-1 md:py-1.5 rounded-full bg-blue-100 dark:bg-blue-950/40 text-blue-700 dark:text-blue-300 border border-blue-300 dark:border-blue-800/50 font-medium; }
  .badge-glow { @apply inline-flex items-center px-3 md:px-4 py-1.5 md:py-2 rounded-full bg-blue-100 dark:bg-blue-900/40 border-2 border-blue-600 dark:border-blue-600 font-bold text-sm md:text-base; }

  .btn-primary { @apply px-4 md:px-8 py-2.5 md:py-4 bg-gradient-to-r from-blue-700 to-indigo-700 hover:from-blue-800 hover:to-indigo-800 text-white font-bold rounded-lg md:rounded-xl shadow-lg shadow-blue-500/30 hover:shadow-xl hover:shadow-blue-500/50 transition-all duration-300 inline-flex items-center gap-2 md:gap-3 hover:scale-105; }
  .btn-secondary { @apply px-4 md:px-8 py-2.5 md:py-4 bg-white dark:bg-slate-900 text-slate-900 dark:text-white border-2 border-blue-600 dark:border-blue-600 font-bold rounded-lg md:rounded-xl hover:bg-blue-50 dark:hover:bg-slate-800 transition-all duration-300 inline-flex items-center gap-2 md:gap-3 hover:scale-105; }

  .section-title { @apply text-2xl sm:text-3xl md:text-5xl font-black mb-2 md:mb-4; }
  .section-subtitle { @apply text-base sm:text-lg md:text-2xl; }

  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

  .modal-content::-webkit-scrollbar { width: 4px; }
  .modal-content::-webkit-scrollbar-track { background: rgb(241 245 249); border-radius: 10px; }
  .dark .modal-content::-webkit-scrollbar-track { background: rgb(30 41 59); }
  .modal-content::-webkit-scrollbar-thumb { background: rgb(59 130 246); border-radius: 10px; }

  .animate-scan-line,
  .animate-float-tech,
  .animate-float-bracket,
  .animate-tech-float,
  .animate-rotate-slow,
  .animate-pulse-glow,
  .animate-terminal-cursor {
    contain: layout style paint;
  }

  @media (max-width: 768px) {
    .animate-float-tech { animation-duration: 12s; }
    .animate-tech-float { animation-duration: 25s; }
    .animate-float-bracket { animation-duration: 10s; }
  }

  @media (prefers-reduced-motion: reduce) {
    * { transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
  }
</style>

<script>
  let currentProject = null;
  let currentImageIndex = 0;

  function scrollToTop() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  document.addEventListener('DOMContentLoaded', function() {
    const backToTopBtn = document.getElementById('backToTop');
    window.addEventListener('scroll', function() {
      if (window.scrollY > 300) {
        backToTopBtn.classList.remove('opacity-0', 'invisible', 'translate-y-4');
        backToTopBtn.classList.add('opacity-100', 'visible', 'translate-y-0');
      } else {
        backToTopBtn.classList.remove('opacity-100', 'visible', 'translate-y-0');
        backToTopBtn.classList.add('opacity-0', 'invisible', 'translate-y-4');
      }
    });

    // Detect mobile and add class for further optimizations
    if (window.innerWidth <= 768) {
      document.body.classList.add('mobile-device');
    }
  });

  function borderZoom(e) { e.currentTarget.classList.add('border-zoom'); }
  function borderUnzoom(e) { e.currentTarget.classList.remove('border-zoom'); }

  function openProjectModal(project) {
    try {
      currentProject = project;
      currentImageIndex = 0;
      const modal = document.getElementById('projectModal');
      const modalContent = modal.querySelector('.modal-content');

      document.getElementById('modalTitle').textContent = project.title || 'Untitled Project';
      document.getElementById('modalDescription').textContent = project.description || '';
      document.getElementById('modalFullDescription').textContent = project.fullDescription || project.description || 'No description available.';
      document.getElementById('modalCategory').textContent = (project.category || 'General').toUpperCase();

      const featuredBadge = document.getElementById('modalFeatured');
      project.featured ? featuredBadge.classList.remove('hidden') : featuredBadge.classList.add('hidden');

      const websiteLink = document.getElementById('modalWebsiteLink');
      if (project.websiteUrl && project.id !== 1) {
        websiteLink.href = project.websiteUrl;
        websiteLink.style.display = 'flex';
      } else {
        websiteLink.style.display = 'none';
      }

      const githubLink = document.getElementById('modalGithubLink');
      if (project.githubUrl) {
        githubLink.href = project.githubUrl;
        githubLink.style.display = 'flex';
      } else {
        githubLink.style.display = 'none';
      }

      const techArray = project.tech || project.technologies || [];
      document.getElementById('modalTechnologies').innerHTML = techArray.map(function(tech) {
        return `<span class="px-2 md:px-3 py-1 md:py-1.5 rounded-lg text-[10px] md:text-xs font-semibold bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 border-2 border-blue-200 dark:border-blue-800">${tech}</span>`;
      }).join('');

      buildSlider(project.images || []);
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      setTimeout(function() {
        modalContent.classList.remove('scale-95', 'opacity-0');
        modalContent.classList.add('scale-100', 'opacity-100');
      }, 10);
      document.body.style.overflow = 'hidden';
    } catch (error) {
      console.error('Error opening modal:', error);
    }
  }

  function buildSlider(images) {
    const slider = document.getElementById('imageSlider');
    const thumbContainer = document.getElementById('thumbnailContainer');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const counter = document.getElementById('imageCounter');
    const thumbRow = document.getElementById('thumbnailRow');

    document.getElementById('totalImages').textContent = images.length || 0;
    slider.innerHTML = '';
    thumbContainer.innerHTML = '';

    const hasMultiple = images.length > 1;
    prevBtn.classList.toggle('hidden', !hasMultiple);
    prevBtn.classList.toggle('flex', hasMultiple);
    nextBtn.classList.toggle('hidden', !hasMultiple);
    nextBtn.classList.toggle('flex', hasMultiple);
    counter.classList.toggle('hidden', !hasMultiple);
    thumbRow.classList.toggle('hidden', !hasMultiple);

    if (images.length === 0) {
      const slide = document.createElement('div');
      slide.className = 'slider-slide w-full relative';
      slide.style.display = 'block';
      slide.innerHTML = `<div class="flex items-center justify-center h-48 md:h-64 bg-slate-200 dark:bg-slate-700 rounded-xl"><i class="fas fa-image text-4xl md:text-6xl text-slate-400 dark:text-slate-500"></i></div>`;
      slider.appendChild(slide);
      return;
    }

    images.forEach(function(src, i) {
      const slide = document.createElement('div');
      slide.className = 'slider-slide w-full';
      slide.style.display = i === 0 ? 'block' : 'none';
      slide.style.position = i === 0 ? 'relative' : 'absolute';
      if (i !== 0) { slide.style.top = '0'; slide.style.left = '0'; slide.style.width = '100%'; }
      slide.innerHTML = `<img src="${src}" alt="Slide ${i+1}" class="w-full h-auto block" style="max-height:350px; object-fit:contain;" onerror="this.parentElement.innerHTML='<div class=\\'flex items-center justify-center h-48 md:h-64 bg-slate-200 dark:bg-slate-700 rounded-xl\\'><i class=\\'fas fa-image text-4xl md:text-6xl text-slate-400 dark:text-slate-500\\'></i></div>'" />`;
      slider.appendChild(slide);
    });

    images.forEach(function(src, i) {
      const btn = document.createElement('button');
      btn.className = 'thumb-btn flex-shrink-0 w-10 h-10 md:w-14 md:h-14 rounded-lg overflow-hidden border-2 transition-all duration-300 ' + (i === 0 ? 'border-blue-600 ring-2 ring-blue-400 ring-offset-1 opacity-100' : 'border-slate-300 dark:border-slate-600 opacity-50 hover:opacity-80');
      btn.innerHTML = `<img src="${src}" alt="thumb ${i+1}" class="w-full h-full object-cover" onerror="this.style.display='none'" />`;
      btn.onclick = function() { goToImage(i); };
      thumbContainer.appendChild(btn);
    });
    updateCounter();
  }

  function goToImage(index) {
    const slides = document.querySelectorAll('.slider-slide');
    const thumbs = document.querySelectorAll('.thumb-btn');
    const slider = document.getElementById('imageSlider');
    if (!slides.length || index < 0 || index >= slides.length) return;

    const currentSlide = slides[currentImageIndex];
    if (currentSlide) {
      slider.style.height = currentSlide.offsetHeight + 'px';
      slider.style.position = 'relative';
      currentSlide.style.display = 'none';
      currentSlide.style.position = 'absolute';
    }
    if (thumbs[currentImageIndex]) {
      thumbs[currentImageIndex].classList.remove('border-blue-600', 'ring-2', 'ring-blue-400', 'ring-offset-1', 'opacity-100');
      thumbs[currentImageIndex].classList.add('border-slate-300', 'opacity-50');
    }
    currentImageIndex = index;
    const newSlide = slides[currentImageIndex];
    if (newSlide) {
      newSlide.style.position = 'absolute';
      newSlide.style.top = '0';
      newSlide.style.left = '0';
      newSlide.style.width = '100%';
      newSlide.style.display = 'block';
    }
    if (thumbs[currentImageIndex]) {
      thumbs[currentImageIndex].classList.add('border-blue-600', 'ring-2', 'ring-blue-400', 'ring-offset-1', 'opacity-100');
      thumbs[currentImageIndex].classList.remove('border-slate-300', 'opacity-50');
    }
    if (newSlide) {
      const newImg = newSlide.querySelector('img');
      const releaseHeight = function() {
        slider.style.height = '';
        slider.style.position = '';
        newSlide.style.position = 'relative';
        newSlide.style.top = '';
        newSlide.style.left = '';
        newSlide.style.width = '';
      };
      if (newImg && newImg.complete) releaseHeight();
      else if (newImg) { newImg.onload = releaseHeight; newImg.onerror = releaseHeight; setTimeout(releaseHeight, 600); }
      else releaseHeight();
    }
    updateCounter();
    if (thumbs[currentImageIndex]) {
      thumbs[currentImageIndex].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }
  }

  function previousImage() {
    if (!currentProject || !currentProject.images || currentProject.images.length === 0) return;
    goToImage(currentImageIndex === 0 ? currentProject.images.length - 1 : currentImageIndex - 1);
  }

  function nextImage() {
    if (!currentProject || !currentProject.images || currentProject.images.length === 0) return;
    goToImage(currentImageIndex === currentProject.images.length - 1 ? 0 : currentImageIndex + 1);
  }

  function updateCounter() {
    const total = document.getElementById('totalImages').textContent;
    document.getElementById('currentImageIndex').textContent = parseInt(total) > 0 ? currentImageIndex + 1 : '0';
  }

  function closeProjectModal() {
    const modal = document.getElementById('projectModal');
    const modalContent = modal.querySelector('.modal-content');
    modalContent.classList.remove('scale-100', 'opacity-100');
    modalContent.classList.add('scale-95', 'opacity-0');
    setTimeout(function() {
      modal.classList.remove('flex');
      modal.classList.add('hidden');
      document.body.style.overflow = 'auto';
      currentProject = null;
      currentImageIndex = 0;
    }, 300);
  }

  document.getElementById('projectModal').addEventListener('click', function(e) {
    if (e.target === this) closeProjectModal();
  });

  document.addEventListener('keydown', function(e) {
    if (document.getElementById('projectModal').classList.contains('hidden')) return;
    if (e.key === 'ArrowLeft') previousImage();
    else if (e.key === 'ArrowRight') nextImage();
    else if (e.key === 'Escape') closeProjectModal();
  });
</script>

