<style>
  /* ============================================================
     MOBILE OPTIMIZATION: DISABLE HEAVY GPU EFFECTS
     ============================================================ */
  
  @media (max-width: 768px) {
    /* 1. DISABLE BACKDROP BLUR (HEAVIEST GPU KILLER) */
    .backdrop-blur-sm,
    .backdrop-blur-md,
    .backdrop-blur-lg,
    .backdrop-blur-xl,
    .backdrop-blur-2xl,
    .bg-white\/95,
    .dark\:bg-slate-950\/95,
    .bg-white\/90,
    .dark\:bg-slate-800\/90,
    .bg-white\/80,
    .dark\:bg-slate-800\/80,
    .bg-white\/50,
    .dark\:bg-slate-900\/50,
    .bg-black\/60,
    [class*="backdrop-blur"] {
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
    }

    /* 2. HIDE PARTICLES (HEAVY) */
    .mobile-hide-particles {
      display: none !important;
    }

    /* 3. HIDE ORBITS (HEAVY) */
    .mobile-hide-orbits {
      display: none !important;
    }

    /* 4. HIDE GLOWING ORBS (HEAVY) */
    .mobile-hide-glow {
      display: none !important;
    }

    /* 5. REDUCE SCAN LINES (MEDIUM) - keep only 2 lines */
    .animate-scan-line:nth-child(n+3) {
      display: none !important;
    }

    /* 6. REDUCE FLOATING ICONS (MEDIUM) - keep only 6 */
    .tech-icon:nth-child(n+7) {
      display: none !important;
    }

    /* 7. HIDE CODE BRACKETS (LOW COST - keep for aesthetic) */
    /* Kept visible - they're light */
  }

  @media (max-width: 480px) {
    /* Further reduce on small phones */
    .tech-icon:nth-child(n+4) {
      display: none !important;
    }
    .animate-scan-line:nth-child(n+2) {
      display: none !important;
    }
  }

  /* ============================================================
     PERFORMANCE: Reduced motion preference
     ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* ============================================================
     REST OF STYLES (unchanged - keep all existing styles)
     ============================================================ */
  
  /* Border Zoom Animation */
  .card-border {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }
  .card-border.border-zoom {
    border-width: 2.5px;
    border-color: #1e40af;
    transform: scale(1.02);
    box-shadow: 0 0 20px rgba(30, 64, 175, 0.3) !important;
  }

  /* Scan Line Animation */
  @keyframes scan-line {
    0%, 100% { opacity: 0; transform: translateX(-100%) translateZ(0); }
    50% { opacity: 1; }
  }
  .animate-scan-line {
    animation: scan-line 4s ease-in-out infinite;
    will-change: transform, opacity;
  }

  /* Tech Float Animation */
  @keyframes float-tech {
    0%, 100% { transform: translateY(0px) rotateZ(0deg) translateZ(0); }
    25% { transform: translateY(-20px) rotateZ(5deg) translateZ(0); }
    50% { transform: translateY(-40px) rotateZ(0deg) translateZ(0); }
    75% { transform: translateY(-20px) rotateZ(-5deg) translateZ(0); }
  }
  .animate-float-tech {
    animation: float-tech 8s ease-in-out infinite;
    will-change: transform;
  }

  /* Particle Float */
  @keyframes tech-float {
    0% { transform: translateY(100vh) translateX(0) translateZ(0); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(-100vh) translateX(100px) translateZ(0); opacity: 0; }
  }
  .animate-tech-float {
    animation: tech-float 20s linear infinite;
    will-change: transform, opacity;
  }

  /* Particle Glow Effects */
  .shadow-glow-blue { box-shadow: 0 0 10px rgba(30, 64, 175, 0.8), 0 0 20px rgba(30, 64, 175, 0.4); }
  .shadow-glow-indigo { box-shadow: 0 0 10px rgba(79, 70, 229, 0.8), 0 0 20px rgba(79, 70, 229, 0.4); }
  .shadow-glow-sky { box-shadow: 0 0 10px rgba(2, 132, 199, 0.8), 0 0 20px rgba(2, 132, 199, 0.4); }
  .shadow-glow-violet { box-shadow: 0 0 10px rgba(139, 92, 246, 0.8), 0 0 20px rgba(139, 92, 246, 0.4); }
  .shadow-glow-teal { box-shadow: 0 0 10px rgba(20, 184, 166, 0.8), 0 0 20px rgba(20, 184, 166, 0.4); }
  .shadow-glow-rose { box-shadow: 0 0 10px rgba(244, 63, 94, 0.8), 0 0 20px rgba(244, 63, 94, 0.4); }

  /* Rotate Slow */
  @keyframes rotate-slow {
    0% { transform: rotate(0deg) translateZ(0); }
    100% { transform: rotate(360deg) translateZ(0); }
  }
  .animate-rotate-slow {
    animation: rotate-slow 20s linear infinite;
    will-change: transform;
  }

  /* Orbit Animations */
  @keyframes orbit-1 { 0% { cx:95; cy:50; } 33.33% { cx:50; cy:5; } 66.66% { cx:5; cy:50; } 100% { cx:95; cy:50; } }
  @keyframes orbit-2 { 0% { cx:50; cy:5; } 33.33% { cx:5; cy:50; } 66.66% { cx:95; cy:50; } 100% { cx:50; cy:5; } }
  @keyframes orbit-3 { 0% { cx:5; cy:50; } 33.33% { cx:95; cy:50; } 66.66% { cx:50; cy:5; } 100% { cx:5; cy:50; } }
  .animate-orbit-1 { animation: orbit-1 6s linear infinite; }
  .animate-orbit-2 { animation: orbit-2 6s linear infinite; }
  .animate-orbit-3 { animation: orbit-3 6s linear infinite; }

  /* Status Pulse */
  @keyframes status-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 10px currentColor; }
    50% { opacity: 0.5; box-shadow: 0 0 5px currentColor; }
  }
  .animate-status-pulse {
    animation: status-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes status-ping { 75%, 100% { transform: scale(2) translateZ(0); opacity: 0; } }
  .animate-status-ping {
    animation: status-ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
    will-change: transform, opacity;
  }

  /* Pulse Glow */
  @keyframes pulse-glow {
    0%, 100% { opacity: 0.5; filter: blur(30px); }
    50% { opacity: 1; filter: blur(15px); }
  }
  .animate-pulse-glow {
    animation: pulse-glow 4s ease-in-out infinite;
    will-change: opacity, filter;
  }

  /* Tech Grid Pattern */
  .bg-grid-tech {
    background-image: 
      linear-gradient(0deg, transparent 24%, rgba(30, 64, 175, 0.05) 25%, rgba(30, 64, 175, 0.05) 26%, transparent 27%, transparent 74%, rgba(30, 64, 175, 0.05) 75%, rgba(30, 64, 175, 0.05) 76%, transparent 77%, transparent),
      linear-gradient(90deg, transparent 24%, rgba(30, 64, 175, 0.05) 25%, rgba(30, 64, 175, 0.05) 26%, transparent 27%, transparent 74%, rgba(30, 64, 175, 0.05) 75%, rgba(30, 64, 175, 0.05) 76%, transparent 77%, transparent);
    background-size: 50px 50px;
  }
  @media (prefers-color-scheme: dark) {
    .bg-grid-tech {
      background-image: 
        linear-gradient(0deg, transparent 24%, rgba(30, 64, 175, 0.08) 25%, rgba(30, 64, 175, 0.08) 26%, transparent 27%, transparent 74%, rgba(30, 64, 175, 0.08) 75%, rgba(30, 64, 175, 0.08) 76%, transparent 77%, transparent),
        linear-gradient(90deg, transparent 24%, rgba(30, 64, 175, 0.08) 25%, rgba(30, 64, 175, 0.08) 26%, transparent 27%, transparent 74%, rgba(30, 64, 175, 0.08) 75%, rgba(30, 64, 175, 0.08) 76%, transparent 77%, transparent);
    }
  }

  /* Floating Code Brackets */
  @keyframes float-bracket {
    0%,100% { transform: translateY(0) scale(1) rotate(0deg); opacity:0.2; }
    25% { transform: translateY(-15px) scale(1.05) rotate(2deg); opacity:0.35; }
    50% { transform: translateY(-30px) scale(0.95) rotate(-2deg); opacity:0.5; }
    75% { transform: translateY(-15px) scale(1.05) rotate(1deg); opacity:0.35; }
  }
  .animate-float-bracket {
    animation: float-bracket 7s ease-in-out infinite;
    will-change: transform,opacity;
  }

  /* Terminal cursor */
  @keyframes terminal-cursor {
    0%,100% { opacity:0.2; transform:translateX(0); }
    50% { opacity:0.6; transform:translateX(8px); }
  }
  .animate-terminal-cursor {
    animation: terminal-cursor 8s ease-in-out infinite;
    will-change: transform,opacity;
  }

  @keyframes blink-cursor { 0%,100% { opacity:1; } 50% { opacity:0; } }
  .animate-blink-cursor {
    animation: blink-cursor 1s step-end infinite;
    will-change: opacity;
  }

  /* Matrix float (kept for future use) */
  @keyframes matrix-float {
    0%,100% { opacity:0.06; transform:translateY(0); }
    50% { opacity:0.15; transform:translateY(-8px); }
  }
  .animate-matrix-float {
    animation: matrix-float 6s ease-in-out infinite;
    will-change: transform,opacity;
  }

  /* Adaptive Stat Box */
  .stat-box {
    @apply bg-white dark:bg-slate-900 backdrop-blur-sm border-t-2 border-l-2 border-blue-300 dark:border-blue-700/50 rounded-xl p-4;
  }
  .stat-box:hover {
    @apply border-blue-600 dark:border-blue-600 shadow-lg shadow-blue-200/50 dark:shadow-blue-900/50;
  }

  /* Feature Card */
  .feature-card {
    @apply bg-white dark:bg-slate-900 backdrop-blur-sm border-t-2 border-l-2 border-blue-300 dark:border-blue-700/50 rounded-2xl p-6;
  }
  .feature-card:hover {
    @apply border-blue-600 dark:border-blue-600 shadow-lg;
  }

  /* Badge */
  .badge {
    @apply text-xs px-3 py-1.5 rounded-full bg-blue-100 dark:bg-blue-950/40 text-blue-700 dark:text-blue-300 border border-blue-300 dark:border-blue-800/50 font-medium;
  }
  .badge-glow {
    @apply inline-flex items-center px-4 py-2 rounded-full bg-blue-100 dark:bg-blue-900/40 border-2 border-blue-600 dark:border-blue-600 font-bold;
  }

  /* Buttons */
  .btn-primary {
    @apply px-8 py-4 bg-gradient-to-r from-blue-700 to-indigo-700 hover:from-blue-800 hover:to-indigo-800 text-white font-bold rounded-xl shadow-lg shadow-blue-500/30 hover:shadow-xl hover:shadow-blue-500/50 transition-all duration-300 inline-flex items-center gap-3 hover:scale-105;
  }
  .btn-secondary {
    @apply px-8 py-4 bg-white dark:bg-slate-900 text-slate-900 dark:text-white border-2 border-blue-600 dark:border-blue-600 font-bold rounded-xl hover:bg-blue-50 dark:hover:bg-slate-800 transition-all duration-300 inline-flex items-center gap-3 hover:scale-105;
  }

  /* Section */
  .section-title { @apply text-4xl md:text-5xl font-black mb-4; }
  .section-subtitle { @apply text-xl md:text-2xl; }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

  .modal-content::-webkit-scrollbar { width: 5px; }
  .modal-content::-webkit-scrollbar-track { background: rgb(241 245 249); border-radius: 10px; }
  .dark .modal-content::-webkit-scrollbar-track { background: rgb(30 41 59); }
  .modal-content::-webkit-scrollbar-thumb { background: rgb(59 130 246); border-radius: 10px; }

  /* Performance: contain paint and layout */
  .animate-scan-line,
  .animate-float-tech,
  .animate-float-bracket,
  .animate-tech-float,
  .animate-rotate-slow,
  .animate-pulse-glow,
  .animate-matrix-float,
  .animate-terminal-cursor {
    contain: layout style paint;
  }

  @media (max-width: 768px) {
    .animate-float-tech { animation-duration: 12s; }
    .animate-tech-float { animation-duration: 30s; }
    .animate-float-bracket { animation-duration: 10s; }
  }
</style>

<script>
  let currentProject = null;
  let currentImageIndex = 0;

  function scrollToTop() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  document.addEventListener('DOMContentLoaded', function() {
    const backToTopBtn = document.getElementById('backToTop');
    window.addEventListener('scroll', function() {
      if (window.scrollY > 300) {
        backToTopBtn.classList.remove('opacity-0', 'invisible', 'translate-y-4');
        backToTopBtn.classList.add('opacity-100', 'visible', 'translate-y-0');
      } else {
        backToTopBtn.classList.remove('opacity-100', 'visible', 'translate-y-0');
        backToTopBtn.classList.add('opacity-0', 'invisible', 'translate-y-4');
      }
    });
  });

  function borderZoom(event) {
    event.currentTarget.classList.add('border-zoom');
  }

  function borderUnzoom(event) {
    event.currentTarget.classList.remove('border-zoom');
  }

  function openProjectModal(project) {
    try {
      currentProject = project;
      currentImageIndex = 0;
      const modal = document.getElementById('projectModal');
      const modalContent = modal.querySelector('.modal-content');

      document.getElementById('modalTitle').textContent = project.title || 'Untitled Project';
      document.getElementById('modalDescription').textContent = project.description || '';
      document.getElementById('modalFullDescription').textContent = project.fullDescription || project.description || 'No description available.';
      document.getElementById('modalCategory').textContent = (project.category || 'General').toUpperCase();

      const featuredBadge = document.getElementById('modalFeatured');
      project.featured ? featuredBadge.classList.remove('hidden') : featuredBadge.classList.add('hidden');

      const websiteLink = document.getElementById('modalWebsiteLink');
      if (project.websiteUrl && project.id !== 1) {
        websiteLink.href = project.websiteUrl;
        websiteLink.style.display = 'flex';
      } else {
        websiteLink.style.display = 'none';
      }

      const githubLink = document.getElementById('modalGithubLink');
      if (project.githubUrl) {
        githubLink.href = project.githubUrl;
        githubLink.style.display = 'flex';
      } else {
        githubLink.style.display = 'none';
      }

      const techArray = project.tech || project.technologies || [];
      document.getElementById('modalTechnologies').innerHTML = techArray.map(function(tech) {
        return `<span class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 border-2 border-blue-200 dark:border-blue-800">${tech}</span>`;
      }).join('');

      buildSlider(project.images || []);
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      setTimeout(function() {
        modalContent.classList.remove('scale-95', 'opacity-0');
        modalContent.classList.add('scale-100', 'opacity-100');
      }, 10);
      document.body.style.overflow = 'hidden';
    } catch (error) {
      console.error('Error opening modal:', error);
    }
  }

  function buildSlider(images) {
    const slider = document.getElementById('imageSlider');
    const thumbContainer = document.getElementById('thumbnailContainer');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const counter = document.getElementById('imageCounter');
    const thumbRow = document.getElementById('thumbnailRow');

    document.getElementById('totalImages').textContent = images.length || 0;
    slider.innerHTML = '';
    thumbContainer.innerHTML = '';

    const hasMultiple = images.length > 1;
    prevBtn.classList.toggle('hidden', !hasMultiple);
    prevBtn.classList.toggle('flex', hasMultiple);
    nextBtn.classList.toggle('hidden', !hasMultiple);
    nextBtn.classList.toggle('flex', hasMultiple);
    counter.classList.toggle('hidden', !hasMultiple);
    thumbRow.classList.toggle('hidden', !hasMultiple);

    if (images.length === 0) {
      const slide = document.createElement('div');
      slide.className = 'slider-slide w-full relative';
      slide.style.display = 'block';
      slide.innerHTML = `<div class="flex items-center justify-center h-64 bg-slate-200 dark:bg-slate-700 rounded-xl"><i class="fas fa-image text-6xl text-slate-400 dark:text-slate-500"></i></div>`;
      slider.appendChild(slide);
      return;
    }

    images.forEach(function(src, i) {
      const slide = document.createElement('div');
      slide.className = 'slider-slide w-full';
      slide.style.display = i === 0 ? 'block' : 'none';
      slide.style.position = i === 0 ? 'relative' : 'absolute';
      if (i !== 0) { slide.style.top = '0'; slide.style.left = '0'; slide.style.width = '100%'; }
      slide.innerHTML = `<img src="${src}" alt="Slide ${i+1}" class="w-full h-auto block" style="max-height:500px; object-fit:contain;" onerror="this.parentElement.innerHTML='<div class=\\'flex items-center justify-center h-64 bg-slate-200 dark:bg-slate-700 rounded-xl\\'><i class=\\'fas fa-image text-6xl text-slate-400 dark:text-slate-500\\'></i></div>'" />`;
      slider.appendChild(slide);
    });

    images.forEach(function(src, i) {
      const btn = document.createElement('button');
      btn.className = 'thumb-btn flex-shrink-0 w-14 h-14 rounded-lg overflow-hidden border-2 transition-all duration-300 ' + (i === 0 ? 'border-blue-600 ring-2 ring-blue-400 ring-offset-1 opacity-100' : 'border-slate-300 dark:border-slate-600 opacity-50 hover:opacity-80');
      btn.innerHTML = `<img src="${src}" alt="thumb ${i+1}" class="w-full h-full object-cover" onerror="this.style.display='none'" />`;
      btn.onclick = function() { goToImage(i); };
      thumbContainer.appendChild(btn);
    });
    updateCounter();
  }

  function goToImage(index) {
    const slides = document.querySelectorAll('.slider-slide');
    const thumbs = document.querySelectorAll('.thumb-btn');
    const slider = document.getElementById('imageSlider');
    if (!slides.length || index < 0 || index >= slides.length) return;

    const currentSlide = slides[currentImageIndex];
    if (currentSlide) {
      slider.style.height = currentSlide.offsetHeight + 'px';
      slider.style.position = 'relative';
      currentSlide.style.display = 'none';
      currentSlide.style.position = 'absolute';
    }
    if (thumbs[currentImageIndex]) {
      thumbs[currentImageIndex].classList.remove('border-blue-600', 'ring-2', 'ring-blue-400', 'ring-offset-1', 'opacity-100');
      thumbs[currentImageIndex].classList.add('border-slate-300', 'opacity-50');
    }
    currentImageIndex = index;
    const newSlide = slides[currentImageIndex];
    if (newSlide) {
      newSlide.style.position = 'absolute';
      newSlide.style.top = '0';
      newSlide.style.left = '0';
      newSlide.style.width = '100%';
      newSlide.style.display = 'block';
    }
    if (thumbs[currentImageIndex]) {
      thumbs[currentImageIndex].classList.add('border-blue-600', 'ring-2', 'ring-blue-400', 'ring-offset-1', 'opacity-100');
      thumbs[currentImageIndex].classList.remove('border-slate-300', 'opacity-50');
    }
    if (newSlide) {
      const newImg = newSlide.querySelector('img');
      const releaseHeight = function() {
        slider.style.height = '';
        slider.style.position = '';
        newSlide.style.position = 'relative';
        newSlide.style.top = '';
        newSlide.style.left = '';
        newSlide.style.width = '';
      };
      if (newImg && newImg.complete) releaseHeight();
      else if (newImg) { newImg.onload = releaseHeight; newImg.onerror = releaseHeight; setTimeout(releaseHeight, 800); }
      else releaseHeight();
    }
    updateCounter();
    if (thumbs[currentImageIndex]) {
      thumbs[currentImageIndex].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }
  }

  function previousImage() {
    if (!currentProject || !currentProject.images || currentProject.images.length === 0) return;
    goToImage(currentImageIndex === 0 ? currentProject.images.length - 1 : currentImageIndex - 1);
  }

  function nextImage() {
    if (!currentProject || !currentProject.images || currentProject.images.length === 0) return;
    goToImage(currentImageIndex === currentProject.images.length - 1 ? 0 : currentImageIndex + 1);
  }

  function updateCounter() {
    const total = document.getElementById('totalImages').textContent;
    document.getElementById('currentImageIndex').textContent = parseInt(total) > 0 ? currentImageIndex + 1 : '0';
  }

  function closeProjectModal() {
    const modal = document.getElementById('projectModal');
    const modalContent = modal.querySelector('.modal-content');
    modalContent.classList.remove('scale-100', 'opacity-100');
    modalContent.classList.add('scale-95', 'opacity-0');
    setTimeout(function() {
      modal.classList.remove('flex');
      modal.classList.add('hidden');
      document.body.style.overflow = 'auto';
      currentProject = null;
      currentImageIndex = 0;
    }, 300);
  }

  document.getElementById('projectModal').addEventListener('click', function(e) {
    if (e.target === this) closeProjectModal();
  });

  document.addEventListener('keydown', function(e) {
    if (document.getElementById('projectModal').classList.contains('hidden')) return;
    if (e.key === 'ArrowLeft') previousImage();
    else if (e.key === 'ArrowRight') nextImage();
    else if (e.key === 'Escape') closeProjectModal();
  });
</script>

