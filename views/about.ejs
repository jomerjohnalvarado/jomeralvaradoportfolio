            <i class="fas fa-graduation-cap text-blue-600 dark:text-blue-400"></i> BSIT Graduate 2025
          </span>
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/80 dark:bg-slate-800/80 border-t-2 border-l-2 border-indigo-500 dark:border-indigo-500/60 text-sm font-semibold text-gray-800 dark:text-slate-200 shadow-sm">
            <i class="fas fa-map-marker-alt text-indigo-600 dark:text-indigo-400"></i> Philippines
          </span>
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/80 dark:bg-slate-800/80 border-t-2 border-l-2 border-sky-500 dark:border-sky-500/60 text-sm font-semibold text-gray-800 dark:text-slate-200 shadow-sm">
            <i class="fas fa-briefcase text-sky-600 dark:text-sky-400"></i> OWWA Intern Alum
          </span>
        </div>

        <div class="flex flex-wrap gap-4">
          <a href="/contact" class="group/cta inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-blue-700 to-indigo-700 text-white font-bold rounded-lg hover:shadow-lg hover:shadow-blue-500/50 hover:scale-105 transition-all duration-300 border-t-2 border-l-2 border-blue-900/50">
            <i class="fas fa-envelope group-hover/cta:rotate-12 transition-transform"></i>
            <span>Get In Touch</span>
          </a>
          <a href="/resume.pdf" class="group/cta2 inline-flex items-center gap-2 px-6 py-3 border-t-2 border-l-2 border-blue-600 dark:border-blue-500/60 text-blue-700 dark:text-blue-400 font-bold rounded-lg hover:bg-blue-500/10 transition-all duration-300 backdrop-blur-sm bg-white/50 dark:bg-slate-900/50">
            <i class="fas fa-download group-hover/cta2:translate-y-1 transition-transform"></i>
            <span>Resume</span>
          </a>
        </div>
      </div>

      <!-- Right: Terminal-style visual -->
      <div class="animate-fade-in-up" style="animation-delay: 0.2s;">
        <div class="relative bg-slate-900 dark:bg-slate-950 rounded-2xl shadow-2xl border-t-2 border-l-2 border-blue-500/60 overflow-hidden hover:shadow-[0_0_40px_10px_rgba(59,130,246,0.35)] transition-all duration-500">
          <!-- Title bar -->
