            <span class="w-3 h-3 rounded-full bg-red-500"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
            <span class="w-3 h-3 rounded-full bg-green-500"></span>
            <span class="ml-3 text-xs text-slate-400 font-mono">about-me.js</span>
          </div>
          <!-- Code content -->
          <div class="p-6 font-mono text-sm leading-relaxed">
            <p><span class="text-purple-400">const</span> <span class="text-blue-300">developer</span> <span class="text-slate-400">=</span> <span class="text-slate-300">{</span></p>
            <p class="pl-4"><span class="text-cyan-300">name</span><span class="text-slate-400">:</span> <span class="text-green-400">'Your Name'</span><span class="text-slate-400">,</span></p>
            <p class="pl-4"><span class="text-cyan-300">degree</span><span class="text-slate-400">:</span> <span class="text-green-400">'BS Information Technology'</span><span class="text-slate-400">,</span></p>
            <p class="pl-4"><span class="text-cyan-300">school</span><span class="text-slate-400">:</span> <span class="text-green-400">'St. Vincent\'s College Inc.'</span><span class="text-slate-400">,</span></p>
            <p class="pl-4"><span class="text-cyan-300">graduated</span><span class="text-slate-400">:</span> <span class="text-orange-400">2025</span><span class="text-slate-400">,</span></p>
            <p class="pl-4"><span class="text-cyan-300">stack</span><span class="text-slate-400">:</span> <span class="text-slate-300">[</span><span class="text-green-400">'JS'</span><span class="text-slate-400">,</span> <span class="text-green-400">'Node'</span><span class="text-slate-400">,</span> <span class="text-green-400">'React'</span><span class="text-slate-300">]</span><span class="text-slate-400">,</span></p>
            <p class="pl-4"><span class="text-cyan-300">passion</span><span class="text-slate-400">:</span> <span class="text-green-400">'Building things that matter'</span><span class="text-slate-400">,</span></p>
            <p class="pl-4"><span class="text-cyan-300">available</span><span class="text-slate-400">:</span> <span class="text-orange-400">true</span></p>
            <p><span class="text-slate-300">};</span></p>
            <p class="mt-3"><span class="text-slate-500">// always learning, always building</span></p>
            <p class="inline-block w-2 h-4 bg-blue-400 animate-blink ml-1 align-middle"></p>
          </div>
        </div>

        <!-- Floating badge -->
        <div class="absolute -bottom-6 -right-6 hidden sm:flex items-center gap-3 bg-white dark:bg-slate-800 rounded-xl px-5 py-4 shadow-xl border-t-2 border-l-2 border-indigo-500 dark:border-indigo-400 animate-float-tech" style="animation-delay:0.5s">
