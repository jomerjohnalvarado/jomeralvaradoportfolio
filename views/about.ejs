          <stop offset="50%"  style="stop-color:#1e40af;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#1e40af;stop-opacity:0"/>
        </linearGradient>
        <linearGradient id="lg2" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%"   style="stop-color:#3b82f6;stop-opacity:0"/>
          <stop offset="50%"  style="stop-color:#3b82f6;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#3b82f6;stop-opacity:0"/>
        </linearGradient>
        <linearGradient id="lg3" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%"   style="stop-color:#6366f1;stop-opacity:0"/>
          <stop offset="50%"  style="stop-color:#6366f1;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#6366f1;stop-opacity:0"/>
        </linearGradient>
        <linearGradient id="lg4" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%"   style="stop-color:#06b6d4;stop-opacity:0"/>
          <stop offset="50%"  style="stop-color:#06b6d4;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:0"/>
        </linearGradient>
        <linearGradient id="lg5" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%"   style="stop-color:#8b5cf6;stop-opacity:0"/>
          <stop offset="50%"  style="stop-color:#8b5cf6;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#8b5cf6;stop-opacity:0"/>
        </linearGradient>
        <pattern id="grid" width="100" height="100" patternUnits="userSpaceOnUse">
          <path d="M 100 0 L 0 0 0 100" fill="none" stroke="rgba(30,64,175,0.3)" stroke-width="1"/>
        </pattern>
        <pattern id="grid-dot" width="60" height="60" patternUnits="userSpaceOnUse">
          <circle cx="30" cy="30" r="1.5" fill="rgba(59,130,246,0.25)" />
        </pattern>
      </defs>
      <line x1="0" y1="6%"  x2="100%" y2="6%"  stroke="url(#lg1)" stroke-width="2" class="animate-scan-line" style="animation-delay:0s"/>
      <line x1="0" y1="18%" x2="100%" y2="18%" stroke="url(#lg2)" stroke-width="2" class="animate-scan-line" style="animation-delay:0.6s"/>
      <line x1="0" y1="30%" x2="100%" y2="30%" stroke="url(#lg4)" stroke-width="2" class="animate-scan-line" style="animation-delay:1.2s"/>
      <line x1="0" y1="42%" x2="100%" y2="42%" stroke="url(#lg3)" stroke-width="2" class="animate-scan-line" style="animation-delay:1.8s"/>
      <line x1="0" y1="54%" x2="100%" y2="54%" stroke="url(#lg5)" stroke-width="2" class="animate-scan-line" style="animation-delay:2.4s"/>
      <line x1="0" y1="66%" x2="100%" y2="66%" stroke="url(#lg1)" stroke-width="2" class="animate-scan-line" style="animation-delay:3s"/>
      <line x1="0" y1="78%" x2="100%" y2="78%" stroke="url(#lg2)" stroke-width="2" class="animate-scan-line" style="animation-delay:0.9s"/>
      <line x1="0" y1="90%" x2="100%" y2="90%" stroke="url(#lg4)" stroke-width="2" class="animate-scan-line" style="animation-delay:2.1s"/>
    </svg>

    <!-- Grid overlays -->
    <svg class="absolute inset-0 w-full h-full opacity-10 dark:opacity-40" preserveAspectRatio="none">
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
    <svg class="absolute inset-0 w-full h-full opacity-5 dark:opacity-20" preserveAspectRatio="none">
      <rect width="100%" height="100%" fill="url(#grid-dot)" />
    </svg>

    <!-- ═══ FLOATING TECH ICONS — REDUCED TO 6 ═══ -->
    <!-- Icon 1: Code -->
    <div class="absolute top-20 left-20 w-24 h-24 opacity-30 dark:opacity-20 animate-float-tech" style="animation-delay: 0s;">
      <div class="w-full h-full border-2 border-blue-600/60 dark:border-blue-500/50 rounded-lg rotate-45 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-code text-blue-700 dark:text-blue-400 text-3xl -rotate-45"></i>
      </div>
    </div>

    <!-- Icon 2: Server -->
    <div class="absolute top-40 right-32 w-20 h-20 opacity-30 dark:opacity-20 animate-float-tech" style="animation-delay: 2s;">
      <div class="w-full h-full border-2 border-indigo-600/60 dark:border-indigo-500/50 rounded-full flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-server text-indigo-700 dark:text-indigo-400 text-2xl"></i>
      </div>
    </div>

    <!-- Icon 3: Database -->
    <div class="absolute bottom-40 left-1/4 w-28 h-28 opacity-30 dark:opacity-20 animate-float-tech" style="animation-delay: 4s;">
      <div class="w-full h-full border-2 border-blue-600/60 dark:border-blue-500/50 rounded-lg flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-database text-blue-700 dark:text-blue-400 text-3xl"></i>
      </div>
    </div>

    <!-- Icon 4: JavaScript -->
    <div class="absolute top-32 left-1/3 w-16 h-16 opacity-25 dark:opacity-15 animate-float-tech" style="animation-delay: 0.6s;">
      <div class="w-full h-full border-2 border-cyan-600/60 dark:border-cyan-500/50 rounded-xl rotate-12 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fab fa-js text-cyan-700 dark:text-cyan-400 text-xl -rotate-12"></i>
      </div>
    </div>

    <!-- Icon 5: Python -->
    <div class="absolute top-1/3 left-10 w-14 h-14 opacity-25 dark:opacity-15 animate-float-tech" style="animation-delay: 2.6s;">
      <div class="w-full h-full border-2 border-violet-600/60 dark:border-violet-500/50 rounded-xl -rotate-6 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fab fa-python text-violet-700 dark:text-violet-400 text-lg rotate-6"></i>
      </div>
    </div>

    <!-- Icon 6: React -->
    <div class="absolute bottom-32 right-1/4 w-16 h-16 opacity-25 dark:opacity-15 animate-float-tech" style="animation-delay: 0.3s;">
      <div class="w-full h-full border-2 border-pink-600/60 dark:border-pink-500/50 rounded-xl -rotate-12 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fab fa-react text-pink-700 dark:text-pink-400 text-xl rotate-12"></i>
      </div>
    </div>

    <!-- ═══ FLOATING CODE BRACKETS ═══ -->
    <div class="absolute top-28 left-2/3 text-4xl font-mono font-bold text-blue-600/20 dark:text-blue-400/15 animate-float-bracket" style="animation-delay:0.3s;">
      { }
    </div>
    <div class="absolute bottom-32 left-1/5 text-3xl font-mono font-bold text-indigo-600/20 dark:text-indigo-400/15 animate-float-bracket" style="animation-delay:1.8s;">
      &lt; / &gt;
    </div>
    <div class="absolute top-1/3 right-1/5 text-4xl font-mono font-bold text-cyan-600/15 dark:text-cyan-400/12 animate-float-bracket" style="animation-delay:2.6s;">
      [ ]
    </div>

    <!-- ═══ TERMINAL CURSOR LINES ═══ -->
    <div class="absolute top-1/2 left-8 text-sm font-mono text-blue-600/20 dark:text-blue-400/15 animate-terminal-cursor hidden sm:block" style="animation-delay:0s;">
      <span class="opacity-80">$</span>
      <span class="text-cyan-600/25 dark:text-cyan-400/20"> npm install --save</span>
      <span class="inline-block w-2 h-4 bg-blue-600/30 dark:bg-blue-400/25 ml-1 animate-blink-cursor"></span>
    </div>
    <div class="absolute bottom-1/4 right-8 text-sm font-mono text-indigo-600/20 dark:text-indigo-400/15 animate-terminal-cursor" style="animation-delay:3s;">
      <span class="opacity-80">$</span>
      <span class="text-violet-600/25 dark:text-violet-400/20"> git push origin main</span>
      <span class="inline-block w-2 h-4 bg-indigo-600/30 dark:bg-indigo-400/25 ml-1 animate-blink-cursor"></span>
    </div>

    <!-- ═══ PARTICLES — REDUCED ═══ -->
    <div class="absolute inset-0 opacity-40 dark:opacity-100">
      <!-- Blue -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 15%; left: 10%; animation-delay: 0s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 35%; left: 70%; animation-delay: 1.5s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 60%; left: 20%; animation-delay: 3s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 75%; right: 15%; animation-delay: 4.5s;"></div>
      
      <!-- Indigo -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top: 25%; right: 30%; animation-delay: 0.8s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top: 50%; left: 45%; animation-delay: 2.3s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top: 80%; left: 30%; animation-delay: 3.8s;"></div>
      
      <!-- Sky -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-sky-500 dark:bg-sky-400 rounded-full animate-tech-float shadow-glow-sky" style="top: 40%; right: 10%; animation-delay: 1.2s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-sky-500 dark:bg-sky-400 rounded-full animate-tech-float shadow-glow-sky" style="top: 70%; right: 50%; animation-delay: 2.8s;"></div>
      
      <!-- Violet -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-violet-500 dark:bg-violet-400 rounded-full animate-tech-float shadow-glow-violet" style="top: 30%; left: 55%; animation-delay: 0.5s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-violet-500 dark:bg-violet-400 rounded-full animate-tech-float shadow-glow-violet" style="top: 90%; right: 30%; animation-delay: 2s;"></div>
    </div>

    <!-- ═══ ANIMATED ORBITS ═══ -->
    <div class="absolute top-1/4 left-1/3 w-64 h-64 opacity-20 dark:opacity-30">
      <svg class="w-full h-full animate-rotate-slow" viewBox="0 0 100 100" preserveAspectRatio="none">
