<%- include('./layouts/header.ejs') %>

<div class="pt-32 pb-20 min-h-screen relative overflow-hidden text-gray-900 dark:text-slate-100">

  <!-- ═══════════════════════════════════════════════════════════
       ANIMATED TECHNOLOGY BACKGROUND — REDUCED ICONS
  ═══════════════════════════════════════════════════════════ -->
  <div class="fixed inset-0 -z-10 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-white via-blue-50 to-indigo-50 dark:from-slate-950 dark:via-blue-950/70 dark:to-indigo-950/40"></div>

