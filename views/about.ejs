    50% { background-position: 100% 50%; }
  }
  .animate-gradient-x { animation: gradient-x 4s ease infinite; }

  @keyframes blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }
  .animate-blink { animation: blink 1s step-start infinite; }

  @keyframes float-bracket {
    0%,100% { transform: translateY(0) scale(1) rotate(0deg); opacity:0.2; }
    25%     { transform: translateY(-15px) scale(1.05) rotate(2deg); opacity:0.35; }
    50%     { transform: translateY(-30px) scale(0.95) rotate(-2deg); opacity:0.5; }
    75%     { transform: translateY(-15px) scale(1.05) rotate(1deg); opacity:0.35; }
  }
  .animate-float-bracket { animation: float-bracket 7s ease-in-out infinite; will-change: transform,opacity; }

  @keyframes terminal-cursor {
    0%,100% { opacity:0.2; transform:translateX(0); }
    50%     { opacity:0.6; transform:translateX(8px); }
  }
  .animate-terminal-cursor { animation: terminal-cursor 8s ease-in-out infinite; will-change: transform,opacity; }

  @keyframes blink-cursor {
    0%,100% { opacity:1; }
    50%     { opacity:0; }
  }
  .animate-blink-cursor { animation: blink-cursor 1s step-end infinite; will-change: opacity; }

  /* ===== PERFORMANCE ===== */
  .animate-scan-line,
  .animate-float-tech,
  .animate-float-bracket,
  .animate-tech-float,
  .animate-rotate-slow,
  .animate-pulse-glow,
  .animate-fade-in-up,
  .animate-terminal-cursor {
    contain: layout style paint;
  }

  @media (max-width: 768px) {
    .animate-float-tech,
    .animate-rotate-slow { animation-duration: 12s; }
    .animate-tech-float { animation-duration: 30s; }
    .animate-float-bracket { animation-duration: 10s; }
  }

  /* ============================================================
     MOBILE OPTIMIZATION: DISABLE HEAVY GPU EFFECTS
     ============================================================ */
  @media (max-width: 768px) {
    /* 1. DISABLE BACKDROP BLUR (HEAVIEST) */
    .backdrop-blur-sm,
    .backdrop-blur-md,
    .backdrop-blur-lg,
    .backdrop-blur-xl,
    .backdrop-blur-2xl,
    .bg-white\/80,
    .dark\:bg-slate-800\/80,
    .bg-white\/90,
    .dark\:bg-slate-900\/90,
    .bg-black\/60,
    .bg-white\/10,
    .dark\:bg-black\/10,
    .bg-white\/50,
    .dark\:bg-slate-900\/50,
    [class*="backdrop-blur"] {
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
    }

    /* 2. HIDE PARTICLES */
    .tech-particle {
      display: none !important;
    }

    /* 3. HIDE ORBITING RINGS */
    .animate-rotate-slow,
    .animate-orbit-1,
    .animate-orbit-2,
    .animate-orbit-3 {
      display: none !important;
    }

    /* 4. HIDE GLOWING ORBS */
    .animate-pulse-glow {
      display: none !important;
    }

    /* 5. REDUCE FLOATING TECH ICONS - keep only first 3 */
    .fixed.inset-0 .animate-float-tech:nth-child(n+4) {
      display: none !important;
    }

    /* 6. REDUCE SCAN LINES - keep only 3 */
    .animate-scan-line:nth-child(n+4) {
      display: none !important;
    }

    /* 7. HIDE FLOATING CODE BRACKETS */
    .animate-float-bracket {
      display: none !important;
    }

    /* 8. HIDE TERMINAL CURSOR LINES */
    .animate-terminal-cursor {
      display: none !important;
    }

    /* 9. HIDE STATUS LIGHTS */
    .animate-status-pulse {
      display: none !important;
    }
  }

  @media (max-width: 480px) {
    /* Further reduce for small phones */
    .fixed.inset-0 .animate-float-tech:nth-child(n+2) {
      display: none !important;
    }
    .animate-scan-line:nth-child(n+2) {
      display: none !important;
    }
  }
</style>

<script>
  // ===================== BACK TO TOP FUNCTIONALITY =====================
  function scrollToTop() {
    window.scrollTo({
      top: 0,
      behavior: 'smooth'
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    const backToTopBtn = document.getElementById('backToTop');
    
    window.addEventListener('scroll', function() {
      if (window.scrollY > 300) {
        backToTopBtn.classList.remove('opacity-0', 'invisible', 'translate-y-4');
        backToTopBtn.classList.add('opacity-100', 'visible', 'translate-y-0');
      } else {
        backToTopBtn.classList.remove('opacity-100', 'visible', 'translate-y-0');
        backToTopBtn.classList.add('opacity-0', 'invisible', 'translate-y-4');
      }
    });
  });
</script>

