          { title: 'Problem Solver',    desc: 'I dig into the "why" before jumping to the "how".',          icon: 'puzzle-piece', color: 'indigo' },
          { title: 'Detail Oriented',   desc: 'The small things make the biggest difference in UX.',       icon: 'search',      color: 'sky'    },
          { title: 'Lifelong Learner',  desc: 'Technology evolves fast — so do I.',                         icon: 'seedling',    color: 'blue'   },
