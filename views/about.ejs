  <!-- ═══════════════════════════════════════════════════════════
       JOURNEY TIMELINE — EDUCATION + INTERNSHIP
  ═══════════════════════════════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 mb-28 relative z-10">

    <div class="text-center mb-16 animate-fade-in-up">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-100 dark:bg-blue-900/40 border-t-2 border-l-2 border-blue-600 dark:border-blue-500/60 mb-6 backdrop-blur-sm shadow-lg">
        <i class="fas fa-route text-blue-700 dark:text-blue-400"></i>
        <span class="text-sm font-bold text-blue-800 dark:text-blue-300">My Journey</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-black mb-4">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-700 to-indigo-700 dark:from-blue-400 dark:to-indigo-400">
          Education & Experience
        </span>
      </h2>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        From the classroom to real-world application — here's how my path unfolded.
      </p>
    </div>

    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-6 md:left-1/2 md:-translate-x-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-blue-500 via-indigo-500 to-sky-500 dark:from-blue-400 dark:via-indigo-400 dark:to-sky-400 opacity-40"></div>

      <!-- Item 1: Education -->
      <div class="relative mb-12 animate-fade-in-up">
