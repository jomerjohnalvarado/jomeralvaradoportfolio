      <% projects.forEach((project, index) => { %>
      <div class="project-item group <%= project.featured ? 'md:col-span-2 lg:col-span-1' : '' %>"
      data-category="<%= project.category %>"
      style="animation-delay: <%= index * 0.1 %>s;">

      <div class="relative h-full">
        <div class="absolute -inset-1 bg-gradient-to-r from-blue-700 via-blue-600 to-blue-700 rounded-2xl opacity-0 group-hover:opacity-100 blur-sm transition-all duration-500"></div>
        <div class="relative h-full bg-white dark:bg-slate-900 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 border-2 border-slate-200 dark:border-slate-800 group-hover:border-blue-700 dark:group-hover:border-blue-700 group-hover:scale-105">

          <!-- Project Image -->
          <div class="relative h-64 bg-gradient-to-br <%= project.bgGradient %> overflow-hidden">
            <img
            src="<%= project.images[0] %>"
            alt="<%= project.title %>"
            class="w-full h-full object-contain"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            >
            <div class="absolute inset-0 hidden items-center justify-center">
              <div class="w-24 h-24 rounded-2xl bg-white/90 dark:bg-slate-800/90 flex items-center justify-center shadow-xl">
                <i class="fas fa-<%= project.icon %> text-5xl bg-gradient-to-r <%= project.gradient %> bg-clip-text text-transparent"></i>
              </div>
            </div>

            <!-- Photo Count -->
            <div class="absolute top-4 left-4 z-10">
              <span class="block px-3 py-1 rounded-full text-xs font-bold bg-black/60 backdrop-blur-sm text-white border border-white/30 shadow-lg">
                <i class="fas fa-images mr-1"></i><%= project.images.length %> Photos
              </span>
            </div>

            <!-- Category -->
            <div class="absolute top-4 right-4 z-10">
              <span class="block px-3 py-1 rounded-full text-xs font-bold bg-white/90 dark:bg-slate-800/90 backdrop-blur-sm text-slate-700 dark:text-slate-200 border-2 border-white/50 shadow-lg">
                <%= project.category.toUpperCase() %>
              </span>
            </div>

            <% if (project.featured) { %>
            <div class="absolute top-12 left-4 z-10 mt-1">
              <span class="block px-3 py-1 rounded-full text-xs font-bold bg-gradient-to-r from-blue-700 to-blue-600 text-white shadow-lg">
                <i class="fas fa-star mr-1"></i>Featured
              </span>
            </div>
            <% } %>

            <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-4 group-hover:translate-y-0 z-20">
              <button onclick='openProjectModal(<%= JSON.stringify(project) %>)'
              class="px-6 py-3 bg-white text-blue-700 rounded-xl font-bold hover:bg-blue-50 transition-all duration-300 shadow-xl">
              <i class="fas fa-images mr-2"></i>View Gallery
            </button>
          </div>
        </div>

        <!-- Card Content -->
        <div class="p-6">
          <h3 class="text-2xl font-bold mb-3 text-slate-900 dark:text-white group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors duration-300">
            <%= project.title %>
          </h3>
          <p class="text-slate-600 dark:text-slate-300 mb-4 line-clamp-2">
            <%= project.description %>
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <% project.technologies.forEach(tech => { %>
            <span class="px-3 py-1 rounded-lg text-xs font-semibold bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border-2 border-slate-200 dark:border-slate-700">
              <%= tech %>
            </span>
            <% }); %>
          </div>

          <!-- Link Badges (Website + GitHub) - Removed "Repo" text -->
          <div class="flex flex-wrap gap-2 mb-4">
            <% if (project.websiteUrl) { %>
            <a href="<%= project.websiteUrl %>" target="_blank"
            class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-xs font-semibold bg-blue-50 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 border border-blue-200 dark:border-blue-800 hover:bg-blue-100 dark:hover:bg-blue-800/50 transition-all duration-300">
            <i class="fas fa-globe text-[10px]"></i> Live
          </a>
          <% } %>
          <% if (project.githubUrl) { %>
          <a href="<%= project.githubUrl %>" target="_blank"
          class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-xs font-semibold bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all duration-300">
          <i class="fab fa-github text-[10px]"></i>
        </a>
        <% } %>
      </div>

      <div class="flex gap-3 pt-4 border-t border-slate-200 dark:border-slate-800">
        <button onclick='openProjectModal(<%= JSON.stringify(project) %>)'
        class="flex-1 text-center px-4 py-2 bg-gradient-to-r from-blue-700 to-blue-600 text-white rounded-lg font-semibold text-sm hover:from-blue-800 hover:to-blue-700 transition-all duration-300 shadow-md">
        <i class="fas fa-eye mr-2"></i>View Details
      </button>
      <button onclick="shareProject('<%= project.title %>', '<%= project.id %>')"
      class="px-4 py-2 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg font-semibold text-sm hover:bg-slate-200 dark:hover:bg-slate-700 transition-all duration-300 border-2 border-slate-200 dark:border-slate-700">
      <i class="fas fa-share-alt"></i>
    </button>
  </div>
</div>
</div>
</div>
</div>
<% }); %>
</div>
</section>

<!-- CTA Section -->
