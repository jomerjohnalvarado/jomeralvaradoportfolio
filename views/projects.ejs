</style>

<!-- ===================== SCRIPTS ===================== -->
<script>
  let currentProject = null;
  let currentImageIndex = 0;

  // ===================== BACK TO TOP FUNCTIONALITY =====================
  function scrollToTop() {
    window.scrollTo({
      top: 0,
      behavior: 'smooth'
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    // Back to top button visibility
    const backToTopBtn = document.getElementById('backToTop');
    
    window.addEventListener('scroll', function() {
      if (window.scrollY > 300) {
        backToTopBtn.classList.remove('opacity-0', 'invisible', 'translate-y-4');
        backToTopBtn.classList.add('opacity-100', 'visible', 'translate-y-0');
      } else {
        backToTopBtn.classList.remove('opacity-100', 'visible', 'translate-y-0');
        backToTopBtn.classList.add('opacity-0', 'invisible', 'translate-y-4');
      }
    });

    // Filter Tabs
    const filterTabs = document.querySelectorAll('.filter-tab');
    const projectItems = document.querySelectorAll('.project-item');

    filterTabs.forEach(tab => {
      tab.addEventListener('click', function() {
        const filter = this.dataset.filter;
        filterTabs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        projectItems.forEach((item, index) => {
          if (filter === 'all' || item.dataset.category === filter) {
            setTimeout(() => {
              item.style.display = 'block';
              item.style.animation = 'fadeInScale 0.5s ease-out forwards';
            }, index * 50);
          } else {
            item.style.display = 'none';
          }
        });
      });
    });
  });

  // Open Modal
  function openProjectModal(project) {
    currentProject = project;
    currentImageIndex = 0;

    const modal = document.getElementById('projectModal');
    const modalContent = modal.querySelector('.modal-content');

    // Text
    document.getElementById('modalTitle').textContent = project.title;
    document.getElementById('modalDescription').textContent = project.description || '';
    document.getElementById('modalFullDescription').textContent = project.fullDescription || project
    .description || '';
    document.getElementById('modalCategory').textContent = project.category.toUpperCase();

    // Featured
    const featuredBadge = document.getElementById('modalFeatured');
    if (project.featured) {
      featuredBadge.classList.remove('hidden');
    } else {
      featuredBadge.classList.add('hidden');
    }

    // --- Website Link ---
    const websiteLink = document.getElementById('modalWebsiteLink');
    if (project.websiteUrl) {
      websiteLink.href = project.websiteUrl;
      websiteLink.style.display = 'flex';
    } else {
      websiteLink.style.display = 'none';
    }

    // --- GitHub Link ---
    const githubLink = document.getElementById('modalGithubLink');
    if (project.githubUrl) {
      githubLink.href = project.githubUrl;
      githubLink.style.display = 'flex';
    } else {
      githubLink.style.display = 'none';
    }

    // Share button
    document.getElementById('modalShareBtn').onclick = () => shareProject(project.title, project.id);

    // Technologies
    document.getElementById('modalTechnologies').innerHTML = (project.technologies || []).map(tech =>
      `<span class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 border-2 border-blue-200 dark:border-blue-800">${tech}</span>`
    ).join('');

    // Features
    document.getElementById('modalFeatures').innerHTML = (project.features || []).map(feature =>
      `<div class="flex items-center gap-2 p-2.5 rounded-xl bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700">
        <div class="w-5 h-5 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center flex-shrink-0">
          <i class="fas fa-check text-green-600 text-xs"></i>
        </div>
        <span class="text-slate-700 dark:text-slate-300 font-medium text-xs">${feature}</span>
      </div>`
    ).join('');

    // Slider
    buildSlider(project.images || []);

    // Show modal
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    setTimeout(() => {
      modalContent.classList.remove('scale-95', 'opacity-0');
      modalContent.classList.add('scale-100', 'opacity-100');
    }, 10);

    document.body.style.overflow = 'hidden';
  }

  // Build Slider
  function buildSlider(images) {
    const slider = document.getElementById('imageSlider');
    const thumbContainer = document.getElementById('thumbnailContainer');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const counter = document.getElementById('imageCounter');
    const thumbRow = document.getElementById('thumbnailRow');

    document.getElementById('totalImages').textContent = images.length || 0;
    slider.innerHTML = '';
    thumbContainer.innerHTML = '';

    const hasMultiple = images.length > 1;
    prevBtn.classList.toggle('hidden', !hasMultiple);
    prevBtn.classList.toggle('flex', hasMultiple);
    nextBtn.classList.toggle('hidden', !hasMultiple);
    nextBtn.classList.toggle('flex', hasMultiple);
    counter.classList.toggle('hidden', !hasMultiple);
    thumbRow.classList.toggle('hidden', !hasMultiple);

    if (images.length === 0) {
      // No images: show placeholder
      const slide = document.createElement('div');
      slide.className = 'slider-slide w-full relative';
      slide.style.display = 'block';
      slide.innerHTML = `
        <div class="flex items-center justify-center h-64 bg-slate-200 dark:bg-slate-700 rounded-xl">
          <i class="fas fa-image text-6xl text-slate-400 dark:text-slate-500"></i>
        </div>
      `;
      slider.appendChild(slide);
      return;
    }

    // Build slides
    images.forEach((src, i) => {
      const slide = document.createElement('div');
      slide.className = 'slider-slide w-full';
      slide.style.display = i === 0 ? 'block' : 'none';
      slide.style.position = i === 0 ? 'relative' : 'absolute';
      if (i !== 0) {
        slide.style.top = '0';
        slide.style.left = '0';
        slide.style.width = '100%';
      }
      slide.innerHTML = `
        <img
          src="${src}"
          alt="Slide ${i + 1}"
          class="w-full h-auto block"
          style="max-height: 500px; object-fit: contain;"
          onerror="this.parentElement.innerHTML = '<div class=\\'flex items-center justify-center h-64 bg-slate-200 dark:bg-slate-700 rounded-xl\\'><i class=\\'fas fa-image text-6xl text-slate-400 dark:text-slate-500\\'></i></div>'"
        />
      `;
      slider.appendChild(slide);
    });

    // Build thumbnails
    images.forEach((src, i) => {
      const btn = document.createElement('button');
      btn.className =
        `thumb-btn flex-shrink-0 w-14 h-14 rounded-lg overflow-hidden border-2 transition-all duration-300 ${
        i === 0
          ? 'border-blue-600 ring-2 ring-blue-400 ring-offset-1 opacity-100'
          : 'border-slate-300 dark:border-slate-600 opacity-50 hover:opacity-80'
      }`;
      btn.innerHTML =
        `<img src="${src}" alt="thumb ${i + 1}" class="w-full h-full object-cover" onerror="this.style.display='none'" />`;
      btn.onclick = () => goToImage(i);
      thumbContainer.appendChild(btn);
    });

    updateCounter();
  }

  // Go to image
  function goToImage(index) {
    const slides = document.querySelectorAll('.slider-slide');
    const thumbs = document.querySelectorAll('.thumb-btn');
    const slider = document.getElementById('imageSlider');

    if (!slides.length || index < 0 || index >= slides.length) return;

    const currentSlide = slides[currentImageIndex];
    if (currentSlide) {
      slider.style.height = currentSlide.offsetHeight + 'px';
      slider.style.position = 'relative';
      currentSlide.style.display = 'none';
      currentSlide.style.position = 'absolute';
    }

    if (thumbs[currentImageIndex]) {
      thumbs[currentImageIndex].classList.remove('border-blue-600', 'ring-2', 'ring-blue-400', 'ring-offset-1',
      'opacity-100');
      thumbs[currentImageIndex].classList.add('border-slate-300', 'opacity-50');
    }

    currentImageIndex = index;

    const newSlide = slides[currentImageIndex];
    if (newSlide) {
      newSlide.style.position = 'absolute';
      newSlide.style.top = '0';
      newSlide.style.left = '0';
      newSlide.style.width = '100%';
      newSlide.style.display = 'block';
    }

    if (thumbs[currentImageIndex]) {
      thumbs[currentImageIndex].classList.add('border-blue-600', 'ring-2', 'ring-blue-400', 'ring-offset-1',
      'opacity-100');
      thumbs[currentImageIndex].classList.remove('border-slate-300', 'opacity-50');
    }

    if (newSlide) {
      const newImg = newSlide.querySelector('img');
      const releaseHeight = () => {
        slider.style.height = '';
        slider.style.position = '';
        newSlide.style.position = 'relative';
        newSlide.style.top = '';
        newSlide.style.left = '';
        newSlide.style.width = '';
      };
      if (newImg && newImg.complete) {
        releaseHeight();
      } else if (newImg) {
        newImg.onload = releaseHeight;
        newImg.onerror = releaseHeight;
        setTimeout(releaseHeight, 800);
      } else {
        releaseHeight();
      }
    }

    updateCounter();
    if (thumbs[currentImageIndex]) {
      thumbs[currentImageIndex].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }
  }

  function previousImage() {
    if (!currentProject || !currentProject.images || currentProject.images.length === 0) return;
    goToImage(currentImageIndex === 0 ? currentProject.images.length - 1 : currentImageIndex - 1);
  }

  function nextImage() {
    if (!currentProject || !currentProject.images || currentProject.images.length === 0) return;
    goToImage(currentImageIndex === currentProject.images.length - 1 ? 0 : currentImageIndex + 1);
  }

  function updateCounter() {
    const total = document.getElementById('totalImages').textContent;
    if (parseInt(total) > 0) {
      document.getElementById('currentImageIndex').textContent = currentImageIndex + 1;
    } else {
      document.getElementById('currentImageIndex').textContent = '0';
    }
  }

  // Close Modal
  function closeProjectModal() {
    const modal = document.getElementById('projectModal');
    const modalContent = modal.querySelector('.modal-content');

    modalContent.classList.remove('scale-100', 'opacity-100');
    modalContent.classList.add('scale-95', 'opacity-0');

    setTimeout(() => {
      modal.classList.remove('flex');
      modal.classList.add('hidden');
      document.body.style.overflow = 'auto';
      currentProject = null;
      currentImageIndex = 0;
    }, 300);
  }

  document.getElementById('projectModal').addEventListener('click', function(e) {
    if (e.target === this) closeProjectModal();
  });

  document.addEventListener('keydown', function(e) {
    if (document.getElementById('projectModal').classList.contains('hidden')) return;
    if (e.key === 'ArrowLeft') previousImage();
    else if (e.key === 'ArrowRight') nextImage();
    else if (e.key === 'Escape') closeProjectModal();
  });

  // Share
  function shareProject(title, projectId) {
    const url = `${window.location.origin}/projects/${projectId}`;
    if (navigator.share) {
      navigator.share({ title, text: `Check out: ${title}`, url }).catch(console.error);
    } else {
      navigator.clipboard.writeText(url)
        .then(() => showToast('Link copied!'))
        .catch(() => showToast('Failed to copy', 'error'));
    }
  }

  // Toast
  function showToast(message, type = 'success') {
    const toast = document.createElement('div');
    toast.className =
      `fixed bottom-8 right-8 z-[9999] px-5 py-3 rounded-xl text-white font-semibold shadow-2xl transition-all duration-300 ${
      type === 'success' ? 'bg-green-600' : 'bg-red-600'
    }`;
    toast.style.transform = 'translateY(80px)';
    toast.style.opacity = '0';
    toast.innerHTML =
      `<i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'} mr-2"></i>${message}`;
    document.body.appendChild(toast);
    setTimeout(() => { toast.style.transform = 'translateY(0)';
      toast.style.opacity = '1'; }, 10);
    setTimeout(() => {
      toast.style.transform = 'translateY(80px)';
      toast.style.opacity = '0';
      setTimeout(() => toast.remove(), 300);
    }, 3000);
  }
</script>

