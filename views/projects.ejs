    <div id="mainImageWrapper" class="relative rounded-2xl overflow-hidden border-2 border-slate-200 dark:border-slate-700 bg-slate-100 dark:bg-slate-800">
      <div id="imageSlider" class="relative w-full">
        <!-- Slides injected by JS -->
      </div>

      <!-- Left Arrow -->
      <button onclick="previousImage()" id="prevBtn"
      class="hidden absolute left-3 top-1/2 -translate-y-1/2 z-20 w-10 h-10 items-center justify-center bg-white/95 dark:bg-slate-800/95 text-slate-700 dark:text-slate-200 rounded-full hover:bg-blue-600 hover:text-white transition-all duration-300 shadow-lg border border-slate-200 dark:border-slate-600 group">
      <i class="fas fa-chevron-left text-sm group-hover:-translate-x-0.5 transition-transform duration-300"></i>
    </button>

    <!-- Right Arrow -->
