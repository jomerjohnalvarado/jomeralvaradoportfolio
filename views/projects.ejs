    <div class="flex items-center gap-2 flex-wrap pr-10">
      <span id="modalCategory" class="px-3 py-1 rounded-full text-xs font-bold bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 border-2 border-blue-200 dark:border-blue-800"></span>
      <span id="modalFeatured" class="hidden px-3 py-1 rounded-full text-xs font-bold bg-gradient-to-r from-blue-700 to-blue-600 text-white">
        <i class="fas fa-star mr-1"></i>Featured
      </span>
    </div>
