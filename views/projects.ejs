    class="hidden absolute right-3 top-1/2 -translate-y-1/2 z-20 w-10 h-10 items-center justify-center bg-white/95 dark:bg-slate-800/95 text-slate-700 dark:text-slate-200 rounded-full hover:bg-blue-600 hover:text-white transition-all duration-300 shadow-lg border border-slate-200 dark:border-slate-600 group">
    <i class="fas fa-chevron-right text-sm group-hover:translate-x-0.5 transition-transform duration-300"></i>
  </button>

  <!-- Counter -->
