<style>
  /* Performance Optimization */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* ===== SMOOTH DARK/LIGHT MODE TRANSITIONS ===== */
  /* Apply to all elements that change with theme */
  * {
    transition: background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                border-color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                fill 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                stroke 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Optimize performance by limiting transition to specific elements */
  body, 
  .bg-white, .dark .bg-white,
  .bg-slate-50, .dark .bg-slate-50,
  .bg-slate-100, .dark .bg-slate-100,
  .bg-slate-200, .dark .bg-slate-200,
  .bg-slate-900, .dark .bg-slate-900,
  .bg-slate-950, .dark .bg-slate-950,
  .bg-blue-50, .dark .bg-blue-50,
  .bg-blue-100, .dark .bg-blue-100,
  .bg-indigo-50, .dark .bg-indigo-50,
  .bg-indigo-100, .dark .bg-indigo-100,
  .text-slate-900, .dark .text-slate-900,
  .text-slate-700, .dark .text-slate-700,
  .text-slate-600, .dark .text-slate-600,
  .text-slate-300, .dark .text-slate-300,
  .text-white, .dark .text-white,
  .border-slate-200, .dark .border-slate-200,
  .border-slate-300, .dark .border-slate-300,
  .border-blue-300, .dark .border-blue-300,
  .border-blue-600, .dark .border-blue-600,
  .shadow-lg, .dark .shadow-lg,
  .shadow-xl, .dark .shadow-xl,
  .backdrop-blur-sm, .dark .backdrop-blur-sm,
  .feature-card, .dark .feature-card,
  .stat-box, .dark .stat-box,
  .card-border, .dark .card-border,
  .modal-content, .dark .modal-content {
    transition: background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                border-color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Smooth gradient transitions */
  .bg-gradient-to-br,
  .bg-gradient-to-r,
  .bg-gradient-to-t,
  .from-slate-50, .dark .from-slate-50,
  .from-blue-50, .dark .from-blue-50,
  .from-indigo-50, .dark .from-indigo-50,
  .to-blue-50, .dark .to-blue-50,
  .to-indigo-50, .dark .to-indigo-50,
  .via-blue-50, .dark .via-blue-50,
  .via-indigo-50, .dark .via-indigo-50 {
    transition: background 0.6s cubic-bezier(0.4, 0, 0.2, 1),
                background-color 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Scan Line Animation - GPU Accelerated */
  @keyframes scan-line {
    0%, 100% {
      opacity: 0;
      transform: translateX(-100%) translateZ(0);
    }
    50% {
      opacity: 1;
    }
  }

  .animate-scan-line {
    animation: scan-line 4s ease-in-out infinite;
    will-change: transform, opacity;
  }

  /* Tech Float Animation - Optimized */
  @keyframes float-tech {
    0%, 100% {
      transform: translateY(0px) rotateZ(0deg) translateZ(0);
    }
    25% {
      transform: translateY(-20px) rotateZ(5deg) translateZ(0);
    }
    50% {
      transform: translateY(-40px) rotateZ(0deg) translateZ(0);
    }
    75% {
      transform: translateY(-20px) rotateZ(-5deg) translateZ(0);
    }
  }

  .animate-float-tech {
    animation: float-tech 8s ease-in-out infinite;
    will-change: transform;
  }

  /* Tech Particle Float - Optimized */
  @keyframes tech-float {
    0% {
      transform: translateY(100vh) translateX(0) translateZ(0);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      transform: translateY(-100vh) translateX(100px) translateZ(0);
      opacity: 0;
    }
  }

  .animate-tech-float {
    animation: tech-float 20s linear infinite;
    will-change: transform, opacity;
  }

  /* Particle Glow Effects */
  .shadow-glow-blue {
    box-shadow: 0 0 10px rgba(30, 64, 175, 0.8), 0 0 20px rgba(30, 64, 175, 0.4);
  }

  .shadow-glow-indigo {
    box-shadow: 0 0 10px rgba(79, 70, 229, 0.8), 0 0 20px rgba(79, 70, 229, 0.4);
  }

  .shadow-glow-sky {
    box-shadow: 0 0 10px rgba(2, 132, 199, 0.8), 0 0 20px rgba(2, 132, 199, 0.4);
  }

  /* Rotate Slow - GPU Accelerated */
  @keyframes rotate-slow {
    0% {
      transform: rotate(0deg) translateZ(0);
    }
    100% {
      transform: rotate(360deg) translateZ(0);
    }
  }

  .animate-rotate-slow {
    animation: rotate-slow 20s linear infinite;
    will-change: transform;
  }

  /* Orbit Animations - Optimized */
  @keyframes orbit-1 {
    0% {
      cx: 95;
      cy: 50;
    }
    33.33% {
      cx: 50;
      cy: 5;
    }
    66.66% {
      cx: 5;
      cy: 50;
    }
    100% {
      cx: 95;
      cy: 50;
    }
  }

  @keyframes orbit-2 {
    0% {
      cx: 50;
      cy: 5;
    }
    33.33% {
      cx: 5;
      cy: 50;
    }
    66.66% {
      cx: 95;
      cy: 50;
    }
    100% {
      cx: 50;
      cy: 5;
    }
  }

  @keyframes orbit-3 {
    0% {
      cx: 5;
      cy: 50;
    }
    33.33% {
      cx: 95;
      cy: 50;
    }
    66.66% {
      cx: 50;
      cy: 5;
    }
    100% {
      cx: 5;
      cy: 50;
    }
  }

  .animate-orbit-1 {
    animation: orbit-1 6s linear infinite;
  }

  .animate-orbit-2 {
    animation: orbit-2 6s linear infinite;
  }

  .animate-orbit-3 {
    animation: orbit-3 6s linear infinite;
  }

  /* Status Pulse - Optimized */
  @keyframes status-pulse {
    0%, 100% {
      opacity: 1;
      box-shadow: 0 0 10px currentColor;
    }
    50% {
      opacity: 0.5;
      box-shadow: 0 0 5px currentColor;
    }
  }

  .animate-status-pulse {
    animation: status-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  /* Status Ping - GPU Accelerated */
  @keyframes status-ping {
    75%, 100% {
      transform: scale(2) translateZ(0);
      opacity: 0;
    }
  }

  .animate-status-ping {
    animation: status-ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
    will-change: transform, opacity;
  }

  /* Pulse Glow - Optimized */
  @keyframes pulse-glow {
    0%, 100% {
      opacity: 0.5;
      filter: blur(30px);
    }
    50% {
      opacity: 1;
      filter: blur(15px);
    }
  }

  .animate-pulse-glow {
    animation: pulse-glow 4s ease-in-out infinite;
    will-change: opacity, filter;
  }

  /* Performance: Contain paint and layout */
  .animate-scan-line,
  .animate-float-tech,
  .animate-tech-float,
  .animate-rotate-slow,
  .animate-pulse-glow {
    contain: layout style paint;
  }

  /* Reduce animations on mobile */
  @media (max-width: 768px) {
    .animate-float-tech,
    .animate-rotate-slow {
      animation-duration: 12s;
    }
    
    .animate-tech-float {
      animation-duration: 30s;
    }
  }

  /* Additional styles */
  @keyframes blob {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(30px, -50px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
    }
  }
  .animate-blob {
    animation: blob 7s infinite;
  }
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  .animation-delay-4000 {
    animation-delay: 4s;
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes fadeInScale {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .animate-fade-in-down {
    animation: fadeInDown 0.6s ease-out both;
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out both;
  }
  .animation-delay-200 {
    animation-delay: 0.2s;
  }
  .animation-delay-400 {
    animation-delay: 0.4s;
  }
  .project-item {
    animation: fadeInScale 0.6s ease-out both;
  }

  .filter-tab {
    color: rgb(71 85 105);
  }
  .dark .filter-tab {
    color: rgb(148 163 184);
  }
  .filter-tab:hover {
    background-color: rgb(241 245 249);
    color: rgb(15 23 42);
  }
  .dark .filter-tab:hover {
    background-color: rgb(30 41 59);
    color: rgb(248 250 252);
  }
  .filter-tab.active {
    background: linear-gradient(to right, rgb(29 78 137), rgb(30 58 138));
    color: white;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .modal-content::-webkit-scrollbar {
    width: 5px;
  }
  .modal-content::-webkit-scrollbar-track {
    background: rgb(241 245 249);
    border-radius: 10px;
  }
  .dark .modal-content::-webkit-scrollbar-track {
    background: rgb(30 41 59);
  }
  .modal-content::-webkit-scrollbar-thumb {
    background: rgb(59 130 246);
    border-radius: 10px;
  }

  .dark .ring-offset-1 {
    --tw-ring-offset-color: #0f172a;
  }

  /* Disable transitions for reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    * {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
    }
  }

  /* ============================================================
     MOBILE OPTIMIZATION: DISABLE HEAVY GPU EFFECTS
     ============================================================ */
  @media (max-width: 768px) {
    /* 1. DISABLE BACKDROP BLUR (HEAVIEST) */
    .backdrop-blur-sm,
    .backdrop-blur-md,
    .backdrop-blur-lg,
    .backdrop-blur-xl,
    .backdrop-blur-2xl,
    .bg-white\/80,
    .dark\:bg-slate-800\/80,
    .bg-white\/90,
    .dark\:bg-slate-900\/90,
    .bg-black\/60,
    [class*="backdrop-blur"] {
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
    }

    /* 2. HIDE PARTICLES */
    .tech-particle {
      display: none !important;
    }

    /* 3. HIDE ORBITING RINGS */
    .animate-rotate-slow,
    .animate-orbit-1,
    .animate-orbit-2,
    .animate-orbit-3 {
      display: none !important;
    }

    /* 4. HIDE GLOWING ORBS */
    .animate-pulse-glow {
      display: none !important;
    }

    /* 5. REDUCE FLOATING TECH ICONS - keep only the first 3 */
    .fixed.inset-0 .animate-float-tech:nth-child(n+4) {
      display: none !important;
    }

    /* 6. REDUCE SCAN LINES - keep only 2 */
    .animate-scan-line:nth-child(n+3) {
      display: none !important;
    }

    /* 7. HIDE FLOATING CODE BRACKETS (lightweight but we hide to save) */
    .animate-float-bracket {
      display: none !important;
    }

    /* 8. HIDE TERMINAL CURSOR LINES (lightweight but optional) */
    .animate-terminal-cursor {
      display: none !important;
    }
  }

  @media (max-width: 480px) {
    /* Further reduce for small phones */
    .fixed.inset-0 .animate-float-tech:nth-child(n+2) {
