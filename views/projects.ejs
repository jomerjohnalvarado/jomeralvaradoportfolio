<%- include('./layouts/header.ejs') %>

<div class="pt-24 pb-20 min-h-screen relative overflow-hidden" id="app">
  <!-- Adaptive Animated Technology Background -->
  <div class="fixed inset-0 -z-10 overflow-hidden" id="bg-container">
    <!-- Gradient Background - Dark Blue Theme -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-blue-50/80 to-indigo-50/60 dark:from-slate-950 dark:via-blue-950/70 dark:to-indigo-950/40"></div>
    
    <!-- Animated Code Lines -->
    <svg class="absolute inset-0 w-full h-full opacity-10 dark:opacity-30" preserveAspectRatio="none">
      <defs>
        <linearGradient id="lineGradient1" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#1e40af;stop-opacity:0" />
          <stop offset="50%" style="stop-color:#1e40af;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#1e40af;stop-opacity:0" />
        </linearGradient>
        <linearGradient id="lineGradient2" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#0284c7;stop-opacity:0" />
          <stop offset="50%" style="stop-color:#0284c7;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#0284c7;stop-opacity:0" />
        </linearGradient>
        <linearGradient id="lineGradient3" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#4f46e5;stop-opacity:0" />
          <stop offset="50%" style="stop-color:#4f46e5;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#4f46e5;stop-opacity:0" />
        </linearGradient>
        <linearGradient id="lg4" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#06b6d4;stop-opacity:0"/>
          <stop offset="50%" style="stop-color:#06b6d4;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:0"/>
        </linearGradient>
        <linearGradient id="lg5" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#8b5cf6;stop-opacity:0"/>
          <stop offset="50%" style="stop-color:#8b5cf6;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#8b5cf6;stop-opacity:0"/>
        </linearGradient>
      </defs>
      
      <!-- Animated Horizontal Lines -->
      <line x1="0" y1="6%"  x2="100%" y2="6%"  stroke="url(#lineGradient1)" stroke-width="2" class="animate-scan-line" style="animation-delay: 0s;"/>
      <line x1="0" y1="18%" x2="100%" y2="18%" stroke="url(#lineGradient2)" stroke-width="2" class="animate-scan-line" style="animation-delay: 0.6s;"/>
      <line x1="0" y1="30%" x2="100%" y2="30%" stroke="url(#lg4)" stroke-width="2" class="animate-scan-line" style="animation-delay: 1.2s;"/>
      <line x1="0" y1="42%" x2="100%" y2="42%" stroke="url(#lineGradient3)" stroke-width="2" class="animate-scan-line" style="animation-delay: 1.8s;"/>
      <line x1="0" y1="54%" x2="100%" y2="54%" stroke="url(#lg5)" stroke-width="2" class="animate-scan-line" style="animation-delay: 2.4s;"/>
      <line x1="0" y1="66%" x2="100%" y2="66%" stroke="url(#lineGradient1)" stroke-width="2" class="animate-scan-line" style="animation-delay: 3s;"/>
      <line x1="0" y1="78%" x2="100%" y2="78%" stroke="url(#lineGradient2)" stroke-width="2" class="animate-scan-line" style="animation-delay: 0.9s;"/>
      <line x1="0" y1="90%" x2="100%" y2="90%" stroke="url(#lg4)" stroke-width="2" class="animate-scan-line" style="animation-delay: 2.1s;"/>
    </svg>

    <!-- Tech Grid Patterns -->
    <svg class="absolute inset-0 w-full h-full opacity-10 dark:opacity-40" preserveAspectRatio="none">
      <defs>
        <pattern id="grid" width="100" height="100" patternUnits="userSpaceOnUse">
          <path d="M 100 0 L 0 0 0 100" fill="none" stroke="rgba(30, 64, 175, 0.3)" stroke-width="1"/>
        </pattern>
        <pattern id="grid-dot" width="60" height="60" patternUnits="userSpaceOnUse">
          <circle cx="30" cy="30" r="1.5" fill="rgba(59,130,246,0.25)" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
    <svg class="absolute inset-0 w-full h-full opacity-5 dark:opacity-20" preserveAspectRatio="none">
      <rect width="100%" height="100%" fill="url(#grid-dot)" />
    </svg>

    <!-- ═══ FLOATING TECH ICONS — KEPT ================ -->
    <!-- Icon 1: Code -->
    <div class="tech-icon absolute top-20 left-20 w-24 h-24 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 0s;">
      <div class="w-full h-full border-t-2 border-l-2 border-blue-600 dark:border-blue-400 rounded-3xl rotate-45 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-code text-blue-700 dark:text-blue-500 text-3xl -rotate-45"></i>
      </div>
    </div>

    <!-- Icon 2: Server -->
    <div class="tech-icon absolute top-40 right-32 w-20 h-20 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 2s;">
      <div class="w-full h-full border-t-2 border-r-2 border-indigo-600 dark:border-indigo-400 rounded-full flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-server text-indigo-700 dark:text-indigo-500 text-2xl"></i>
      </div>
    </div>

    <!-- Icon 3: Database -->
    <div class="tech-icon absolute bottom-40 left-1/4 w-28 h-28 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 4s;">
      <div class="w-full h-full border-b-2 border-r-2 border-blue-500 dark:border-blue-400 rounded-3xl flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-database text-blue-600 dark:text-blue-500 text-3xl"></i>
      </div>
    </div>

    <!-- Icon 4: Microchip -->
    <div class="tech-icon absolute bottom-20 right-20 w-24 h-24 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 1s;">
      <div class="w-full h-full border-b-2 border-l-2 border-blue-600 dark:border-blue-400 rounded-full flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-microchip text-blue-700 dark:text-blue-500 text-2xl"></i>
      </div>
    </div>

    <!-- Icon 5: Network -->
    <div class="tech-icon absolute top-1/2 right-1/4 w-20 h-20 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 3s;">
      <div class="w-full h-full border-t-2 border-b-2 border-indigo-600 dark:border-indigo-400 rounded-3xl flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-network-wired text-indigo-700 dark:text-indigo-500 text-xl"></i>
      </div>
    </div>

    <!-- ═══ NEW: HTML5 (visible on mobile, placed early) ═══ -->
    <div class="tech-icon absolute top-32 left-1/3 w-16 h-16 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 0.6s;">
      <div class="w-full h-full border-2 border-orange-600/60 dark:border-orange-500/50 rounded-xl rotate-12 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fab fa-html5 text-orange-700 dark:text-orange-400 text-xl -rotate-12"></i>
      </div>
    </div>

    <!-- ═══ NEW: CSS3 (visible on mobile, placed early) ═══ -->
    <div class="tech-icon absolute top-1/3 left-10 w-14 h-14 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 2.6s;">
      <div class="w-full h-full border-2 border-blue-600/60 dark:border-blue-500/50 rounded-xl -rotate-6 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fab fa-css3-alt text-blue-700 dark:text-blue-400 text-lg rotate-6"></i>
      </div>
    </div>

    <!-- Icon 6: JavaScript -->
    <div class="tech-icon absolute bottom-1/3 left-1/3 w-18 h-18 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 1.8s;">
      <div class="w-full h-full border-2 border-cyan-600/60 dark:border-cyan-500/50 rounded-xl rotate-45 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fab fa-js text-cyan-700 dark:text-cyan-400 text-xl -rotate-45"></i>
      </div>
    </div>

    <!-- Icon 7: Python -->
    <div class="tech-icon absolute bottom-32 right-1/4 w-16 h-16 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 0.3s;">
      <div class="w-full h-full border-2 border-violet-600/60 dark:border-violet-500/50 rounded-xl -rotate-12 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fab fa-python text-violet-700 dark:text-violet-400 text-xl rotate-12"></i>
      </div>
    </div>

    <!-- Icon 8: React -->
    <div class="tech-icon absolute top-1/2 left-2/3 w-14 h-14 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 3.8s;">
      <div class="w-full h-full border-2 border-pink-600/60 dark:border-pink-500/50 rounded-xl rotate-6 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fab fa-react text-pink-700 dark:text-pink-400 text-lg -rotate-6"></i>
      </div>
    </div>

    <!-- Rest of icons (hidden on mobile) -->
    <div class="tech-icon absolute top-60 right-10 w-18 h-18 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 1.4s;">
      <div class="w-full h-full border-2 border-sky-600/60 dark:border-sky-500/50 rounded-2xl rotate-3 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fab fa-php text-sky-700 dark:text-sky-400 text-xl -rotate-3"></i>
      </div>
    </div>
    <div class="tech-icon absolute bottom-1/4 right-1/5 w-16 h-16 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 2.2s;">
      <div class="w-full h-full border-2 border-amber-600/60 dark:border-amber-500/50 rounded-full flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-cloud text-amber-700 dark:text-amber-400 text-xl"></i>
      </div>
    </div>
    <div class="tech-icon absolute top-1/4 right-1/3 w-14 h-14 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 0.9s;">
      <div class="w-full h-full border-2 border-rose-600/60 dark:border-rose-500/50 rounded-xl -rotate-8 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-terminal text-rose-700 dark:text-rose-400 text-lg rotate-8"></i>
      </div>
    </div>
    <div class="tech-icon absolute top-2/3 right-1/3 w-18 h-18 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 4.2s;">
      <div class="w-full h-full border-2 border-teal-600/60 dark:border-teal-500/50 rounded-2xl rotate-12 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-cogs text-teal-700 dark:text-teal-400 text-xl -rotate-12"></i>
      </div>
    </div>
    <div class="tech-icon absolute bottom-10 left-1/3 w-16 h-16 opacity-10 dark:opacity-20 animate-float-tech" style="animation-delay: 3.4s;">
      <div class="w-full h-full border-2 border-fuchsia-600/60 dark:border-fuchsia-500/50 rounded-xl rotate-6 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
        <i class="fas fa-laptop-code text-fuchsia-700 dark:text-fuchsia-400 text-lg -rotate-6"></i>
      </div>
    </div>
    <div class="tech-icon absolute top-1/4 left-2/3 w-14 h-14 opacity-8 dark:opacity-15 animate-float-tech" style="animation-delay: 5s;">
      <div class="w-full h-full border-2 border-blue-600/50 dark:border-blue-500/40 rounded-lg rotate-45 flex items-center justify-center bg-white/5 dark:bg-black/5 backdrop-blur-sm">
        <i class="fas fa-robot text-blue-600 dark:text-blue-400 text-lg -rotate-45"></i>
      </div>
    </div>
    <div class="tech-icon absolute bottom-2/3 left-1/5 w-16 h-16 opacity-8 dark:opacity-15 animate-float-tech" style="animation-delay: 1s;">
      <div class="w-full h-full border-2 border-indigo-600/50 dark:border-indigo-500/40 rounded-2xl -rotate-3 flex items-center justify-center bg-white/5 dark:bg-black/5 backdrop-blur-sm">
        <i class="fas fa-shield-alt text-indigo-600 dark:text-indigo-400 text-lg rotate-3"></i>
      </div>
    </div>
    <div class="tech-icon absolute top-3/4 right-2/3 w-14 h-14 opacity-8 dark:opacity-15 animate-float-tech" style="animation-delay: 3s;">
      <div class="w-full h-full border-2 border-cyan-600/50 dark:border-cyan-500/40 rounded-full flex items-center justify-center bg-white/5 dark:bg-black/5 backdrop-blur-sm">
        <i class="fas fa-bolt text-cyan-600 dark:text-cyan-400 text-lg"></i>
      </div>
    </div>
    <div class="tech-icon absolute top-1/3 right-10 w-16 h-16 opacity-8 dark:opacity-15 animate-float-tech" style="animation-delay: 2.8s;">
      <div class="w-full h-full border-2 border-green-600/50 dark:border-green-500/40 rounded-xl rotate-8 flex items-center justify-center bg-white/5 dark:bg-black/5 backdrop-blur-sm">
        <i class="fab fa-git-alt text-green-700 dark:text-green-400 text-lg -rotate-8"></i>
      </div>
    </div>

    <!-- ═══ FLOATING CODE BRACKETS ═══ -->
    <div class="absolute top-28 left-2/3 text-4xl font-mono font-bold text-blue-600/20 dark:text-blue-400/15 animate-float-bracket" style="animation-delay:0.3s;">
      { }
    </div>
    <div class="absolute bottom-32 left-1/5 text-3xl font-mono font-bold text-indigo-600/20 dark:text-indigo-400/15 animate-float-bracket" style="animation-delay:1.8s;">
      &lt; / &gt;
    </div>
    <div class="absolute top-1/3 right-1/5 text-4xl font-mono font-bold text-cyan-600/15 dark:cyan-400/12 animate-float-bracket" style="animation-delay:2.6s;">
      [ ]
    </div>
    <div class="absolute bottom-1/3 left-2/3 text-3xl font-mono font-bold text-violet-600/15 dark:text-violet-400/12 animate-float-bracket" style="animation-delay:0.9s;">
      ( )
    </div>
    <div class="absolute top-2/3 right-1/4 text-3xl font-mono font-bold text-rose-600/15 dark:text-rose-400/12 animate-float-bracket" style="animation-delay:3.8s;">
      { &lt; / &gt; }
    </div>
    <div class="absolute top-10 left-1/2 text-2xl font-mono font-bold text-blue-600/12 dark:text-blue-400/10 animate-float-bracket" style="animation-delay:4.5s;">
      &lt; code &gt;
    </div>

    <!-- ═══ TERMINAL CURSOR LINES ═══ -->
    <div class="absolute top-1/2 left-8 text-sm font-mono text-blue-600/20 dark:text-blue-400/15 animate-terminal-cursor hidden sm:block" style="animation-delay:0s;">
      <span class="opacity-80">$</span>
      <span class="text-cyan-600/25 dark:text-cyan-400/20"> npm install --save</span>
      <span class="inline-block w-2 h-4 bg-blue-600/30 dark:bg-blue-400/25 ml-1 animate-blink-cursor"></span>
    </div>
    <div class="absolute bottom-1/4 right-8 text-sm font-mono text-indigo-600/20 dark:text-indigo-400/15 animate-terminal-cursor" style="animation-delay:3s;">
      <span class="opacity-80">$</span>
      <span class="text-violet-600/25 dark:text-violet-400/20"> git push origin main</span>
      <span class="inline-block w-2 h-4 bg-indigo-600/30 dark:bg-indigo-400/25 ml-1 animate-blink-cursor"></span>
    </div>
    <div class="absolute top-3/4 left-1/4 text-sm font-mono text-cyan-600/20 dark:text-cyan-400/15 animate-terminal-cursor" style="animation-delay:6s;">
      <span class="opacity-80">$</span>
      <span class="text-sky-600/25 dark:text-sky-400/20"> yarn build</span>
      <span class="inline-block w-2 h-4 bg-cyan-600/30 dark:bg-cyan-400/25 ml-1 animate-blink-cursor"></span>
    </div>

    <!-- ═══ PARTICLES — HEAVY: DISABLED ON MOBILE ═══ -->
    <div class="absolute inset-0 opacity-60 dark:opacity-100 mobile-hide-particles">
      <!-- Blue Particles -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 15%; left: 10%; animation-delay: 0s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 35%; left: 70%; animation-delay: 1.5s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 60%; left: 20%; animation-delay: 3s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 75%; right: 15%; animation-delay: 4.5s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 45%; left: 5%; animation-delay: 6s;"></div>
      
      <!-- Indigo Particles -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top: 25%; right: 30%; animation-delay: 0.8s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top: 50%; left: 45%; animation-delay: 2.3s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top: 80%; left: 30%; animation-delay: 3.8s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top: 10%; left: 50%; animation-delay: 5.2s;"></div>
      
      <!-- Sky Particles -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-sky-500 dark:bg-sky-400 rounded-full animate-tech-float shadow-glow-sky" style="top: 40%; right: 10%; animation-delay: 1.2s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-sky-500 dark:bg-sky-400 rounded-full animate-tech-float shadow-glow-sky" style="top: 70%; right: 50%; animation-delay: 2.8s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-sky-500 dark:bg-sky-400 rounded-full animate-tech-float shadow-glow-sky" style="top: 20%; left: 80%; animation-delay: 4.2s;"></div>
      
      <!-- Violet Particles -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-violet-500 dark:bg-violet-400 rounded-full animate-tech-float shadow-glow-violet" style="top: 30%; left: 55%; animation-delay: 0.5s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-violet-500 dark:bg-violet-400 rounded-full animate-tech-float shadow-glow-violet" style="top: 90%; right: 30%; animation-delay: 2s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-violet-500 dark:bg-violet-400 rounded-full animate-tech-float shadow-glow-violet" style="top: 5%; right: 60%; animation-delay: 3.5s;"></div>
      
      <!-- Teal Particles -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-teal-500 dark:bg-teal-400 rounded-full animate-tech-float shadow-glow-teal" style="top: 10%; right: 15%; animation-delay: 0.2s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-teal-500 dark:bg-teal-400 rounded-full animate-tech-float shadow-glow-teal" style="top: 95%; left: 40%; animation-delay: 1.7s;"></div>
      
      <!-- Rose/Pink Particles -->
      <div class="tech-particle absolute w-1.5 h-1.5 bg-rose-500 dark:bg-rose-400 rounded-full animate-tech-float shadow-glow-rose" style="top: 78%; left: 10%; animation-delay: 0.7s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-rose-500 dark:bg-rose-400 rounded-full animate-tech-float shadow-glow-rose" style="top: 18%; left: 40%; animation-delay: 2.2s;"></div>
    </div>

    <!-- ═══ ANIMATED ORBITS — HEAVY: DISABLED ON MOBILE ═══ -->
    <div class="absolute top-1/4 left-1/3 w-64 h-64 opacity-20 dark:opacity-30 mobile-hide-orbits">
      <svg class="w-full h-full animate-rotate-slow" viewBox="0 0 100 100" preserveAspectRatio="none">
        <circle cx="50" cy="50" r="45" fill="none" stroke="url(#lineGradient1)" stroke-width="0.5" opacity="0.5"/>
        <circle cx="50" cy="50" r="30" fill="none" stroke="url(#lineGradient2)" stroke-width="0.5" opacity="0.5"/>
        <circle cx="50" cy="50" r="15" fill="none" stroke="url(#lineGradient3)" stroke-width="0.5" opacity="0.5"/>
        <circle cx="95" cy="50" r="2.5" fill="#1e40af" class="animate-orbit-1"/>
        <circle cx="50" cy="5" r="2.5" fill="#0284c7" class="animate-orbit-2"/>
        <circle cx="5" cy="50" r="2.5" fill="#4f46e5" class="animate-orbit-3"/>
      </svg>
    </div>
    <!-- Second orbit ring -->
    <div class="absolute bottom-1/3 right-1/4 w-48 h-48 opacity-15 dark:opacity-20 mobile-hide-orbits">
      <svg class="w-full h-full animate-rotate-slow" viewBox="0 0 100 100" preserveAspectRatio="none" style="animation-duration:25s;animation-direction:reverse">
        <circle cx="50" cy="50" r="40" fill="none" stroke="url(#lg4)" stroke-width="0.4" opacity="0.4"/>
        <circle cx="50" cy="50" r="25" fill="none" stroke="url(#lg5)" stroke-width="0.4" opacity="0.4"/>
        <circle cx="90" cy="50" r="2" fill="#06b6d4" class="animate-orbit-1" style="animation-duration:8s"/>
        <circle cx="50" cy="10" r="2" fill="#8b5cf6" class="animate-orbit-2" style="animation-duration:8s"/>
      </svg>
    </div>

    <!-- ═══ STATUS INDICATOR LIGHTS — KEPT (low cost) ═══ -->
    <div class="absolute top-20 right-1/3 w-3 h-3 bg-blue-500 rounded-full animate-status-pulse" style="animation-delay: 0s;">
      <div class="absolute inset-0 bg-blue-500 rounded-full animate-status-ping"></div>
    </div>
    <div class="absolute top-1/3 left-1/4 w-3 h-3 bg-indigo-500 rounded-full animate-status-pulse" style="animation-delay: 1s;">
      <div class="absolute inset-0 bg-indigo-500 rounded-full animate-status-ping"></div>
    </div>
    <div class="absolute bottom-1/3 right-1/4 w-3 h-3 bg-sky-500 rounded-full animate-status-pulse" style="animation-delay: 2s;">
      <div class="absolute inset-0 bg-sky-500 rounded-full animate-status-ping"></div>
    </div>
    <div class="absolute top-2/3 left-10 w-2.5 h-2.5 bg-violet-500 rounded-full animate-status-pulse" style="animation-delay: 0.5s;">
      <div class="absolute inset-0 bg-violet-500 rounded-full animate-status-ping"></div>
    </div>
    <div class="absolute bottom-20 left-1/3 w-2.5 h-2.5 bg-teal-500 rounded-full animate-status-pulse" style="animation-delay: 1.5s;">
      <div class="absolute inset-0 bg-teal-500 rounded-full animate-status-ping"></div>
    </div>
    <div class="absolute top-1/2 right-10 w-2.5 h-2.5 bg-rose-500 rounded-full animate-status-pulse" style="animation-delay: 2.5s;">
      <div class="absolute inset-0 bg-rose-500 rounded-full animate-status-ping"></div>
    </div>

    <!-- ═══ GLOWING ORBS — HEAVY: DISABLED ON MOBILE ═══ -->
    <div class="absolute top-0 left-1/3 w-96 h-96 bg-gradient-to-br from-blue-200/30 to-indigo-200/20 dark:from-blue-500/10 dark:to-indigo-500/5 rounded-full blur-3xl animate-pulse-glow mobile-hide-glow"></div>
    <div class="absolute top-1/2 right-0 w-96 h-96 bg-gradient-to-br from-indigo-200/30 to-blue-200/20 dark:from-indigo-500/10 dark:to-blue-500/5 rounded-full blur-3xl animate-pulse-glow mobile-hide-glow" style="animation-delay: 1s;"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-gradient-to-br from-blue-200/30 to-indigo-200/20 dark:from-blue-500/10 dark:to-indigo-500/5 rounded-full blur-3xl animate-pulse-glow mobile-hide-glow" style="animation-delay: 2s;"></div>
    <div class="absolute top-1/3 right-1/4 w-72 h-72 bg-gradient-to-br from-cyan-200/15 to-violet-200/10 dark:from-cyan-500/8 dark:to-violet-500/5 rounded-full blur-3xl animate-pulse-glow mobile-hide-glow" style="animation-delay: 3s;"></div>
  </div>

  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-blue-50 via-slate-50 to-blue-50 dark:from-slate-900 dark:via-blue-950 dark:to-slate-900 py-20 mb-16">
    <div class="absolute inset-0 opacity-30 dark:opacity-20">
      <div class="absolute top-0 -left-4 w-72 h-72 bg-blue-500 dark:bg-blue-700 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-xl animate-blob"></div>
      <div class="absolute top-0 -right-4 w-72 h-72 bg-slate-500 dark:bg-slate-700 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-xl animate-blob animation-delay-2000"></div>
      <div class="absolute -bottom-8 left-20 w-72 h-72 bg-blue-600 dark:bg-blue-800 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-xl animate-blob animation-delay-4000"></div>
    </div>
    <div class="absolute inset-0 opacity-100 dark:opacity-30" style="background-image: radial-gradient(circle at 1px 1px, rgb(30 58 138 / 0.15) 1px, transparent 0); background-size: 40px 40px;"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center">
        <div class="relative inline-block group/badge mb-6">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-blue-700 via-blue-600 to-blue-700 rounded-full opacity-0 group-hover/badge:opacity-100 blur-sm transition-all duration-500"></div>
          <div class="relative inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 dark:bg-slate-800/80 backdrop-blur-md border-2 border-blue-300 dark:border-blue-600/50 animate-fade-in-down shadow-lg transition-all duration-300 group-hover/badge:scale-110 group-hover/badge:border-blue-500">
            <span class="relative flex h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-600 dark:bg-blue-700 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-blue-700 dark:bg-blue-600"></span>
            </span>
            <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Featured Work</span>
          </div>
        </div>

        <h1 class="text-5xl md:text-7xl font-black mb-6 animate-fade-in-up">
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-700 via-blue-600 to-blue-800 dark:from-blue-400 dark:via-blue-500 dark:to-blue-600">
            Creative Portfolio
          </span>
        </h1>

        <p class="text-xl text-slate-600 dark:text-slate-300 mb-8 max-w-2xl mx-auto animate-fade-in-up animation-delay-200">
          Explore a collection of innovative projects built with modern technologies and creative solutions
        </p>

        <div class="flex flex-wrap justify-center gap-8 animate-fade-in-up animation-delay-400">
          <div class="relative group/stat">
            <div class="absolute -inset-0.5 bg-gradient-to-r from-blue-700 to-blue-800 rounded-xl opacity-0 group-hover/stat:opacity-100 blur-sm transition-all duration-500"></div>
            <div class="relative text-center p-4 rounded-xl border-2 border-slate-200 dark:border-slate-700 group-hover/stat:border-blue-600 transition-all duration-300 group-hover/stat:scale-110 bg-white/50 dark:bg-slate-900/50 backdrop-blur-sm">
              <div class="text-3xl font-bold text-blue-700 dark:text-blue-400"><%= projects.length %>+</div>
              <div class="text-sm text-slate-600 dark:text-slate-400">Projects</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Filter Tabs -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
    <div class="relative inline-block group/filter-container">
      <div class="absolute -inset-1 bg-gradient-to-r from-blue-700 via-blue-600 to-blue-700 rounded-2xl opacity-0 group-hover/filter-container:opacity-100 blur-sm transition-all duration-500"></div>
      <div class="relative bg-white dark:bg-slate-900 rounded-2xl p-2 shadow-xl border-2 border-slate-200 dark:border-slate-800 inline-flex gap-2 flex-wrap transition-all duration-300 group-hover/filter-container:border-blue-600 dark:group-hover/filter-container:border-blue-700 group-hover/filter-container:scale-105">
        <button class="filter-tab active relative group/tab px-6 py-3 rounded-xl font-semibold text-sm transition-all duration-300" data-filter="all">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-blue-700 to-blue-600 rounded-xl opacity-0 group-hover/tab:opacity-100 blur-sm transition-all duration-500"></div>
          <span class="relative"><i class="fas fa-th-large mr-2"></i>All Projects</span>
        </button>
        <button class="filter-tab relative group/tab px-6 py-3 rounded-xl font-semibold text-sm transition-all duration-300" data-filter="app">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-blue-700 to-blue-600 rounded-xl opacity-0 group-hover/tab:opacity-100 blur-sm transition-all duration-500"></div>
          <span class="relative"><i class="fas fa-mobile-alt mr-2"></i>Mobile Apps</span>
        </button>
        <button class="filter-tab relative group/tab px-6 py-3 rounded-xl font-semibold text-sm transition-all duration-300" data-filter="website">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-blue-700 to-blue-600 rounded-xl opacity-0 group-hover/tab:opacity-100 blur-sm transition-all duration-500"></div>
          <span class="relative"><i class="fas fa-desktop mr-2"></i>Websites</span>
        </button>
        <button class="filter-tab relative group/tab px-6 py-3 rounded-xl font-semibold text-sm transition-all duration-300" data-filter="system">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-blue-700 to-blue-600 rounded-xl opacity-0 group-hover/tab:opacity-100 blur-sm transition-all duration-500"></div>
          <span class="relative"><i class="fas fa-server mr-2"></i>Systems</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="projects-grid">

      <% projects.forEach((project, index) => { %>
      <div class="project-item group <%= project.featured ? 'md:col-span-2 lg:col-span-1' : '' %>"
      data-category="<%= project.category %>"
      style="animation-delay: <%= index * 0.1 %>s;">

      <div class="relative h-full">
        <div class="absolute -inset-1 bg-gradient-to-r from-blue-700 via-blue-600 to-blue-700 rounded-2xl opacity-0 group-hover:opacity-100 blur-sm transition-all duration-500"></div>
        <div class="relative h-full bg-white dark:bg-slate-900 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 border-2 border-slate-200 dark:border-slate-800 group-hover:border-blue-700 dark:group-hover:border-blue-700 group-hover:scale-105">

          <!-- Project Image -->
          <div class="relative h-64 bg-gradient-to-br <%= project.bgGradient %> overflow-hidden">
            <img
            src="<%= project.images[0] %>"
            alt="<%= project.title %>"
            class="w-full h-full object-contain"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            >
            <div class="absolute inset-0 hidden items-center justify-center">
              <div class="w-24 h-24 rounded-2xl bg-white/90 dark:bg-slate-800/90 flex items-center justify-center shadow-xl">
                <i class="fas fa-<%= project.icon %> text-5xl bg-gradient-to-r <%= project.gradient %> bg-clip-text text-transparent"></i>
              </div>
            </div>

            <!-- Photo Count -->
            <div class="absolute top-4 left-4 z-10">
              <span class="block px-3 py-1 rounded-full text-xs font-bold bg-black/60 backdrop-blur-sm text-white border border-white/30 shadow-lg">
                <i class="fas fa-images mr-1"></i><%= project.images.length %> Photos
              </span>
            </div>

            <!-- Category -->
            <div class="absolute top-4 right-4 z-10">
              <span class="block px-3 py-1 rounded-full text-xs font-bold bg-white/90 dark:bg-slate-800/90 backdrop-blur-sm text-slate-700 dark:text-slate-200 border-2 border-white/50 shadow-lg">
                <%= project.category.toUpperCase() %>
              </span>
            </div>

            <% if (project.featured) { %>
            <div class="absolute top-12 left-4 z-10 mt-1">
              <span class="block px-3 py-1 rounded-full text-xs font-bold bg-gradient-to-r from-blue-700 to-blue-600 text-white shadow-lg">
                <i class="fas fa-star mr-1"></i>Featured
              </span>
            </div>
            <% } %>

            <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-4 group-hover:translate-y-0 z-20">
              <button onclick='openProjectModal(<%= JSON.stringify(project) %>)'
              class="px-6 py-3 bg-white text-blue-700 rounded-xl font-bold hover:bg-blue-50 transition-all duration-300 shadow-xl">
              <i class="fas fa-images mr-2"></i>View Gallery
            </button>
          </div>
        </div>

        <!-- Card Content -->
        <div class="p-6">
          <h3 class="text-2xl font-bold mb-3 text-slate-900 dark:text-white group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors duration-300">
            <%= project.title %>
          </h3>
          <p class="text-slate-600 dark:text-slate-300 mb-4 line-clamp-2">
            <%= project.description %>
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <% project.technologies.forEach(tech => { %>
            <span class="px-3 py-1 rounded-lg text-xs font-semibold bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border-2 border-slate-200 dark:border-slate-700">
              <%= tech %>
            </span>
            <% }); %>
          </div>

          <!-- Link Badges (Website + GitHub) -->
          <div class="flex flex-wrap gap-2 mb-4">
            <% if (project.websiteUrl) { %>
            <a href="<%= project.websiteUrl %>" target="_blank"
            class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-xs font-semibold bg-blue-50 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 border border-blue-200 dark:border-blue-800 hover:bg-blue-100 dark:hover:bg-blue-800/50 transition-all duration-300">
            <i class="fas fa-globe text-[10px]"></i> Live
          </a>
          <% } %>
          <% if (project.githubUrl) { %>
          <a href="<%= project.githubUrl %>" target="_blank"
          class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-xs font-semibold bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all duration-300">
          <i class="fab fa-github text-[10px]"></i>
        </a>
        <% } %>
      </div>

      <div class="flex gap-3 pt-4 border-t border-slate-200 dark:border-slate-800">
        <button onclick='openProjectModal(<%= JSON.stringify(project) %>)'
        class="flex-1 text-center px-4 py-2 bg-gradient-to-r from-blue-700 to-blue-600 text-white rounded-lg font-semibold text-sm hover:from-blue-800 hover:to-blue-700 transition-all duration-300 shadow-md">
        <i class="fas fa-eye mr-2"></i>View Details
      </button>
      <button onclick="shareProject('<%= project.title %>', '<%= project.id %>')"
      class="px-4 py-2 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg font-semibold text-sm hover:bg-slate-200 dark:hover:bg-slate-700 transition-all duration-300 border-2 border-slate-200 dark:border-slate-700">
      <i class="fas fa-share-alt"></i>
    </button>
  </div>
</div>
</div>
</div>
</div>
<% }); %>
</div>
</section>

<!-- CTA Section -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
  <div class="relative group/cta">
    <div class="absolute -inset-1 bg-gradient-to-r from-blue-700 via-blue-600 to-blue-700 rounded-3xl opacity-0 group-hover/cta:opacity-100 blur-md transition-all duration-500"></div>
    <div class="relative overflow-hidden rounded-3xl p-12 text-center shadow-2xl transition-all duration-300 group-hover/cta:scale-[1.02] border-2 border-blue-600/50"
    style="background: linear-gradient(to right, #1e3a8a, #1e40af, #0c4a6e);">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-0 left-0 w-40 h-40 bg-white rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-0 right-0 w-40 h-40 bg-white rounded-full blur-3xl animate-pulse animation-delay-2000"></div>
    </div>
    <div class="relative z-10">
      <div class="inline-block p-4 rounded-2xl mb-6" style="background: rgba(255,255,255,0.25);">
        <i class="fas fa-rocket text-5xl text-white"></i>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Ready to Start Your Project?</h2>
      <p class="text-xl text-white mb-8 max-w-2xl mx-auto">Let's collaborate and create something amazing together.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/contact" class="px-8 py-4 bg-white text-blue-700 rounded-xl font-bold hover:bg-slate-50 transition-all duration-300 shadow-xl">
          <i class="fas fa-paper-plane mr-2"></i>Get Started
        </a>
        <a href="#" class="px-8 py-4 text-white border-2 border-white rounded-xl font-bold transition-all duration-300" style="background: rgba(255,255,255,0.20);">
          <i class="fas fa-calendar mr-2"></i>Schedule Call
        </a>
      </div>
    </div>
  </div>
</div>
</section>

</div>

<!-- ===================== BACK TO TOP BUTTON ===================== -->
<button id="backToTop" 
        class="fixed bottom-8 right-8 z-50 w-14 h-14 rounded-full bg-gradient-to-r from-blue-600 to-indigo-600 text-white shadow-lg shadow-blue-500/30 hover:shadow-xl hover:shadow-blue-500/50 hover:scale-110 transition-all duration-300 flex items-center justify-center group opacity-0 invisible translate-y-4"
        onclick="scrollToTop()"
        aria-label="Back to top">
  <i class="fas fa-arrow-up text-xl group-hover:-translate-y-1 transition-transform duration-300"></i>
  <span class="absolute -top-2 -right-2 w-5 h-5 bg-red-500 rounded-full flex items-center justify-center text-[10px] font-bold animate-pulse">↑</span>
</button>

<!-- ===================== PROJECT MODAL ===================== -->
<div id="projectModal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/70 backdrop-blur-sm">
  <div class="modal-content relative w-full max-w-3xl max-h-[95vh] overflow-y-auto bg-white dark:bg-slate-900 rounded-3xl shadow-2xl transform transition-all duration-500 scale-95 opacity-0">

    <!-- Close Button -->
    <button onclick="closeProjectModal()"
    class="absolute top-4 right-4 z-50 w-10 h-10 flex items-center justify-center bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-full hover:bg-red-500 hover:text-white transition-all duration-300 shadow-xl border-2 border-slate-200 dark:border-slate-700 group">
    <i class="fas fa-times group-hover:rotate-90 transition-transform duration-300"></i>
  </button>

  <!-- Title Bar -->
  <div class="px-6 pt-6 pb-3">
    <div class="flex items-center gap-2 flex-wrap pr-10">
      <span id="modalCategory" class="px-3 py-1 rounded-full text-xs font-bold bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 border-2 border-blue-200 dark:border-blue-800"></span>
      <span id="modalFeatured" class="hidden px-3 py-1 rounded-full text-xs font-bold bg-gradient-to-r from-blue-700 to-blue-600 text-white">
        <i class="fas fa-star mr-1"></i>Featured
      </span>
    </div>
    <h2 id="modalTitle" class="text-2xl md:text-3xl font-black text-slate-900 dark:text-white mt-2"></h2>
    <p id="modalDescription" class="text-slate-500 dark:text-slate-400 mt-1 text-sm"></p>
  </div>

  <!-- Image Viewer -->
  <div class="px-6 py-3">
    <div id="mainImageWrapper" class="relative rounded-2xl overflow-hidden border-2 border-slate-200 dark:border-slate-700 bg-slate-100 dark:bg-slate-800">
      <div id="imageSlider" class="relative w-full">
        <!-- Slides injected by JS -->
      </div>

      <!-- Left Arrow -->
      <button onclick="previousImage()" id="prevBtn"
      class="hidden absolute left-3 top-1/2 -translate-y-1/2 z-20 w-10 h-10 items-center justify-center bg-white/95 dark:bg-slate-800/95 text-slate-700 dark:text-slate-200 rounded-full hover:bg-blue-600 hover:text-white transition-all duration-300 shadow-lg border border-slate-200 dark:border-slate-600 group">
      <i class="fas fa-chevron-left text-sm group-hover:-translate-x-0.5 transition-transform duration-300"></i>
    </button>

    <!-- Right Arrow -->
    <button onclick="nextImage()" id="nextBtn"
    class="hidden absolute right-3 top-1/2 -translate-y-1/2 z-20 w-10 h-10 items-center justify-center bg-white/95 dark:bg-slate-800/95 text-slate-700 dark:text-slate-200 rounded-full hover:bg-blue-600 hover:text-white transition-all duration-300 shadow-lg border border-slate-200 dark:border-slate-600 group">
    <i class="fas fa-chevron-right text-sm group-hover:translate-x-0.5 transition-transform duration-300"></i>
  </button>

  <!-- Counter -->
  <div id="imageCounter" class="hidden absolute top-3 right-3 z-20">
    <span class="px-2.5 py-1 bg-black/65 backdrop-blur-sm text-white rounded-full text-xs font-bold">
      <span id="currentImageIndex">1</span> / <span id="totalImages">1</span>
    </span>
  </div>
</div>

<!-- Thumbnails -->
<div id="thumbnailRow" class="hidden mt-3">
  <div id="thumbnailContainer" class="flex gap-2 overflow-x-auto pb-1 scrollbar-hide">
    <!-- Thumbnails injected by JS -->
  </div>
</div>
</div>

<!-- Modal Body -->
<div class="px-6 pb-6">

  <!-- About -->
  <div class="mb-6">
    <h3 class="text-base font-bold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
      <div class="w-6 h-6 rounded-md bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center">
        <i class="fas fa-info-circle text-blue-600 text-xs"></i>
      </div>
      About This Project
    </h3>
    <p id="modalFullDescription" class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed"></p>
  </div>

  <!-- Technologies -->
  <div class="mb-6">
    <h3 class="text-base font-bold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
      <div class="w-6 h-6 rounded-md bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center">
        <i class="fas fa-code text-blue-600 text-xs"></i>
      </div>
      Technologies Used
    </h3>
    <div id="modalTechnologies" class="flex flex-wrap gap-2"></div>
  </div>

  <!-- Features -->
  <div class="mb-6">
    <h3 class="text-base font-bold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
      <div class="w-6 h-6 rounded-md bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center">
        <i class="fas fa-check-circle text-blue-600 text-xs"></i>
      </div>
      Key Features
    </h3>
    <div id="modalFeatures" class="grid grid-cols-1 sm:grid-cols-2 gap-2"></div>
  </div>

  <!-- ===== ACTION BUTTONS - Website + GitHub ===== -->
  <div class="flex flex-wrap gap-3 pt-5 border-t border-slate-200 dark:border-slate-800">

    <!-- Visit Website -->
    <a id="modalWebsiteLink" href="#" target="_blank"
    class="flex-1 min-w-[140px] flex items-center justify-center gap-2 px-5 py-3 bg-blue-600 text-white rounded-xl font-bold text-sm hover:bg-blue-700 transition-all duration-300 shadow-md">
    <i class="fas fa-globe"></i>Visit Website
  </a>

  <!-- GitHub -->
  <a id="modalGithubLink" href="#" target="_blank"
  class="flex-1 min-w-[140px] flex items-center justify-center gap-2 px-5 py-3 bg-slate-800 dark:bg-slate-700 text-white rounded-xl font-bold text-sm hover:bg-slate-900 dark:hover:bg-slate-600 transition-all duration-300 shadow-md">
  <i class="fab fa-github"></i>View on GitHub
</a>

<!-- Share -->
<button id="modalShareBtn"
class="flex items-center justify-center gap-2 px-5 py-3 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-xl font-bold text-sm hover:bg-slate-200 dark:hover:bg-slate-700 transition-all duration-300 shadow-md border-2 border-slate-200 dark:border-slate-700">
<i class="fas fa-share-alt"></i>Share
</button>

</div>
</div>
</div>
</div>

<!-- ===================== ANIMATION STYLES ===================== -->
<style>
  /* Performance Optimization */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* ===== SMOOTH DARK/LIGHT MODE TRANSITIONS ===== */
  /* Apply to all elements that change with theme */
  * {
    transition: background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                border-color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                fill 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                stroke 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Optimize performance by limiting transition to specific elements */
  body, 
  .bg-white, .dark .bg-white,
  .bg-slate-50, .dark .bg-slate-50,
  .bg-slate-100, .dark .bg-slate-100,
  .bg-slate-200, .dark .bg-slate-200,
  .bg-slate-900, .dark .bg-slate-900,
  .bg-slate-950, .dark .bg-slate-950,
  .bg-blue-50, .dark .bg-blue-50,
  .bg-blue-100, .dark .bg-blue-100,
  .bg-indigo-50, .dark .bg-indigo-50,
  .bg-indigo-100, .dark .bg-indigo-100,
  .text-slate-900, .dark .text-slate-900,
  .text-slate-700, .dark .text-slate-700,
  .text-slate-600, .dark .text-slate-600,
  .text-slate-300, .dark .text-slate-300,
  .text-white, .dark .text-white,
  .border-slate-200, .dark .border-slate-200,
  .border-slate-300, .dark .border-slate-300,
  .border-blue-300, .dark .border-blue-300,
  .border-blue-600, .dark .border-blue-600,
  .shadow-lg, .dark .shadow-lg,
  .shadow-xl, .dark .shadow-xl,
  .backdrop-blur-sm, .dark .backdrop-blur-sm,
  .feature-card, .dark .feature-card,
  .stat-box, .dark .stat-box,
  .card-border, .dark .card-border,
  .modal-content, .dark .modal-content {
    transition: background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                border-color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Smooth gradient transitions */
  .bg-gradient-to-br,
  .bg-gradient-to-r,
  .bg-gradient-to-t,
  .from-slate-50, .dark .from-slate-50,
  .from-blue-50, .dark .from-blue-50,
  .from-indigo-50, .dark .from-indigo-50,
  .to-blue-50, .dark .to-blue-50,
  .to-indigo-50, .dark .to-indigo-50,
  .via-blue-50, .dark .via-blue-50,
  .via-indigo-50, .dark .via-indigo-50 {
    transition: background 0.6s cubic-bezier(0.4, 0, 0.2, 1),
                background-color 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Scan Line Animation - GPU Accelerated */
  @keyframes scan-line {
    0%, 100% {
      opacity: 0;
      transform: translateX(-100%) translateZ(0);
    }
    50% {
      opacity: 1;
    }
  }

  .animate-scan-line {
    animation: scan-line 4s ease-in-out infinite;
    will-change: transform, opacity;
  }

  /* Tech Float Animation - Optimized */
  @keyframes float-tech {
    0%, 100% {
      transform: translateY(0px) rotateZ(0deg) translateZ(0);
    }
    25% {
      transform: translateY(-20px) rotateZ(5deg) translateZ(0);
    }
    50% {
      transform: translateY(-40px) rotateZ(0deg) translateZ(0);
    }
    75% {
      transform: translateY(-20px) rotateZ(-5deg) translateZ(0);
    }
  }

  .animate-float-tech {
    animation: float-tech 8s ease-in-out infinite;
    will-change: transform;
  }

  /* Tech Particle Float - Optimized */
  @keyframes tech-float {
    0% {
      transform: translateY(100vh) translateX(0) translateZ(0);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      transform: translateY(-100vh) translateX(100px) translateZ(0);
      opacity: 0;
    }
  }

  .animate-tech-float {
    animation: tech-float 20s linear infinite;
    will-change: transform, opacity;
  }

  /* Particle Glow Effects */
  .shadow-glow-blue {
    box-shadow: 0 0 10px rgba(30, 64, 175, 0.8), 0 0 20px rgba(30, 64, 175, 0.4);
  }
  .shadow-glow-indigo {
    box-shadow: 0 0 10px rgba(79, 70, 229, 0.8), 0 0 20px rgba(79, 70, 229, 0.4);
  }
  .shadow-glow-sky {
    box-shadow: 0 0 10px rgba(2, 132, 199, 0.8), 0 0 20px rgba(2, 132, 199, 0.4);
  }
  .shadow-glow-violet {
    box-shadow: 0 0 10px rgba(139, 92, 246, 0.8), 0 0 20px rgba(139, 92, 246, 0.4);
  }
  .shadow-glow-teal {
    box-shadow: 0 0 10px rgba(20, 184, 166, 0.8), 0 0 20px rgba(20, 184, 166, 0.4);
  }
  .shadow-glow-rose {
    box-shadow: 0 0 10px rgba(244, 63, 94, 0.8), 0 0 20px rgba(244, 63, 94, 0.4);
  }

  /* Rotate Slow - GPU Accelerated */
  @keyframes rotate-slow {
    0% {
      transform: rotate(0deg) translateZ(0);
    }
    100% {
      transform: rotate(360deg) translateZ(0);
    }
  }

  .animate-rotate-slow {
    animation: rotate-slow 20s linear infinite;
    will-change: transform;
  }

  /* Orbit Animations - Optimized */
  @keyframes orbit-1 {
    0% {
      cx: 95;
      cy: 50;
    }
    33.33% {
      cx: 50;
      cy: 5;
    }
    66.66% {
      cx: 5;
      cy: 50;
    }
    100% {
      cx: 95;
      cy: 50;
    }
  }

  @keyframes orbit-2 {
    0% {
      cx: 50;
      cy: 5;
    }
    33.33% {
      cx: 5;
      cy: 50;
    }
    66.66% {
      cx: 95;
      cy: 50;
    }
    100% {
      cx: 50;
      cy: 5;
    }
  }

  @keyframes orbit-3 {
    0% {
      cx: 5;
      cy: 50;
    }
    33.33% {
      cx: 95;
      cy: 50;
    }
    66.66% {
      cx: 50;
      cy: 5;
    }
    100% {
      cx: 5;
      cy: 50;
    }
  }

  .animate-orbit-1 {
    animation: orbit-1 6s linear infinite;
  }

  .animate-orbit-2 {
    animation: orbit-2 6s linear infinite;
  }

  .animate-orbit-3 {
    animation: orbit-3 6s linear infinite;
  }

  /* Status Pulse - Optimized */
  @keyframes status-pulse {
    0%, 100% {
      opacity: 1;
      box-shadow: 0 0 10px currentColor;
    }
    50% {
      opacity: 0.5;
      box-shadow: 0 0 5px currentColor;
    }
  }

  .animate-status-pulse {
    animation: status-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  /* Status Ping - GPU Accelerated */
  @keyframes status-ping {
    75%, 100% {
      transform: scale(2) translateZ(0);
      opacity: 0;
    }
  }

  .animate-status-ping {
    animation: status-ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
    will-change: transform, opacity;
  }

  /* Pulse Glow - Optimized */
  @keyframes pulse-glow {
    0%, 100% {
      opacity: 0.5;
      filter: blur(30px);
    }
    50% {
      opacity: 1;
      filter: blur(15px);
    }
  }

  .animate-pulse-glow {
    animation: pulse-glow 4s ease-in-out infinite;
    will-change: opacity, filter;
  }

  /* Floating Code Brackets */
  @keyframes float-bracket {
    0%,100% { transform: translateY(0) scale(1) rotate(0deg); opacity:0.2; }
    25% { transform: translateY(-15px) scale(1.05) rotate(2deg); opacity:0.35; }
    50% { transform: translateY(-30px) scale(0.95) rotate(-2deg); opacity:0.5; }
    75% { transform: translateY(-15px) scale(1.05) rotate(1deg); opacity:0.35; }
  }
  .animate-float-bracket {
    animation: float-bracket 7s ease-in-out infinite;
    will-change: transform,opacity;
  }

  /* Terminal cursor */
  @keyframes terminal-cursor {
    0%,100% { opacity:0.2; transform:translateX(0); }
    50% { opacity:0.6; transform:translateX(8px); }
  }
  .animate-terminal-cursor {
    animation: terminal-cursor 8s ease-in-out infinite;
    will-change: transform,opacity;
  }

  @keyframes blink-cursor { 0%,100% { opacity:1; } 50% { opacity:0; } }
  .animate-blink-cursor {
    animation: blink-cursor 1s step-end infinite;
    will-change: opacity;
  }

  /* Performance: Contain paint and layout */
  .animate-scan-line,
  .animate-float-tech,
  .animate-float-bracket,
  .animate-tech-float,
  .animate-rotate-slow,
  .animate-pulse-glow,
  .animate-terminal-cursor {
    contain: layout style paint;
  }

  /* Reduce animations on mobile */
  @media (max-width: 768px) {
    .animate-float-tech,
    .animate-rotate-slow {
      animation-duration: 12s;
    }
    .animate-tech-float {
      animation-duration: 30s;
    }
    .animate-float-bracket {
      animation-duration: 10s;
    }
  }

  /* Additional styles */
  @keyframes blob {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(30px, -50px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
    }
  }
  .animate-blob {
    animation: blob 7s infinite;
  }
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  .animation-delay-4000 {
    animation-delay: 4s;
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes fadeInScale {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .animate-fade-in-down {
    animation: fadeInDown 0.6s ease-out both;
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out both;
  }
  .animation-delay-200 {
    animation-delay: 0.2s;
  }
  .animation-delay-400 {
    animation-delay: 0.4s;
  }
  .project-item {
    animation: fadeInScale 0.6s ease-out both;
  }

  .filter-tab {
    color: rgb(71 85 105);
  }
  .dark .filter-tab {
    color: rgb(148 163 184);
  }
  .filter-tab:hover {
    background-color: rgb(241 245 249);
    color: rgb(15 23 42);
  }
  .dark .filter-tab:hover {
    background-color: rgb(30 41 59);
    color: rgb(248 250 252);
  }
  .filter-tab.active {
    background: linear-gradient(to right, rgb(29 78 137), rgb(30 58 138));
    color: white;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .modal-content::-webkit-scrollbar {
    width: 5px;
  }
  .modal-content::-webkit-scrollbar-track {
    background: rgb(241 245 249);
    border-radius: 10px;
  }
  .dark .modal-content::-webkit-scrollbar-track {
    background: rgb(30 41 59);
  }
  .modal-content::-webkit-scrollbar-thumb {
    background: rgb(59 130 246);
    border-radius: 10px;
  }

  .dark .ring-offset-1 {
    --tw-ring-offset-color: #0f172a;
  }

  /* Disable transitions for reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    * {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
    }
  }

  /* ============================================================
     MOBILE OPTIMIZATION: DISABLE HEAVY GPU EFFECTS
     ============================================================ */
  @media (max-width: 768px) {
    /* 1. DISABLE BACKDROP BLUR (HEAVIEST) */
    .backdrop-blur-sm,
    .backdrop-blur-md,
    .backdrop-blur-lg,
    .backdrop-blur-xl,
    .backdrop-blur-2xl,
    .bg-white\/80,
    .dark\:bg-slate-800\/80,
    .bg-white\/90,
    .dark\:bg-slate-900\/90,
