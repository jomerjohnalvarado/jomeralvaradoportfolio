<%- include('./layouts/header.ejs') %>

<div class="min-h-screen flex items-center justify-center relative overflow-hidden text-gray-900 dark:text-slate-100">

  <!-- ═══════════════════════════════════════════════════════════
       ANIMATED TECHNOLOGY BACKGROUND — DARK BLUE THEME
  ═══════════════════════════════════════════════════════════ -->
  <div class="fixed inset-0 -z-10 overflow-hidden">
    <!-- Gradient Background - Dark Blue -->
    <div class="absolute inset-0 bg-gradient-to-br from-white via-blue-50 to-indigo-50 dark:from-slate-950 dark:via-blue-950/70 dark:to-indigo-950/40"></div>
    
    <!-- Animated Code Lines -->
    <svg class="absolute inset-0 w-full h-full opacity-20 dark:opacity-30" preserveAspectRatio="none">
      <defs>
        <linearGradient id="lineGradient1" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#1e40af;stop-opacity:0" />
          <stop offset="50%" style="stop-color:#1e40af;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#1e40af;stop-opacity:0" />
        </linearGradient>
        <linearGradient id="lineGradient2" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#0284c7;stop-opacity:0" />
          <stop offset="50%" style="stop-color:#0284c7;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#0284c7;stop-opacity:0" />
        </linearGradient>
        <linearGradient id="lineGradient3" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#4f46e5;stop-opacity:0" />
          <stop offset="50%" style="stop-color:#4f46e5;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#4f46e5;stop-opacity:0" />
        </linearGradient>
        <pattern id="grid" width="100" height="100" patternUnits="userSpaceOnUse">
          <path d="M 100 0 L 0 0 0 100" fill="none" stroke="rgba(30, 64, 175, 0.3)" stroke-width="1"/>
        </pattern>
      </defs>
      
      <!-- Animated Horizontal Lines -->
      <line x1="0" y1="10%" x2="100%" y2="10%" stroke="url(#lineGradient1)" stroke-width="2" class="animate-scan-line" style="animation-delay: 0s;"/>
      <line x1="0" y1="25%" x2="100%" y2="25%" stroke="url(#lineGradient2)" stroke-width="2" class="animate-scan-line" style="animation-delay: 1s;"/>
      <line x1="0" y1="40%" x2="100%" y2="40%" stroke="url(#lineGradient1)" stroke-width="2" class="animate-scan-line" style="animation-delay: 2s;"/>
      <line x1="0" y1="55%" x2="100%" y2="55%" stroke="url(#lineGradient3)" stroke-width="2" class="animate-scan-line" style="animation-delay: 3s;"/>
      <line x1="0" y1="70%" x2="100%" y2="70%" stroke="url(#lineGradient2)" stroke-width="2" class="animate-scan-line" style="animation-delay: 1.5s;"/>
      <line x1="0" y1="85%" x2="100%" y2="85%" stroke="url(#lineGradient1)" stroke-width="2" class="animate-scan-line" style="animation-delay: 2.5s;"/>
    </svg>

    <!-- Tech Grid Pattern -->
    <svg class="absolute inset-0 w-full h-full opacity-10 dark:opacity-40" preserveAspectRatio="none">
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>

    <!-- Floating Tech Icons -->
    <div class="absolute top-20 left-20 w-24 h-24 opacity-30 dark:opacity-20 animate-float-tech" style="animation-delay: 0s;">
      <div class="w-full h-full border-2 border-blue-600/60 dark:border-blue-500/50 rounded-lg rotate-45 flex items-center justify-center">
        <i class="fas fa-search text-blue-700 dark:text-blue-400 text-3xl -rotate-45"></i>
      </div>
    </div>

    <div class="absolute top-40 right-32 w-20 h-20 opacity-30 dark:opacity-20 animate-float-tech" style="animation-delay: 2s;">
      <div class="w-full h-full border-2 border-indigo-600/60 dark:border-indigo-500/50 rounded-full flex items-center justify-center">
        <i class="fas fa-map-marker-alt text-indigo-700 dark:text-indigo-400 text-2xl"></i>
      </div>
    </div>

    <div class="absolute bottom-40 left-1/4 w-28 h-28 opacity-30 dark:opacity-20 animate-float-tech" style="animation-delay: 4s;">
      <div class="w-full h-full border-2 border-blue-600/60 dark:border-blue-500/50 rounded-lg flex items-center justify-center">
        <i class="fas fa-compass text-blue-700 dark:text-blue-400 text-3xl"></i>
      </div>
    </div>

    <div class="absolute bottom-20 right-20 w-24 h-24 opacity-30 dark:opacity-20 animate-float-tech" style="animation-delay: 1s;">
      <div class="w-full h-full border-2 border-blue-600/60 dark:border-blue-500/50 rounded-full flex items-center justify-center">
        <i class="fas fa-question text-blue-700 dark:text-blue-400 text-2xl"></i>
      </div>
    </div>

    <div class="absolute top-1/2 right-1/4 w-20 h-20 opacity-30 dark:opacity-20 animate-float-tech" style="animation-delay: 3s;">
      <div class="w-full h-full border-2 border-indigo-600/60 dark:border-indigo-500/50 rounded-lg flex items-center justify-center">
        <i class="fas fa-unlink text-indigo-700 dark:text-indigo-400 text-xl"></i>
      </div>
    </div>

    <!-- Animated Particles with Tech Style -->
    <div class="absolute inset-0 opacity-40 dark:opacity-100">
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 15%; left: 10%; animation-delay: 0s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 35%; left: 70%; animation-delay: 1.5s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 60%; left: 20%; animation-delay: 3s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue" style="top: 75%; right: 15%; animation-delay: 4.5s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top: 25%; right: 30%; animation-delay: 0.8s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top: 50%; left: 45%; animation-delay: 2.3s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top: 80%; left: 30%; animation-delay: 3.8s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-sky-500 dark:bg-sky-400 rounded-full animate-tech-float shadow-glow-sky" style="top: 40%; right: 10%; animation-delay: 1.2s;"></div>
      <div class="tech-particle absolute w-1.5 h-1.5 bg-sky-500 dark:bg-sky-400 rounded-full animate-tech-float shadow-glow-sky" style="top: 70%; right: 50%; animation-delay: 2.8s;"></div>
    </div>

    <!-- Animated Orbits -->
    <div class="absolute top-1/4 left-1/3 w-64 h-64 opacity-20 dark:opacity-30">
      <svg class="w-full h-full animate-rotate-slow" viewBox="0 0 100 100" preserveAspectRatio="none">
        <circle cx="50" cy="50" r="45" fill="none" stroke="url(#lineGradient1)" stroke-width="0.5" opacity="0.5"/>
        <circle cx="50" cy="50" r="30" fill="none" stroke="url(#lineGradient2)" stroke-width="0.5" opacity="0.5"/>
        <circle cx="50" cy="50" r="15" fill="none" stroke="url(#lineGradient3)" stroke-width="0.5" opacity="0.5"/>
        <circle cx="95" cy="50" r="2" fill="#1e40af" class="animate-orbit-1"/>
        <circle cx="50" cy="5" r="2" fill="#0284c7" class="animate-orbit-2"/>
        <circle cx="5" cy="50" r="2" fill="#4f46e5" class="animate-orbit-3"/>
      </svg>
    </div>

    <!-- Status Indicator Lights -->
    <div class="absolute top-20 right-1/3 w-3 h-3 bg-blue-500 rounded-full animate-status-pulse" style="animation-delay: 0s;">
      <div class="absolute inset-0 bg-blue-500 rounded-full animate-status-ping"></div>
    </div>
    <div class="absolute top-1/3 left-1/4 w-3 h-3 bg-indigo-500 rounded-full animate-status-pulse" style="animation-delay: 1s;">
      <div class="absolute inset-0 bg-indigo-500 rounded-full animate-status-ping"></div>
    </div>
    <div class="absolute bottom-1/3 right-1/4 w-3 h-3 bg-sky-500 rounded-full animate-status-pulse" style="animation-delay: 2s;">
      <div class="absolute inset-0 bg-sky-500 rounded-full animate-status-ping"></div>
    </div>

    <!-- Glowing Orbs with Tech Effect -->
    <div class="absolute top-0 left-1/3 w-96 h-96 bg-gradient-to-br from-blue-200/20 to-indigo-200/15 dark:from-blue-500/10 dark:to-indigo-500/5 rounded-full blur-3xl animate-pulse-glow"></div>
    <div class="absolute top-1/2 right-0 w-96 h-96 bg-gradient-to-br from-indigo-200/20 to-blue-200/15 dark:from-indigo-500/10 dark:to-blue-500/5 rounded-full blur-3xl animate-pulse-glow" style="animation-delay: 1s;"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-gradient-to-br from-blue-200/20 to-indigo-200/15 dark:from-blue-500/10 dark:to-indigo-500/5 rounded-full blur-3xl animate-pulse-glow" style="animation-delay: 2s;"></div>
  </div>

  <!-- Main Content -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-20">
    <div class="text-center">

      <!-- 404 Number -->
      <div class="relative inline-block mb-8 animate-fade-in-up">
        <h1 class="text-[140px] md:text-[220px] font-black leading-none">
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-700 via-indigo-700 to-blue-700 dark:from-blue-400 dark:via-indigo-400 dark:to-blue-400 bg-[length:200%_auto] animate-gradient-x">
            404
          </span>
        </h1>
      </div>

      <!-- Animated Icon -->
      <div class="mb-8 animate-fade-in-up animation-delay-200">
        <div class="inline-flex items-center justify-center w-28 h-28 rounded-2xl bg-gradient-to-br from-blue-100 to-indigo-100 dark:from-blue-900/50 dark:to-indigo-900/40 border-t-2 border-l-2 border-blue-500 dark:border-blue-500/60 shadow-xl animate-bounce-gentle">
          <i class="fas fa-satellite-dish text-5xl text-blue-700 dark:text-blue-400"></i>
        </div>
      </div>

      <!-- Error Message -->
      <div class="animate-fade-in-up animation-delay-400">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-slate-100 mb-4">
          Oops! Page Not Found
        </h2>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 mb-3">
          The page you're looking for seems to have wandered off into the digital void.
        </p>
        <p class="text-base text-gray-500 dark:text-gray-500 mb-10">
          Don't worry, even the best explorers get lost sometimes! 🧭
        </p>
      </div>

      <!-- Suggested Actions -->
      <div class="animate-fade-in-up animation-delay-600">
        <div class="inline-block w-full bg-white/90 dark:bg-slate-800/90 backdrop-blur-md rounded-2xl p-8 shadow-xl border-t-2 border-l-2 border-blue-500 dark:border-blue-500/70 mb-10 hover:shadow-[0_0_28px_6px_rgba(59,130,246,0.3)] transition-all duration-300">
          <p class="text-sm font-semibold text-gray-700 dark:text-slate-300 mb-6">
            <i class="fas fa-lightbulb text-blue-500 dark:text-blue-400 mr-2"></i>
            Here's what you can do:
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
            <a href="/" class="group flex flex-col items-center p-4 rounded-xl bg-blue-50 dark:bg-blue-950/30 border-t-2 border-l-2 border-blue-400 dark:border-blue-600/50 hover:shadow-[0_0_16px_3px_rgba(59,130,246,0.3)] transition-all duration-300">
              <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-blue-100 to-indigo-100 dark:from-blue-900/60 dark:to-indigo-900/50 border border-blue-300 dark:border-blue-600/60 flex items-center justify-center mb-3 group-hover:scale-110 group-hover:rotate-6 transition-all duration-300 shadow-inner">
                <i class="fas fa-home text-xl text-blue-700 dark:text-blue-400"></i>
              </div>
              <span class="text-sm font-semibold text-gray-800 dark:text-slate-200">Go Home</span>
            </a>

            <a href="/projects" class="group flex flex-col items-center p-4 rounded-xl bg-indigo-50 dark:bg-indigo-950/30 border-t-2 border-l-2 border-indigo-400 dark:border-indigo-600/50 hover:shadow-[0_0_16px_3px_rgba(99,102,241,0.3)] transition-all duration-300">
              <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-indigo-100 to-blue-100 dark:from-indigo-900/60 dark:to-blue-900/50 border border-indigo-300 dark:border-indigo-600/60 flex items-center justify-center mb-3 group-hover:scale-110 group-hover:rotate-6 transition-all duration-300 shadow-inner">
                <i class="fas fa-folder-open text-xl text-indigo-700 dark:text-indigo-400"></i>
              </div>
              <span class="text-sm font-semibold text-gray-800 dark:text-slate-200">View Projects</span>
            </a>

            <a href="/contact" class="group flex flex-col items-center p-4 rounded-xl bg-sky-50 dark:bg-sky-950/30 border-t-2 border-l-2 border-sky-400 dark:border-sky-600/50 hover:shadow-[0_0_16px_3px_rgba(14,165,233,0.3)] transition-all duration-300">
              <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-sky-100 to-blue-100 dark:from-sky-900/60 dark:to-blue-900/50 border border-sky-300 dark:border-sky-600/60 flex items-center justify-center mb-3 group-hover:scale-110 group-hover:rotate-6 transition-all duration-300 shadow-inner">
                <i class="fas fa-envelope text-xl text-sky-700 dark:text-sky-400"></i>
              </div>
              <span class="text-sm font-semibold text-gray-800 dark:text-slate-200">Contact Me</span>
            </a>
          </div>

          <!-- Primary CTA Buttons -->
          <div class="flex flex-wrap gap-4 justify-center">
            <a href="/" class="group inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-blue-700 to-indigo-700 hover:shadow-lg hover:shadow-blue-500/50 text-white rounded-xl font-bold shadow-lg hover:scale-105 active:scale-95 transition-all duration-300 border-t-2 border-l-2 border-blue-900/50">
              <i class="fas fa-arrow-left group-hover:-translate-x-1 transition-transform duration-300"></i>
              <span>Back to Homepage</span>
            </a>

            <button onclick="history.back()" class="group inline-flex items-center gap-2 px-8 py-4 bg-white/50 dark:bg-slate-900/50 backdrop-blur-sm hover:bg-blue-500/10 text-blue-700 dark:text-blue-400 rounded-xl font-bold shadow-lg border-t-2 border-l-2 border-blue-600 dark:border-blue-500/60 hover:scale-105 active:scale-95 transition-all duration-300">
              <i class="fas fa-undo group-hover:-rotate-45 transition-transform duration-300"></i>
              <span>Go Back</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Fun Error Code Message -->
      <div class="animate-fade-in-up animation-delay-800">
        <div class="inline-block px-6 py-3 bg-blue-100 dark:bg-blue-900/40 rounded-full border-t-2 border-l-2 border-blue-500 dark:border-blue-500/60">
          <p class="text-sm font-mono text-blue-800 dark:text-blue-300">
            <i class="fas fa-code text-blue-600 dark:text-blue-400 mr-2"></i>
            Error Code: <span class="text-red-500 dark:text-red-400 font-bold">PAGE_NOT_FOUND</span>
          </p>
        </div>
      </div>

      <!-- Additional Links -->
      <div class="mt-10 animate-fade-in-up animation-delay-1000">
        <p class="text-sm text-gray-500 dark:text-gray-500 mb-4">
          Quick Links:
        </p>
        <div class="flex flex-wrap gap-4 justify-center text-sm">
          <a href="/about" class="text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-semibold hover:underline transition-colors duration-300">
            About Me
          </a>
          <span class="text-slate-300 dark:text-slate-700">|</span>
          <a href="/services" class="text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-semibold hover:underline transition-colors duration-300">
            Services
          </a>
          <span class="text-slate-300 dark:text-slate-700">|</span>
          <a href="/blog" class="text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-semibold hover:underline transition-colors duration-300">
            Blog
          </a>
          <span class="text-slate-300 dark:text-slate-700">|</span>
          <a href="/faq" class="text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-semibold hover:underline transition-colors duration-300">
            FAQ
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- Decorative Bottom Bar -->
  <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-blue-500 via-indigo-500 to-sky-500"></div>
</div>

<style>
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  .shadow-glow-blue {
    box-shadow: 0 0 10px rgba(30, 64, 175, 0.8), 0 0 20px rgba(30, 64, 175, 0.4);
  }

  .shadow-glow-indigo {
    box-shadow: 0 0 10px rgba(79, 70, 229, 0.8), 0 0 20px rgba(79, 70, 229, 0.4);
  }

  .shadow-glow-sky {
    box-shadow: 0 0 10px rgba(2, 132, 199, 0.8), 0 0 20px rgba(2, 132, 199, 0.4);
  }

  @keyframes scan-line {
    0%, 100% { opacity: 0; transform: translateX(-100%) translateZ(0); }
    50% { opacity: 1; }
  }
  .animate-scan-line {
    animation: scan-line 4s ease-in-out infinite;
    will-change: transform, opacity;
  }

  @keyframes float-tech {
    0%, 100% { transform: translateY(0px) rotateZ(0deg) translateZ(0); }
    25% { transform: translateY(-20px) rotateZ(5deg) translateZ(0); }
    50% { transform: translateY(-40px) rotateZ(0deg) translateZ(0); }
    75% { transform: translateY(-20px) rotateZ(-5deg) translateZ(0); }
  }
  .animate-float-tech {
    animation: float-tech 8s ease-in-out infinite;
    will-change: transform;
  }

  @keyframes tech-float {
    0% { transform: translateY(100vh) translateX(0) translateZ(0); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(-100vh) translateX(100px) translateZ(0); opacity: 0; }
  }
  .animate-tech-float {
    animation: tech-float 20s linear infinite;
    will-change: transform, opacity;
  }

  @keyframes rotate-slow {
    0% { transform: rotate(0deg) translateZ(0); }
    100% { transform: rotate(360deg) translateZ(0); }
  }
  .animate-rotate-slow {
    animation: rotate-slow 20s linear infinite;
    will-change: transform;
  }

  @keyframes orbit-1 {
    0% { cx: 95; cy: 50; } 33.33% { cx: 50; cy: 5; } 66.66% { cx: 5; cy: 50; } 100% { cx: 95; cy: 50; }
  }
  @keyframes orbit-2 {
    0% { cx: 50; cy: 5; } 33.33% { cx: 5; cy: 50; } 66.66% { cx: 95; cy: 50; } 100% { cx: 50; cy: 5; }
  }
  @keyframes orbit-3 {
    0% { cx: 5; cy: 50; } 33.33% { cx: 95; cy: 50; } 66.66% { cx: 50; cy: 5; } 100% { cx: 5; cy: 50; }
  }
  .animate-orbit-1 { animation: orbit-1 6s linear infinite; }
  .animate-orbit-2 { animation: orbit-2 6s linear infinite; }
  .animate-orbit-3 { animation: orbit-3 6s linear infinite; }

  @keyframes status-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 10px currentColor; }
    50% { opacity: 0.5; box-shadow: 0 0 5px currentColor; }
  }
  .animate-status-pulse {
    animation: status-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes status-ping {
    75%, 100% { transform: scale(2) translateZ(0); opacity: 0; }
  }
  .animate-status-ping {
    animation: status-ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
    will-change: transform, opacity;
  }

  @keyframes pulse-glow {
    0%, 100% { opacity: 0.5; filter: blur(30px); }
    50% { opacity: 1; filter: blur(15px); }
  }
  .animate-pulse-glow {
    animation: pulse-glow 4s ease-in-out infinite;
    will-change: opacity, filter;
  }

  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(30px) translateZ(0); }
    to { opacity: 1; transform: translateY(0) translateZ(0); }
  }
  .animate-fade-in-up {
    animation: fade-in-up 0.8s ease-out forwards;
    will-change: transform, opacity;
  }

  .animation-delay-200 { animation-delay: 0.2s; }
  .animation-delay-400 { animation-delay: 0.4s; }
  .animation-delay-600 { animation-delay: 0.6s; }
  .animation-delay-800 { animation-delay: 0.8s; }
  .animation-delay-1000 { animation-delay: 1s; }

  @keyframes bounce-gentle {
    0%, 100% { transform: translateY(0) translateZ(0); }
    50% { transform: translateY(-10px) translateZ(0); }
  }
  .animate-bounce-gentle {
    animation: bounce-gentle 2s ease-in-out infinite;
  }

  @keyframes gradient-x {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .animate-gradient-x {
    animation: gradient-x 4s ease infinite;
  }

  .animate-scan-line,
  .animate-float-tech,
  .animate-tech-float,
  .animate-rotate-slow,
  .animate-pulse-glow,
  .animate-fade-in-up {
    contain: layout style paint;
  }

  @media (max-width: 768px) {
    .animate-float-tech,
    .animate-rotate-slow { animation-duration: 12s; }
    .animate-tech-float { animation-duration: 30s; }
  }
</style>

<%- include('./layouts/footer.ejs') %>