<%- include('./layouts/header.ejs') %>

<div class="pt-32 pb-20 min-h-screen relative overflow-hidden text-gray-900 dark:text-slate-100">

    <!-- ═══════════════════════════════════════════════════════════
         ANIMATED BACKGROUND — REDUCED ICONS
    ═══════════════════════════════════════════════════════════ -->
    <div class="fixed inset-0 -z-10 overflow-hidden">
        <!-- Base gradient -->
        <div class="absolute inset-0 bg-gradient-to-br from-white via-blue-50 to-indigo-50 dark:from-slate-950 dark:via-blue-950/70 dark:to-indigo-950/40"></div>

        <!-- Scan lines -->
        <svg class="absolute inset-0 w-full h-full opacity-20 dark:opacity-30" preserveAspectRatio="none">
            <defs>
                <linearGradient id="lg1" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%"   style="stop-color:#1e40af;stop-opacity:0"/>
                    <stop offset="50%"  style="stop-color:#1e40af;stop-opacity:1"/>
                    <stop offset="100%" style="stop-color:#1e40af;stop-opacity:0"/>
                </linearGradient>
                <linearGradient id="lg2" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%"   style="stop-color:#3b82f6;stop-opacity:0"/>
                    <stop offset="50%"  style="stop-color:#3b82f6;stop-opacity:1"/>
                    <stop offset="100%" style="stop-color:#3b82f6;stop-opacity:0"/>
                </linearGradient>
                <linearGradient id="lg3" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%"   style="stop-color:#6366f1;stop-opacity:0"/>
                    <stop offset="50%"  style="stop-color:#6366f1;stop-opacity:1"/>
                    <stop offset="100%" style="stop-color:#6366f1;stop-opacity:0"/>
                </linearGradient>
                <linearGradient id="lg4" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%"   style="stop-color:#06b6d4;stop-opacity:0"/>
                    <stop offset="50%"  style="stop-color:#06b6d4;stop-opacity:1"/>
                    <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:0"/>
                </linearGradient>
                <linearGradient id="lg5" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%"   style="stop-color:#8b5cf6;stop-opacity:0"/>
                    <stop offset="50%"  style="stop-color:#8b5cf6;stop-opacity:1"/>
                    <stop offset="100%" style="stop-color:#8b5cf6;stop-opacity:0"/>
                </linearGradient>
                <pattern id="grid" width="100" height="100" patternUnits="userSpaceOnUse">
                    <path d="M 100 0 L 0 0 0 100" fill="none" stroke="rgba(30,64,175,0.3)" stroke-width="1"/>
                </pattern>
                <pattern id="grid-dot" width="60" height="60" patternUnits="userSpaceOnUse">
                    <circle cx="30" cy="30" r="1.5" fill="rgba(59,130,246,0.25)" />
                </pattern>
            </defs>
            <line x1="0" y1="8%"  x2="100%" y2="8%"  stroke="url(#lg1)" stroke-width="2" class="animate-scan-line" style="animation-delay:0s"/>
            <line x1="0" y1="22%" x2="100%" y2="22%" stroke="url(#lg2)" stroke-width="2" class="animate-scan-line" style="animation-delay:0.8s"/>
            <line x1="0" y1="36%" x2="100%" y2="36%" stroke="url(#lg4)" stroke-width="2" class="animate-scan-line" style="animation-delay:1.6s"/>
            <line x1="0" y1="50%" x2="100%" y2="50%" stroke="url(#lg3)" stroke-width="2" class="animate-scan-line" style="animation-delay:2.4s"/>
            <line x1="0" y1="64%" x2="100%" y2="64%" stroke="url(#lg5)" stroke-width="2" class="animate-scan-line" style="animation-delay:3.2s"/>
            <line x1="0" y1="78%" x2="100%" y2="78%" stroke="url(#lg2)" stroke-width="2" class="animate-scan-line" style="animation-delay:1.2s"/>
            <line x1="0" y1="92%" x2="100%" y2="92%" stroke="url(#lg1)" stroke-width="2" class="animate-scan-line" style="animation-delay:2s"/>
        </svg>

        <!-- Grid overlays -->
        <svg class="absolute inset-0 w-full h-full opacity-10 dark:opacity-40" preserveAspectRatio="none">
            <rect width="100%" height="100%" fill="url(#grid)"/>
        </svg>
        <svg class="absolute inset-0 w-full h-full opacity-5 dark:opacity-20" preserveAspectRatio="none">
            <rect width="100%" height="100%" fill="url(#grid-dot)"/>
        </svg>

        <!-- ═══ FLOATING TECH ICONS — REDUCED TO 6 ═══ -->
        <!-- Icon 1: Code -->
        <div class="absolute top-20 left-20 w-24 h-24 opacity-30 dark:opacity-20 animate-float-tech" style="animation-delay:0s">
            <div class="w-full h-full border-2 border-blue-600/60 dark:border-blue-500/50 rounded-2xl rotate-45 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
                <i class="fas fa-code text-blue-700 dark:text-blue-400 text-3xl -rotate-45"></i>
            </div>
        </div>

        <!-- Icon 2: Server -->
        <div class="absolute top-40 right-32 w-20 h-20 opacity-30 dark:opacity-20 animate-float-tech" style="animation-delay:2s">
            <div class="w-full h-full border-2 border-indigo-600/60 dark:border-indigo-500/50 rounded-full flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
                <i class="fas fa-server text-indigo-700 dark:text-indigo-400 text-2xl"></i>
            </div>
        </div>

        <!-- Icon 3: Database -->
        <div class="absolute bottom-40 left-1/4 w-28 h-28 opacity-30 dark:opacity-20 animate-float-tech" style="animation-delay:4s">
            <div class="w-full h-full border-2 border-blue-600/60 dark:border-blue-500/50 rounded-2xl flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
                <i class="fas fa-database text-blue-700 dark:text-blue-400 text-3xl"></i>
            </div>
        </div>

        <!-- Icon 4: JavaScript -->
        <div class="absolute top-32 left-1/3 w-16 h-16 opacity-25 dark:opacity-15 animate-float-tech" style="animation-delay:0.6s">
            <div class="w-full h-full border-2 border-cyan-600/60 dark:border-cyan-500/50 rounded-xl rotate-12 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
                <i class="fab fa-js text-cyan-700 dark:text-cyan-400 text-xl -rotate-12"></i>
            </div>
        </div>

        <!-- Icon 5: React -->
        <div class="absolute bottom-32 right-1/4 w-16 h-16 opacity-25 dark:opacity-15 animate-float-tech" style="animation-delay:0.3s">
            <div class="w-full h-full border-2 border-pink-600/60 dark:border-pink-500/50 rounded-xl -rotate-12 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
                <i class="fab fa-react text-pink-700 dark:text-pink-400 text-xl rotate-12"></i>
            </div>
        </div>

        <!-- Icon 6: Python -->
        <div class="absolute top-1/3 left-10 w-14 h-14 opacity-25 dark:opacity-15 animate-float-tech" style="animation-delay:2.6s">
            <div class="w-full h-full border-2 border-violet-600/60 dark:border-violet-500/50 rounded-xl -rotate-6 flex items-center justify-center bg-white/10 dark:bg-black/10 backdrop-blur-sm">
                <i class="fab fa-python text-violet-700 dark:text-violet-400 text-lg rotate-6"></i>
            </div>
        </div>

        <!-- ═══ FLOATING CODE BRACKETS ═══ -->
        <div class="absolute top-28 left-2/3 text-4xl font-mono font-bold text-blue-600/20 dark:text-blue-400/15 animate-float-bracket" style="animation-delay:0.3s">
            { }
        </div>
        <div class="absolute bottom-32 left-1/5 text-3xl font-mono font-bold text-indigo-600/20 dark:text-indigo-400/15 animate-float-bracket" style="animation-delay:1.8s">
            &lt; / &gt;
        </div>
        <div class="absolute top-1/3 right-1/5 text-4xl font-mono font-bold text-cyan-600/15 dark:text-cyan-400/12 animate-float-bracket" style="animation-delay:2.6s">
            [ ]
        </div>

        <!-- ═══ TERMINAL CURSOR ═══ -->
        <div class="absolute top-1/2 left-8 text-sm font-mono text-blue-600/20 dark:text-blue-400/15 animate-terminal-cursor hidden sm:block" style="animation-delay:0s">
            <span class="opacity-80">$</span>
            <span class="text-cyan-600/25 dark:text-cyan-400/20"> npm install --save</span>
            <span class="inline-block w-2 h-4 bg-blue-600/30 dark:bg-blue-400/25 ml-1 animate-blink-cursor"></span>
        </div>
        <div class="absolute bottom-1/4 right-8 text-sm font-mono text-indigo-600/20 dark:text-indigo-400/15 animate-terminal-cursor" style="animation-delay:3s">
            <span class="opacity-80">$</span>
            <span class="text-violet-600/25 dark:text-violet-400/20"> git push origin main</span>
            <span class="inline-block w-2 h-4 bg-indigo-600/30 dark:bg-indigo-400/25 ml-1 animate-blink-cursor"></span>
        </div>

        <!-- ═══ PARTICLES — REDUCED ═══ -->
        <div class="absolute inset-0 opacity-40 dark:opacity-100">
            <!-- Blue particles -->
            <div class="absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue"   style="top:15%;left:10%;animation-delay:0s"></div>
            <div class="absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue"   style="top:35%;left:70%;animation-delay:1.5s"></div>
            <div class="absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue"   style="top:60%;left:20%;animation-delay:3s"></div>
            <div class="absolute w-1.5 h-1.5 bg-blue-600 dark:bg-blue-400 rounded-full animate-tech-float shadow-glow-blue"   style="top:75%;right:15%;animation-delay:4.5s"></div>
            
            <!-- Indigo particles -->
            <div class="absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top:25%;right:30%;animation-delay:0.8s"></div>
            <div class="absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top:50%;left:45%;animation-delay:2.3s"></div>
            <div class="absolute w-1.5 h-1.5 bg-indigo-600 dark:bg-indigo-400 rounded-full animate-tech-float shadow-glow-indigo" style="top:80%;left:30%;animation-delay:3.8s"></div>
            
            <!-- Sky particles -->
            <div class="absolute w-1.5 h-1.5 bg-sky-500 dark:bg-sky-400 rounded-full animate-tech-float shadow-glow-sky"     style="top:40%;right:10%;animation-delay:1.2s"></div>
            <div class="absolute w-1.5 h-1.5 bg-sky-500 dark:bg-sky-400 rounded-full animate-tech-float shadow-glow-sky"     style="top:70%;right:50%;animation-delay:2.8s"></div>
            
            <!-- Violet particles -->
            <div class="absolute w-1.5 h-1.5 bg-violet-500 dark:bg-violet-400 rounded-full animate-tech-float shadow-glow-violet" style="top:30%;left:55%;animation-delay:0.5s"></div>
            <div class="absolute w-1.5 h-1.5 bg-violet-500 dark:bg-violet-400 rounded-full animate-tech-float shadow-glow-violet" style="top:90%;right:30%;animation-delay:2s"></div>
        </div>

        <!-- ═══ ANIMATED ORBITS ═══ -->
        <div class="absolute top-1/4 left-1/3 w-64 h-64 opacity-20 dark:opacity-30">
            <svg class="w-full h-full animate-rotate-slow" viewBox="0 0 100 100" preserveAspectRatio="none">
                <circle cx="50" cy="50" r="45" fill="none" stroke="url(#lg1)" stroke-width="0.5" opacity="0.5"/>
                <circle cx="50" cy="50" r="30" fill="none" stroke="url(#lg2)" stroke-width="0.5" opacity="0.5"/>
                <circle cx="50" cy="50" r="15" fill="none" stroke="url(#lg3)" stroke-width="0.5" opacity="0.5"/>
                <circle cx="95" cy="50" r="2.5" fill="#1e40af" class="animate-orbit-1"/>
                <circle cx="50" cy="5"  r="2.5" fill="#3b82f6" class="animate-orbit-2"/>
                <circle cx="5"  cy="50" r="2.5" fill="#6366f1" class="animate-orbit-3"/>
            </svg>
        </div>

        <!-- ═══ STATUS LIGHTS ═══ -->
        <div class="absolute top-20 right-1/3 w-3 h-3 bg-blue-500 rounded-full animate-status-pulse" style="animation-delay:0s">
            <div class="absolute inset-0 bg-blue-500 rounded-full animate-status-ping"></div>
        </div>
        <div class="absolute top-1/3 left-1/4 w-3 h-3 bg-indigo-500 rounded-full animate-status-pulse" style="animation-delay:1s">
            <div class="absolute inset-0 bg-indigo-500 rounded-full animate-status-ping"></div>
        </div>
        <div class="absolute bottom-1/3 right-1/4 w-3 h-3 bg-sky-500 rounded-full animate-status-pulse" style="animation-delay:2s">
            <div class="absolute inset-0 bg-sky-500 rounded-full animate-status-ping"></div>
        </div>

        <!-- ═══ GLOWING ORBS ═══ -->
        <div class="absolute top-0 left-1/3 w-96 h-96 bg-gradient-to-br from-blue-200/20 to-indigo-200/15 dark:from-blue-500/10 dark:to-indigo-500/5 rounded-full blur-3xl animate-pulse-glow"></div>
        <div class="absolute bottom-0 left-0 w-96 h-96 bg-gradient-to-br from-blue-200/20 to-indigo-200/15 dark:from-blue-500/10 dark:to-indigo-500/5 rounded-full blur-3xl animate-pulse-glow" style="animation-delay:2s"></div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         PAGE HEADER
    ═══════════════════════════════════════════════════════════ -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20 relative z-10">
        <div class="text-center animate-fade-in-up">

            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-lg
                  bg-gradient-to-r from-blue-100 to-indigo-100
                  dark:from-blue-900/40 dark:to-indigo-900/40
                  border-t-2 border-l-2 border-blue-600 dark:border-blue-500/60
                  mb-6 backdrop-blur-sm hover:scale-105 transition-transform duration-300 shadow-lg">
                <i class="fas fa-bolt text-blue-700 dark:text-blue-400"></i>
                <span class="text-sm font-bold text-blue-800 dark:text-blue-300">My Arsenal</span>
            </div>

            <h1 class="text-5xl md:text-7xl font-black mb-6 animate-fade-in-up" style="animation-delay:0.1s">
                <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-700 to-indigo-700 dark:from-blue-400 dark:to-indigo-400">
                    Skills &
                </span>
                <br/>
                <span class="bg-clip-text text-transparent bg-gradient-to-r from-indigo-700 to-blue-700 dark:from-indigo-400 dark:to-blue-400">
                    Technologies
                </span>
            </h1>

            <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto animate-fade-in-up" style="animation-delay:0.2s">
                A comprehensive overview of the technologies, tools and expertise I bring to every project.
            </p>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         SKILLS PROFICIENCY — FULL-WIDTH HORIZONTAL BARS
    ═══════════════════════════════════════════════════════════ -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-24 relative z-10">

        <!-- Section divider -->
        <div class="flex items-center justify-center gap-3 mb-10 animate-fade-in-up">
            <div class="h-px flex-1 bg-gradient-to-r from-transparent to-blue-500/50 dark:to-blue-400/40"></div>
            <span class="flex items-center gap-2 text-lg font-bold text-gray-700 dark:text-gray-300 px-4">
                <i class="fas fa-chart-bar text-blue-600 dark:text-blue-400"></i>
                Skill Proficiency
            </span>
            <div class="h-px flex-1 bg-gradient-to-l from-transparent to-blue-500/50 dark:to-blue-400/40"></div>
        </div>

        <%
          const skillsOverview = [
            { name: 'Web Development',              pct: 60, icon: 'globe',      from: '#1d4ed8', to: '#3b82f6', shadow: 'rgba(59,130,246,0.55)'  },
            { name: 'Graphic Design',               pct: 70, icon: 'palette',    from: '#1e3a8a', to: '#2563eb', shadow: 'rgba(37,99,235,0.55)'   },
            { name: 'Photography',                  pct: 80, icon: 'camera',     from: '#1e40af', to: '#60a5fa', shadow: 'rgba(96,165,250,0.55)'  },
            { name: 'Photo & Video Editing',        pct: 75, icon: 'film',       from: '#1d4ed8', to: '#818cf8', shadow: 'rgba(129,140,248,0.55)' },
            { name: 'AI Prompting',                 pct: 85, icon: 'brain',      from: '#2563eb', to: '#38bdf8', shadow: 'rgba(56,189,248,0.55)'  },
            { name: 'IT Support & Troubleshooting', pct: 75, icon: 'wrench',     from: '#1e3a8a', to: '#6366f1', shadow: 'rgba(99,102,241,0.55)'  },
            { name: 'Office & Task Management',     pct: 90, icon: 'tasks',      from: '#1d4ed8', to: '#93c5fd', shadow: 'rgba(147,197,253,0.55)' },
            { name: 'Versatile & Analytical',       pct: 80, icon: 'chart-bar',  from: '#1e40af', to: '#4f46e5', shadow: 'rgba(79,70,229,0.55)'   },
            { name: 'App Development (Flutter)',    pct: 50, icon: 'mobile-alt', from: '#1e3a8a', to: '#3b82f6', shadow: 'rgba(59,130,246,0.55)'  },
            { name: 'Programming',                  pct: 40, icon: 'code',       from: '#1d4ed8', to: '#7dd3fc', shadow: 'rgba(125,211,252,0.55)' }
          ];
        %>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% skillsOverview.forEach((skill, i) => { %>
            <div
            class="group skill-card bg-white/90 dark:bg-slate-800/90 backdrop-blur-md rounded-2xl p-5 shadow-md
            border-t-2 border-l-2 border-blue-500 dark:border-blue-500/70
            transition-all duration-300 hover:-translate-y-1 animate-fade-in-up"
            style="animation-delay:<%= i * 0.07 %>s;
            --hover-shadow: <%= skill.shadow %>;
            --bar-from: <%= skill.from %>;
            --bar-to:   <%= skill.to %>;">

            <!-- Top row: icon + name + percentage -->
            <div class="flex items-center gap-4 mb-4">

                <!-- Icon bubble -->
                <div class="w-12 h-12 flex-shrink-0 rounded-xl
                      bg-gradient-to-br from-blue-100 to-indigo-100
                      dark:from-blue-900/60 dark:to-indigo-900/50
                      border border-blue-300 dark:border-blue-600/60
                      flex items-center justify-center shadow-inner
                      group-hover:scale-110 group-hover:rotate-6 transition-all duration-300">
                    <i class="fas fa-<%= skill.icon %> text-lg text-blue-700 dark:text-blue-300"></i>
                </div>

                <!-- Name -->
                <p class="flex-1 font-bold text-gray-800 dark:text-slate-100 text-sm leading-tight">
                    <%= skill.name %>
                </p>

                <!-- Percentage badge -->
                <span class="flex-shrink-0 px-2.5 py-1 rounded-lg text-xs font-black
                      bg-blue-100 dark:bg-blue-900/40
                      text-blue-700 dark:text-blue-300
                      border border-blue-300 dark:border-blue-600/60">
                    <%= skill.pct %>%
                </span>
            </div>

            <!-- Progress bar track -->
            <div class="relative w-full h-3 bg-gray-200 dark:bg-slate-700/80 rounded-full overflow-visible">

                <!-- Tick marks at 25 / 50 / 75 -->
                <% [25, 50, 75].forEach(tick => { %>
                <div class="absolute top-1/2 -translate-y-1/2 flex flex-col items-center z-10"
                style="left:<%= tick %>%;">
                <div class="w-px h-5 -mt-1 bg-blue-400/50 dark:bg-blue-400/40"></div>
            </div>
            <% }); %>

            <!-- Filled bar -->
            <div class="skill-bar h-full rounded-full relative overflow-hidden"
            style="width:0%;
            background: linear-gradient(90deg, var(--bar-from), var(--bar-to));
            transition: width 1s cubic-bezier(0.4,0,0.2,1);
            box-shadow: 0 0 10px var(--hover-shadow);"
            data-width="<%= skill.pct %>%">
            <!-- Shimmer -->
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/25 to-transparent animate-shimmer"></div>
        </div>
    </div>

    <!-- Scale labels -->
    <div class="flex justify-between mt-2 px-0.5">
        <span class="text-xs text-gray-400 dark:text-blue-900/60 dark:text-slate-500 font-medium">0%</span>
        <span class="text-xs text-gray-400 dark:text-slate-500 font-medium">25%</span>
        <span class="text-xs text-gray-400 dark:text-slate-500 font-medium">50%</span>
        <span class="text-xs text-gray-400 dark:text-slate-500 font-medium">75%</span>
        <span class="text-xs text-gray-400 dark:text-slate-500 font-medium">100%</span>
    </div>

</div>
<% }); %>
</div>
</section>

<!-- ═══════════════════════════════════════════════════════════
     TECH STACK + CERTIFICATIONS
═══════════════════════════════════════════════════════════ -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-24 relative z-10">

    <div class="flex items-center justify-center gap-3 mb-10 animate-fade-in-up">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent to-indigo-500/50 dark:to-indigo-400/40"></div>
        <span class="flex items-center gap-2 text-lg font-bold text-gray-700 dark:text-gray-300 px-4">
            <i class="fas fa-layers text-indigo-600 dark:text-indigo-400"></i>
            Tech Stack & Credentials
        </span>
        <div class="h-px flex-1 bg-gradient-to-l from-transparent to-indigo-500/50 dark:to-indigo-400/40"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">

        <!-- Key Expertise -->
        <div class="group/card bg-white/90 dark:bg-slate-800/90 backdrop-blur-md rounded-2xl p-8 shadow-md
                border-t-2 border-l-2 border-blue-600 dark:border-blue-500/70
                hover:shadow-[0_0_28px_6px_rgba(59,130,246,0.45)]
                transition-all duration-300 hover:-translate-y-1 animate-fade-in-up">
            <h3 class="text-xl font-bold mb-6 flex items-center gap-3 text-gray-900 dark:text-slate-100">
                <span class="w-10 h-10 rounded-xl
                      bg-gradient-to-br from-blue-100 to-indigo-100 dark:from-blue-900/60 dark:to-indigo-900/50
                      border border-blue-300 dark:border-blue-600/60
                      flex items-center justify-center shadow-inner
                      group-hover/card:scale-110 group-hover/card:rotate-6 transition-all duration-300">
                    <i class="fas fa-laptop text-blue-700 dark:text-blue-400"></i>
                </span>
                Key Expertise
            </h3>
            <div class="space-y-3">
                <%
                  const stacks = [
                    { title: 'Web Development',  items: 'React, Vue.js, Tailwind CSS, JavaScript / TypeScript', icon: 'globe'      },
                    { title: 'Business Tools',   items: 'Office Software, Power BI, SmartBooks, Task Mgmt',     icon: 'briefcase'  },
                    { title: 'Creative Suite',   items: 'Graphic Design, Photography, Video Editing',            icon: 'palette'    },
                    { title: 'Mobile & AI',      items: 'Flutter, App Development, AI Prompting',               icon: 'mobile-alt' }
                  ];
                  stacks.forEach((s, si) => {
                %>
                <div class="flex items-start gap-3 p-4 rounded-xl
